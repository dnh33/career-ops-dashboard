---
// Card.astro — Signal Card Atomic Unit
// Design System Foundation §3.3.3 & §4.2.3
// Astro + module script, semantic tokens only, data-* attributes for config

interface Props {
  /** Card variant: default | elevated | interactive */
  variant?: 'default' | 'elevated' | 'interactive';
  /** Grade badge variant: high | mid | low — uses semantic grade tokens */
  grade?: 'high' | 'mid' | 'low';
  /** Signal indicator: live (pulse) | stale | offline */
  signal?: 'live' | 'stale' | 'offline';
  /** Optional custom class */
  class?: string;
  /** Card content */
  children: any;
}

const {
  variant = 'default',
  grade,
  signal,
  class: className = '',
  children,
} = Astro.props;

/* Variant class mapping */
const variantClassMap: Record<string, string> = {
  default: 'signal-card--default',
  elevated: 'signal-card--elevated',
  interactive: 'signal-card--interactive',
};

/* Grade token mapping */
const gradeTokenMap: Record<string, { bg: string; text: string; dot: string }> = {
  high: {
    bg: 'var(--grade-high-bg)',
    text: 'var(--grade-high-text)',
    dot: 'var(--grade-high)',
  },
  mid: {
    bg: 'var(--grade-mid-bg)',
    text: 'var(--grade-mid-text)',
    dot: 'var(--grade-mid)',
  },
  low: {
    bg: 'var(--grade-low-bg)',
    text: 'var(--grade-low-text)',
    dot: 'var(--grade-low)',
  },
};

const variantClass = variantClassMap[variant] ?? variantClassMap.default;
const gradeTokens = grade ? gradeTokenMap[grade] : null;
const signalColor = signal ? gradeTokenMap[signal]?.dot : null;

/* Unique ID for signal indicator animation */
const signalId = `signal-${Math.random().toString(36).substring(2, 9)}`;
---

<article
  class:list={[
    'signal-card',
    variantClass,
    className,
  ]}
  data-component="signal-card"
  data-variant={variant}
  data-grade={grade || ''}
  data-signal={signal || ''}
  data-signal-id={signalId}
>
  {/* Grade badge - top right */}
  {gradeTokens && (
    <span
      class="signal-card__grade-badge"
      style={`background: ${gradeTokens.bg}; color: ${gradeTokens.text};`}
      aria-label={`Grade: ${grade}`}
    >
      {grade.toUpperCase()}
    </span>
  )}

  {/* Signal indicator dot - top left */}
  {signalColor && (
    <span
      class:list={[
        'signal-card__signal-dot',
        signal === 'live' && 'signal-card__signal-dot--live',
      ]}
      style={`background: ${signalColor};`}
      aria-label={`Signal: ${signal}`}
      data-signal-state={signal}
    >
      {signal === 'live' && <span class="signal-card__pulse-ring" aria-hidden="true" />}
    </span>
  )}

  {/* Card content */}
  <div class="signal-card__content">
    <slot />
  </div>

  {/* Radar mini slot - bottom area */}
  <div class="signal-card__radar-mini">
    <slot name="radar-mini" />
  </div>
</article>

<style>
  .signal-card {
    position: relative;
    background: var(--card-bg);
    border: var(--border-width) solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition:
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }
  /* Variant: default - base card */
  .signal-card--default {
    /* base styles only */
  }

  /* Variant: elevated - more prominent */
  .signal-card--elevated {
    box-shadow: var(--shadow-md);
    border-color: var(--border-hover);
  }

  /* Variant: interactive - hover/click states */
  .signal-card--interactive {
    cursor: pointer;
  }
  .signal-card--interactive:hover {
    background: var(--card-hover-bg);
    border-color: var(--card-hover-border);
  }
  .signal-card--interactive:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  /* Grade badge - top right corner */
  .signal-card__grade-badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    font-family: var(--font-sans);
    border-radius: var(--radius-sm);
    line-height: 1;
    white-space: nowrap;
  }

  /* Signal indicator dot - top left corner */
  .signal-card__signal-dot {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    width: var(--size-2);
    height: var(--size-2);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Pulse animation for live signal */
  .signal-card__signal-dot--live {
    animation: signal-pulse 2s ease-out infinite;
  }

  .signal-card__pulse-ring {
    position: absolute;
    inset: calc(-1 * var(--size-1));
    border-radius: var(--radius-full);
    border: var(--border-width-thick) solid currentColor;
    opacity: 0;
    animation: pulse-ring 2s ease-out infinite;
  }

  @keyframes signal-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  @keyframes pulse-ring {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(2.5);
      opacity: 0;
    }
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .signal-card__signal-dot--live,
    .signal-card__pulse-ring {
      animation: none !important;
    }
    .signal-card__pulse-ring {
      display: none;
    }
  }

  /* Card content area */
  .signal-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    z-index: 1;
  }

  /* Radar mini slot area */
  .signal-card__radar-mini {
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: var(--border-width) solid var(--border-default);
    min-height: var(--size-15);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .signal-card__radar-mini:empty {
    display: none;
  }

  /* MutationObserver will auto-apply these to headings/paragraphs */
  .signal-card__content :not([class*="text-"]) h1,
  .signal-card__content :not([class*="text-"]) h2,
  .signal-card__content :not([class*="text-"]) h3,
  .signal-card__content :not([class*="text-"]) h4,
  .signal-card__content :not([class*="text-"]) h5,
  .signal-card__content :not([class*="text-"]) h6 {
    font-family: var(--font-display);
    color: var(--color-heading);
    font-weight: var(--font-bold);
    line-height: 1.1;
  }

  .signal-card__content :not([class*="text-"]) p {
    color: var(--color-body);
    line-height: 1.7;
  }
</style>

<script>
  // Module-scoped initialization for signal-card component
  // Auto-enforce heading/body hierarchy via MutationObserver
  // Enhanced interactivity: hover effects, click handling

  export function initSignalCard(root: HTMLElement) {
    const cards = root.querySelectorAll('[data-component="signal-card"]');

    cards.forEach((card) => {
      // MutationObserver to enforce text-heading/text-body hierarchy
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (node.nodeType !== Node.ELEMENT_NODE) return;
            const element = node as HTMLElement;

            // Enforce heading hierarchy
            const headings = element.querySelectorAll('h1, h2, h3, h4, h5, h6');
            headings.forEach((heading) => {
              if (!heading.classList.contains('text-heading') &&
                  !heading.hasAttribute('class')?.includes('text-')) {
                heading.classList.add('text-heading');
              }
            });

            // Enforce body text
            const paragraphs = element.querySelectorAll('p');
            paragraphs.forEach((p) => {
              if (!p.classList.contains('text-body') &&
                  !p.hasAttribute('class')?.includes('text-')) {
                p.classList.add('text-body');
              }
            });
          });
        });
      });

      observer.observe(card, {
        childList: true,
        subtree: true,
      });

      // Store observer for cleanup
      (card as HTMLElement & { _signalCardObserver?: MutationObserver })._signalCardObserver = observer;

      // Enhanced interactivity for interactive variant
      if (card.classList.contains('signal-card--interactive')) {
        card.addEventListener('click', (e: MouseEvent) => {
          // Emit custom event for signal card click
          const event = new CustomEvent('signal-card:click', {
            detail: {
              variant: card.getAttribute('data-variant'),
              grade: card.getAttribute('data-grade'),
              signal: card.getAttribute('data-signal'),
              target: e.target,
            },
            bubbles: true,
            composed: true,
          });
          card.dispatchEvent(event);
        });

        // Keyboard activation
        card.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            card.click();
          }
        });

        // Make focusable if not already
        if (!card.hasAttribute('tabindex')) {
          card.setAttribute('tabindex', '0');
        }
      }

      // Signal indicator pulse management
      const signalDot = card.querySelector('.signal-card__signal-dot--live');
      if (signalDot) {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduced) {
          signalDot.classList.remove('signal-card__signal-dot--live');
        }
      }
    });

    // Cleanup function
    return () => {
      cards.forEach((card) => {
        const observer = (card as HTMLElement & { _signalCardObserver?: MutationObserver })._signalCardObserver;
        if (observer) {
          observer.disconnect();
        }
      });
    };
  }

  // Auto-initialize on component mount
  if (typeof document !== 'undefined') {
    document.addEventListener('DOMContentLoaded', () => {
      initSignalCard(document.body);
    });

    // Also handle dynamic insertion via component registry
    document.addEventListener('signal-card:init', ((e: CustomEvent) => {
      initSignalCard(e.detail?.root || document.body);
    }) as EventListener);
  }
</script>