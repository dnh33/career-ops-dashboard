---
// SalaryCards — Salary range comparison tiles
// Receives data from MarketOverview class via global reference
// Renders cards dynamically based on API data
---
<div class="salary-cards-container" id="salaryCardsContainer">
  <!-- Cards will be populated by MarketOverview.renderSalaryCards() -->
  <div class="salary-card-placeholder">
    <div class="empty-row">Loading salary data...</div>
  </div>
</div>

<style>
  .salary-cards-grid {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-3-5);
  }

  .salary-card {
    background: var(--bg-secondary);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-3-5);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .salary-card:hover {
    border-color: color-mix(in srgb, var(--accent-primary) 25%, var(--border-default));
    box-shadow: 0 0 var(--size-4) color-mix(in srgb, var(--accent-primary) 6%, transparent);
  }

  .salary-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .salary-card-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  .salary-card-location {
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    padding: var(--space-1) var(--space-2);
    border: var(--border-width) solid var(--border-hover);
    border-radius: var(--radius-sm);
  }

  .salary-card-ranges {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .salary-range {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .salary-range-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    margin-bottom: var(--space-1);
  }

  .salary-range-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    background: var(--bg-tertiary);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    min-width: var(--size-15);
    text-align: center;
  }

  .salary-card-footer {
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-align: center;
  }

  .salary-card-placeholder {
    text-align: center;
    padding: var(--space-8);
    color: var(--text-muted);
  }

  .empty-row {
    font-style: italic;
  }

  /* Responsive grid */
  @media (min-width: 640px) {
    .salary-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .salary-cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>