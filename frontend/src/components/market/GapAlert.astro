---
// GapAlert — Skill gap alert panel
// Receives data from MarketOverview class via global reference
// Renders gaps dynamically based on API data
---
<div class="gap-alert-container" id="gapListContainer">
  <!-- Gaps will be populated by MarketOverview.renderGapAlert() -->
  <div class="gap-item-placeholder">
    <div class="empty-row">Loading gap data...</div>
  </div>
</div>

<style>
  .gap-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-3-5);
  }

  .gap-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
    transition: background-color var(--transition-base);
  }

  .gap-item:hover {
    background: var(--bg-elevated);
  }

  .gap-item-severity {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    width: var(--size-7);
    height: var(--size-7);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    color: var(--text-primary);
  }

  .gap-item-severity.high {
    background: var(--grade-low);
    color: var(--grade-low-text);
  }

  .gap-item-severity.medium {
    background: var(--grade-mid);
    color: var(--grade-mid-text);
  }

  .gap-item-severity.low {
    background: var(--grade-high);
    color: var(--grade-high-text);
  }

  .gap-item-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .gap-item-skill {
    font-weight: 600;
    color: var(--text-primary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .gap-item-market {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .gap-item-action {
    font-size: var(--text-sm);
    color: var(--accent-primary);
    font-weight: 500;
    margin-top: var(--space-1);
  }

  .gap-item-placeholder {
    text-align: center;
    padding: var(--space-8);
    color: var(--text-muted);
  }

  .empty-row {
    font-style: italic;
  }
</style>