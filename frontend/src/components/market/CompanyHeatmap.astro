---
// CompanyHeatmap — Company hiring heatmap card grid
// Receives data from MarketOverview class via global reference
// Renders cards dynamically based on API data
---
<div class="company-heatmap-container" id="companyGridContainer">
  <!-- Cards will be populated by MarketOverview.renderCompanyHeatmap() -->
  <div class="company-card-placeholder">
    <div class="empty-row">Loading company data...</div>
  </div>
</div>

<style>
  .company-grid {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-3-5);
  }

  .company-card {
    background: var(--bg-secondary);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-3-5);
    transition: transform var(--transition-base), border-color var(--transition-base);
    cursor: pointer;
  }

  .company-card:hover {
    transform: translateY(calc(-1 * var(--size-1)));
    border-color: color-mix(in srgb, var(--accent-primary) 25%, var(--border-default));
  }

  .company-card:active {
    transform: translateY(0) scale(0.98);
  }

  .company-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .company-card-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  .company-card-temperature {
    font-size: var(--text-sm);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-transform: uppercase;
  }

  .company-card-temperature.hot {
    background: var(--grade-low);
    color: var(--grade-low-text);
  }

  .company-card-temperature.warm {
    background: var(--grade-mid);
    color: var(--grade-mid-text);
  }

  .company-card-temperature.cool {
    background: var(--grade-high);
    color: var(--grade-high-text);
  }

  .company-card-roles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .company-card-salary {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .company-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .company-card-view {
    color: var(--accent-primary);
    font-weight: 500;
  }

  .company-card-placeholder {
    text-align: center;
    padding: var(--space-8);
    color: var(--text-muted);
  }

  .empty-row {
    font-style: italic;
  }

  /* Responsive grid */
  @media (min-width: 640px) {
    .company-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .company-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Horizontal scroll for mobile */
  @media (max-width: 768px) {
    .company-grid {
      display: flex;
      overflow-x: auto;
      gap: var(--space-3);
      padding: var(--space-3) 0;
      scroll-snap-type: x mandatory;
    }

    .company-card {
      flex: 0 0 var(--size-50);
      scroll-snap-align: start;
    }
  }
</style>