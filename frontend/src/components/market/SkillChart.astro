---
// SkillChart — Horizontal bar chart showing skill demand percentages
// Receives data from MarketOverview class via global reference
// Renders bars dynamically based on API data
---
<div class="skill-chart-container" id="skillChartContainer">
  <!-- Bars will be populated by MarketOverview.renderSkillChart() -->
  <div style="text-align: center; padding: var(--space-8); color: var(--text-muted);">
    Loading skill data...
  </div>
</div>

<style>
  .skill-bar {
    display: flex;
    flex-direction: column;
  }

  .bar-container {
    background: var(--bg-tertiary);
    border-radius: var(--radius-sm);
    overflow: hidden;
    height: var(--size-7);
  }

  .bar-fill {
    transition: width 0.3s ease;
  }

  /* Tag styles (reuse existing) */
  .tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-md);
  }

  .tag-high { background: var(--tag-high-bg); color: var(--tag-high-text); border: var(--border-width) solid var(--tag-high-border); }
  .tag-mid { background: var(--tag-mid-bg); color: var(--tag-mid-text); border: var(--border-width) solid var(--tag-mid-border); }
  .tag-low { background: var(--tag-low-bg); color: var(--tag-low-text); border: var(--border-width) solid var(--tag-low-border); }
  .tag-neutral { background: var(--tag-neutral-bg); color: var(--tag-neutral-text); border: var(--border-width) solid var(--tag-neutral-border); }

  .skill-category {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-muted);
  }
</style>