---
// CompanyFit — Culture fit score, roles hiring, salary comparison
interface Props {
  company: {
    cultureFitScore: number;
    cultureFitFactors: string[];
    openRoles: string[];
    allRoles: Array<{
      title: string;
      department: string;
      level: string;
      salaryRange: string;
    }>;
    salaryComparison: {
      companyMedian: number;
      marketAverage: number;
      difference: number;
      vsMarketPct: number;
    };
    applyUrl: string;
  };
}

const { company } = Astro.props;

const fitColor = company.cultureFitScore >= 80 ? 'var(--success)' : 
                 company.cultureFitScore >= 60 ? 'var(--warning)' : 'var(--error)';

const salaryDiffClass = company.salaryComparison.difference >= 0 ? 'positive' : 'negative';
---
<div class="company-fit">
  <div class="fit-score">
    <h3 class="section-title">Culture Fit Score</h3>
    <div class="score-container">
      <div class="score-bar">
        <div class="score-fill" style="width: ${company.cultureFitScore}%; background-color: ${fitColor};"></div>
      </div>
      <div class="score-value">${company.cultureFitScore}/100</div>
    </div>
  </div>

  <div class="fit-factors">
    <h3 class="section-title">Culture Fit Factors</h3>
    <ul class="factors-list">
      {company.cultureFitFactors.map(factor => (
        <li>{factor}</li>
      ))}
    </ul>
  </div>

  <div class="open-roles">
    <h3 class="section-title">Roles Hiring</h3>
    <div class="roles-tags">
      {company.openRoles.map(role => (
        <span class="role-tag">{role}</span>
      ))}
    </div>
  </div>

  <div class="salary-comparison">
    <h3 class="section-title">Salary Comparison</h3>
    <div class="salary-chart">
      <div class="salary-bar company">
        <label>Company Median</label>
        <div class="bar" style="height: ${Math.min(company.salaryComparison.companyMedian / 1000 * 10, 80)}px;"></div>
        <span class="value">${company.salaryComparison.companyMedian} DKK</span>
      </div>
      <div class="salary-bar market">
        <label>Market Average</label>
        <div class="bar" style="height: ${Math.min(company.salaryComparison.marketAverage / 1000 * 10, 80)}px;"></div>
        <span class="value">${company.salaryComparison.marketAverage} DKK</span>
      </div>
    </div>
    <p class="salary-diff ${salaryDiffClass}">
      {company.salaryComparison.difference >= 0 ? 
        `Above market by ${company.salaryComparison.difference} DKK (${company.salaryComparison.vsMarketPct}%)` : 
        `Below market by ${Math.abs(company.salaryComparison.difference)} DKK (${company.salaryComparison.vsMarketPct}%)`}
    </p>
  </div>

  <div class="apply-section">
    <a href={company.applyUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
      Apply Now
    </a>
  </div>
</div>

<style>
  .company-fit {
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .section-title {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .fit-score .score-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .score-bar {
    flex: 1;
    height: 12px;
    background: var(--bg-tertiary);
    border-radius: 6px;
    overflow: hidden;
  }

  .score-fill {
    height: 100%;
    transition: width 300ms ease;
  }

  .score-value {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    min-width: 60px;
    text-align: center;
  }

  .fit-factors .factors-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .fit-factors .factors-list li {
    padding: 0.375rem 0;
    border-bottom: 1px solid var(--border-hover);
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .fit-factors .factors-list li:last-child {
    border-bottom: none;
  }

  .open-roles .roles-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .role-tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.625rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-hover);
    border-radius: 4px;
    color: var(--text-secondary);
  }

  .salary-comparison .salary-chart {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .salary-bar {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .salary-bar label {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .salary-bar .bar {
    width: 20px;
    background: var(--accent-primary);
    border-radius: 4px;
    margin-bottom: 0.25rem;
  }

  .salary-bar .value {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .salary-diff {
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem;
    border-radius: 4px;
    text-align: center;
  }

  .salary-diff.positive {
    background: color-mix(in srgb, var(--success) 10%, var(--bg-tertiary));
    color: var(--success);
    border: 1px solid color-mix(in srgb, var(--success) 20%, var(--border-default));
  }

  .salary-diff.negative {
    background: color-mix(in srgb, var(--error) 10%, var(--bg-tertiary));
    color: var(--error);
    border: 1px solid color-mix(in srgb, var(--error) 20%, var(--border-default));
  }

  .apply-section {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-default);
    text-align: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: inherit;
    border-radius: 6px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 150ms ease;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--accent-primary);
    color: var(--text-primary);
  }

  .btn-primary:hover {
    background: color-mix(in srgb, var(--accent-primary) 90%, var(--bg-tertiary));
  }
</style>