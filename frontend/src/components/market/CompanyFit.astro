---
// CompanyFit — Culture fit score, roles hiring, salary comparison
interface Props {
  company?: {
    cultureFitScore: number;
    cultureFitFactors: string[];
    openRoles: string[];
    allRoles: Array<{
      title: string;
      department: string;
      level: string;
      salaryRange: string;
    }>;
    salaryComparison: {
      companyMedian: number;
      marketAverage: number;
      difference: number;
      vsMarketPct: number;
    };
    applyUrl: string;
  };
}

const { company } = Astro.props;
---

{company && (
<>
  <script>
    const fitColor = company.cultureFitScore >= 80 ? 'var(--grade-high)' : 
                     company.cultureFitScore >= 60 ? 'var(--grade-mid)' : 'var(--grade-low)';
    const salaryDiffClass = company.salaryComparison.difference >= 0 ? 'positive' : 'negative';
  </script>

  <div class="company-fit">
    <div class="fit-score">
      <h3 class="section-title">Culture Fit Score</h3>
      <div class="score-container">
        <div class="score-bar">
          <div class="score-fill" style="width: {company.cultureFitScore}%; background-color: {fitColor};"></div>
        </div>
        <div class="score-value">{company.cultureFitScore}/100</div>
      </div>
    </div>

    <div class="fit-factors">
      <h3 class="section-title">Culture Fit Factors</h3>
      <ul class="factors-list">
        {company.cultureFitFactors.map(factor => (
          <li>{factor}</li>
        ))}
      </ul>
    </div>

    <div class="open-roles">
      <h3 class="section-title">Roles Hiring</h3>
      <div class="roles-tags">
        {company.openRoles.map(role => (
          <span class="role-tag">{role}</span>
        ))}
      </div>
    </div>

    <div class="salary-comparison">
      <h3 class="section-title">Salary Comparison</h3>
      <div class="salary-chart">
        <div class="salary-bar company">
          <label>Company Median</label>
          <div class="bar" style="height: {Math.min(company.salaryComparison.companyMedian / 1000 * 10, 80)}px;"></div>
          <span class="value">{company.salaryComparison.companyMedian} DKK</span>
        </div>
        <div class="salary-bar market">
          <label>Market Average</label>
          <div class="bar" style="height: {Math.min(company.salaryComparison.marketAverage / 1000 * 10, 80)}px;"></div>
          <span class="value">{company.salaryComparison.marketAverage} DKK</span>
        </div>
      </div>
      <p class={`salary-diff ${salaryDiffClass}`}>
        {company.salaryComparison.difference >= 0 ? 
          `Above market by ${company.salaryComparison.difference} DKK (${company.salaryComparison.vsMarketPct}%)` : 
          `Below market by ${Math.abs(company.salaryComparison.difference)} DKK (${company.salaryComparison.vsMarketPct}%)`}
      </p>
    </div>

    <div class="apply-section">
      <a href={company.applyUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        Apply Now
      </a>
    </div>
  </div>
</>
)}

<style>
  .company-fit {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .section-title {
    margin: 0 0 var(--space-3);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
  }

  .fit-score .score-container {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .score-bar {
    flex: 1;
    height: var(--size-3);
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .score-fill {
    height: 100%;
    transition: width 300ms ease;
  }

  .score-value {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    min-width: var(--size-15);
    text-align: center;
  }

  .fit-factors .factors-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .fit-factors .factors-list li {
    padding: var(--space-1-5) 0;
    border-bottom: var(--border-width) solid var(--border-hover);
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  .fit-factors .factors-list li:last-child {
    border-bottom: none;
  }

  .open-roles .roles-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .role-tag {
    font-size: var(--text-sm);
    padding: var(--space-1) var(--space-2-5);
    background: var(--bg-tertiary);
    border: var(--border-width) solid var(--border-hover);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
  }

  .salary-comparison .salary-chart {
    display: flex;
    gap: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .salary-bar {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .salary-bar label {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-1);
  }

  .salary-bar .bar {
    width: var(--size-5);
    background: var(--accent-primary);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-1);
  }

  .salary-bar .value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  .salary-diff {
    font-size: var(--text-sm);
    font-weight: 500;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    text-align: center;
  }

  .salary-diff.positive {
    background: color-mix(in srgb, var(--grade-high) 10%, var(--bg-tertiary));
    color: var(--grade-high);
    border: var(--border-width) solid color-mix(in srgb, var(--grade-high) 20%, var(--border-default));
  }

  .salary-diff.negative {
    background: color-mix(in srgb, var(--grade-low) 10%, var(--bg-tertiary));
    color: var(--grade-low);
    border: var(--border-width) solid color-mix(in srgb, var(--grade-low) 20%, var(--border-default));
  }

  .apply-section {
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: var(--border-width) solid var(--border-default);
    text-align: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2-5) var(--space-5);
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: var(--font-sans);
    border-radius: var(--radius-md);
    border: var(--border-width) solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast) var(--ease-out);
    text-decoration: none;
  }

  .btn-primary {
    background: var(--accent-primary);
    color: var(--bg-primary);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
  }
</style>