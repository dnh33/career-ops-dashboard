---
// GapAnalysisPanel — Expandable panel showing top 3 gaps with improvement suggestions
interface Props {
  gaps: string[];
  suggestions: string[];
  strengths: string[];
  visible: boolean;
}

const { gaps, suggestions, strengths, visible } = Astro.props;

if (!visible) {
  // Render nothing if not visible
}
---

<div class="gap-analysis-panel">
  <details class="gap-details" open>
    <summary class="gap-summary">
      <span class="gap-title">Top 3 Gaps & Improvements</span>
      <svg class="gap-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <div class="gap-content">
      {gaps.length > 0 && (
        <div class="gap-section">
          <h4 class="gap-section-title">Missing Skills</h4>
          <ul class="gap-list">
            {gaps.slice(0, 3).map((gap, i) => (
              <li class="gap-item">
                <span class="gap-index">{i + 1}</span>
                <span class="gap-text">{gap}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
      {suggestions.length > 0 && (
        <div class="gap-section">
          <h4 class="gap-section-title">Actionable Improvements</h4>
          <ul class="gap-list">
            {suggestions.slice(0, 3).map((suggestion, i) => (
              <li class="gap-item">
                <span class="gap-index">{i + 1}</span>
                <span class="gap-text">{suggestion}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
      {strengths.length > 0 && (
        <div class="gap-section strengths-section">
          <h4 class="gap-section-title">Your Strengths</h4>
          <ul class="gap-list strengths-list">
            {strengths.slice(0, 3).map((strength, i) => (
              <li class="gap-item strength-item">
                <svg class="strength-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="gap-text">{strength}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
      {(gaps.length === 0 && suggestions.length === 0 && strengths.length === 0) && (
        <p class="gap-empty">No gap analysis available. Run an evaluation first.</p>
      )}
    </div>
  </details>
</div>

<style>
  .gap-analysis-panel {
    background: var(--bg-surface);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .gap-details {
    border: none;
  }

  .gap-details > summary {
    list-style: none;
    cursor: pointer;
  }

  .gap-details > summary::-webkit-details-marker {
    display: none;
  }

  .gap-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    background: var(--bg-tertiary);
    border-bottom: var(--border-width) solid var(--border-default);
    font-weight: 600;
    color: var(--text-primary);
    font-size: var(--text-sm);
    user-select: none;
  }

  .gap-chevron {
    width: var(--size-5);
    height: var(--size-5);
    color: var(--text-muted);
    transition: transform var(--transition-base);
  }

  .gap-details[open] .gap-chevron {
    transform: rotate(180deg);
  }

  .gap-content {
    padding: var(--space-5);
  }

  .gap-section {
    margin-bottom: var(--space-5);
  }

  .gap-section:last-child {
    margin-bottom: 0;
  }

  .gap-section-title {
    margin: 0 0 var(--space-3);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-secondary);
  }

  .gap-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .gap-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    background: var(--bg-tertiary);
    border: var(--border-width) solid var(--border-hover);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .gap-index {
    flex-shrink: 0;
    width: var(--size-5);
    height: var(--size-5);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-primary);
    color: var(--bg-primary);
    border-radius: var(--radius-sm);
    font-weight: 700;
    font-size: var(--text-sm);
    font-family: var(--font-mono);
  }

  .strengths-section .gap-section-title {
    color: var(--grade-high);
  }

  .strengths-list .gap-item {
    background: color-mix(in srgb, var(--grade-high) 10%, var(--bg-tertiary));
    border-color: color-mix(in srgb, var(--grade-high) 20%, var(--border-hover));
  }

  .strength-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .strength-icon {
    flex-shrink: 0;
    width: var(--size-5);
    height: var(--size-5);
    color: var(--grade-high);
    margin-top: var(--border-width-double);
  }

  .gap-empty {
    margin: 0;
    padding: var(--space-6);
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>