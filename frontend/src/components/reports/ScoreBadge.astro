---
import { gradeClass } from '../../utils/colors';

interface Props {
  grade: string;
  size?: 'sm' | 'md' | 'lg';
}

const { grade, size = 'md' } = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'w-8 h-8 text-xs',
  md: 'w-10 h-10 text-sm',
  lg: 'w-14 h-14 text-xl',
};

const descriptors: Record<string, string> = {
  A: 'Excellent',
  B: 'Strong',
  C: 'Good',
  D: 'Fair',
  E: 'Weak',
  F: 'Poor',
  G: 'Mismatch',
};

const descriptor = descriptors[grade] || '';
---

<div
  class={`${gradeClass(grade)} ${sizeClasses[size]}`}
  title={`${grade} — ${descriptor}`}
>
  {grade}
</div>

{size === 'lg' && (
  <span class="text-xs text-[var(--text-secondary)] mt-1">{descriptor}</span>
)}