---
// PageLayout.astro — Feature slots + injection roots + pagelayout:ready + Cmd+K
// Design System Foundation §3.3 & §4.3
// Astro + module script, semantic tokens only

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  useSidebar?: boolean;
}

const {
  title,
  description,
  currentPath = Astro.url.pathname,
  useSidebar = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title || 'Career Ops Dashboard'}</title>
    <link rel="preload" href="/fonts/Sora-Variable.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (function () {
        try {
          // Theme: [data-theme] on <html>
          var storedTheme = localStorage.getItem('career-ops-theme');
          var theme = storedTheme || 'dark'; // default: dark observatory
          document.documentElement.setAttribute('data-theme', theme);

          // Density: [data-density] on <html>
          var storedDensity = localStorage.getItem('career-ops-density') || 'comfortable';
          document.documentElement.setAttribute('data-density', storedDensity);
        } catch (e) {
          /* storage unavailable */
        }
      })();
    </script>
  </head>
  <body>
    <div class="page-layout" data-component="page-layout">
      <slot name="topbar" />

      <div class="page-layout__body">
        <aside class="page-layout__sidebar" aria-label="Sidebar">
          <slot name="sidebar">
            {useSidebar && <slot name="nav" />}
          </slot>
        </aside>

        <main class:list={['page-layout__main', useSidebar && 'page-layout__main--with-sidebar']}>
          <header class="page-layout__header">
            <slot name="breadcrumbs" />
            {(title || description) && (
              <div class="page-layout__hero">
                <slot name="hero">
                  {title && <h1 class="page-layout__title">{title}</h1>}
                  {description && <p class="page-layout__description">{description}</p>}
                </slot>
              </div>
            )}
            <slot name="actions" />
          </header>

          <div class="page-layout__content">
            <slot />
          </div>

          <footer class="page-layout__footer">
            <slot name="footer" />
          </footer>
          <slot name="command-line-bar" />
        </main>
      </div>

      {/* Injection roots for modal/toast/drawer */}
      <div id="modal-root" class="page-layout__modal-root" aria-hidden="true" />
      <div id="toast-root" class="page-layout__toast-root" aria-live="polite" aria-atomic="true" />
      <div id="drawer-root" class="page-layout__drawer-root" aria-hidden="true" />
    </div>
  </body>
</html>

<style>
  .page-layout {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background: var(--bg-page);
  }

  .page-layout__body {
    display: flex;
    flex: 1;
    min-height: 0;
  }

  .page-layout__sidebar {
    display: none;
    flex-direction: column;
    width: var(--sidebar-width);
    background: var(--bg-surface);
    border-right: var(--border-width) solid var(--border-default);
    z-index: var(--z-sticky);
  }

  @media (min-width: 1024px) {
    .page-layout__sidebar {
      display: flex;
    }
  }

  .page-layout__main {
    flex: 1;
    min-width: 0;
    padding: var(--space-6) var(--space-6);
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 1024px) {
    .page-layout__main--with-sidebar {
      margin-left: var(--sidebar-width);
      transition: margin-left var(--duration-base) var(--ease-out);
    }
  }

  .page-layout__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .page-layout__hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .page-layout__title {
    margin: 0;
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-heading);
    font-family: var(--font-display);
    line-height: 1.1;
  }

  .page-layout__description {
    margin: 0;
    font-size: var(--text-lg);
    color: var(--color-muted);
    font-family: var(--font-sans);
    max-width: var(--size-192);
  }

  .page-layout__content {
    flex: 1;
    width: 100%;
    max-width: var(--size-320);
    margin-inline: auto;
  }

  .page-layout__footer {
    margin-top: auto;
    padding-top: var(--space-6);
    border-top: var(--border-width) solid var(--border-default);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  /* Injection roots - fixed positioning for overlays */
  .page-layout__modal-root {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    pointer-events: none;
  }
  .page-layout__modal-root > * {
    pointer-events: auto;
  }

  .page-layout__toast-root {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: var(--z-toast);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    pointer-events: none;
  }
  .page-layout__toast-root > * {
    pointer-events: auto;
  }

  .page-layout__drawer-root {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    pointer-events: none;
  }
  .page-layout__drawer-root > * {
    pointer-events: auto;
  }
</style>

<script>
  export function initPageLayout(root: HTMLElement): () => void {
    const layout = root.querySelector('[data-component="page-layout"]') as HTMLElement;
    if (!layout) return () => {};

    // Dispatch pagelayout:ready event for component registry
    const dispatchReady = () => {
      const event = new CustomEvent('pagelayout:ready', {
        detail: { root: document.body },
        bubbles: true,
        composed: true,
      });
      layout.dispatchEvent(event);
    };

    // Global Cmd+K listener for command palette
    const handleKeyDown = (event: KeyboardEvent) => {
      if ((event.metaKey || event.ctrlKey) && event.key === 'k') {
        event.preventDefault();
        const palette = document.querySelector('[data-component="command-palette"]') as HTMLElement;
        if (palette) {
          palette.setAttribute('data-visible', 'true');
          // Focus the search input
          const input = palette.querySelector('input') as HTMLInputElement;
          input?.focus();
        }
      }
    };

    document.addEventListener('keydown', handleKeyDown);

    // Dispatch ready after a brief delay to ensure DOM is settled
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', dispatchReady);
    } else {
      dispatchReady();
    }

    return () => {
      document.removeEventListener('keydown', handleKeyDown);
      document.removeEventListener('DOMContentLoaded', dispatchReady);
    };
  }

  // Auto-init
  if (typeof document !== 'undefined') {
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('[data-component="page-layout"]').forEach((el) => {
        initPageLayout(el as HTMLElement);
      });
    });
  }
</script>