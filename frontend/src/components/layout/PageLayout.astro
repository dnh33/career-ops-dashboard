---
import TopBar from './TopBar.astro';
import Sidebar from './Sidebar.astro';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  useSidebar?: boolean;
}

const {
  title,
  description,
  currentPath = Astro.url.pathname,
  useSidebar = true,
} = Astro.props;
---

<div class="page-layout">
  <TopBar currentPath={currentPath} />
  <div class="page-layout__body">
    {useSidebar && <Sidebar currentPath={currentPath} />}
    <main class:list={['page-layout__main', useSidebar && 'page-layout__main--with-sidebar']}>
      {(title || description) && (
        <header class="page-layout__header">
          {title && <h1 class="page-layout__title">{title}</h1>}
          {description && <p class="page-layout__description">{description}</p>}
        </header>
      )}
      <div class="page-layout__content">
        <slot />
      </div>
    </main>
  </div>
</div>

<style>
  .page-layout {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background: var(--bg-chrome);
  }

  .page-layout__body {
    display: flex;
    flex: 1;
    min-height: 0;
  }

  .page-layout__main {
    flex: 1;
    min-width: 0;
    padding: var(--space-6) var(--page-inset-x);
  }

  @media (min-width: 1024px) {
    .page-layout__main--with-sidebar {
      margin-left: var(--sidebar-width);
      transition: margin-left var(--transition-base);
    }

    :global(.hermes-sidebar--collapsed) ~ .page-layout__main--with-sidebar,
    :global(.page-layout__body:has(.hermes-sidebar--collapsed)) .page-layout__main--with-sidebar {
      margin-left: 3.5rem;
    }
  }

  .page-layout__header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--stroke-hairline);
  }

  .page-layout__title {
    margin: 0 0 var(--space-2);
    font-size: var(--text-2xl);
  }

  .page-layout__description {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-family: var(--font-ui);
    max-width: 48rem;
  }

  .page-layout__content {
    width: 100%;
    max-width: 1280px;
  }
</style>
