---
// FilterBar — Search input + filter dropdown
// Props:
//   searchValue (string) — controlled search input value
//   filterOptions (array of { value, label }) — dropdown options
//   activeFilter (string) — currently selected filter value
//   placeholder (string) — search placeholder text
//   onSearch (string) — event handler for search input (passed as inline JS expression)
//   onFilterChange (string) — event handler for filter dropdown change

interface FilterOption {
  value: string;
  label: string;
}

interface Props {
  searchValue?: string;
  filterOptions?: FilterOption[];
  activeFilter?: string;
  placeholder?: string;
}

const {
  searchValue = '',
  filterOptions = [],
  activeFilter = 'all',
  placeholder = 'Search...',
} = Astro.props;
---

<div class="filter-bar" role="search" aria-label="Filter results">
  <!-- Search Input -->
  <div class="filter-search-wrap">
    <svg
      class="filter-search-icon"
      width="16"
      height="16"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      type="search"
      class="filter-search-input"
      placeholder={placeholder}
      value={searchValue}
      aria-label="Search entries"
    />
  </div>

  <!-- Filter Dropdown -->
  {filterOptions.length > 0 && (
    <div class="filter-select-wrap">
      <select
        class="filter-select"
        aria-label="Filter by status"
        value={activeFilter}
      >
        {filterOptions.map((opt) => (
          <option value={opt.value} selected={opt.value === activeFilter}>
            {opt.label}
          </option>
        ))}
      </select>
      <svg
        class="filter-select-chevron"
        width="12"
        height="12"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  )}
</div>

<style>
  .filter-bar {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .filter-search-wrap {
    position: relative;
    flex: 1;
    min-width: 200px;
  }

  .filter-search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  .filter-search-input {
    width: 100%;
    padding: 0.5rem 0.75rem 0.5rem 2.25rem;
    font-size: 0.875rem;
    font-family: inherit;
    color: var(--text-primary);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-hover);
    border-radius: 0.375rem;
    outline: none;
    transition: border-color 150ms ease;
  }

  .filter-search-input::placeholder {
    color: var(--text-muted);
  }

  .filter-search-input:focus {
    border-color: var(--accent-primary);
  }

  .filter-select-wrap {
    position: relative;
  }

  .filter-select {
    appearance: none;
    padding: 0.5rem 2rem 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-family: inherit;
    color: var(--text-primary);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-hover);
    border-radius: 0.375rem;
    cursor: pointer;
    outline: none;
    transition: border-color 150ms ease;
    min-height: 44px;
  }

  .filter-select:focus {
    border-color: var(--accent-primary);
  }

  .filter-select-chevron {
    position: absolute;
    right: 0.625rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }
</style>