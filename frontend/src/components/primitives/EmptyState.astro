---
import type { EmptyStateProps } from './types';

interface Props extends EmptyStateProps {}

const {
  title,
  description,
  icon = 'inbox',
  actionLabel,
  actionHref,
  class: className = '',
} = Astro.props;
---

<div class:list={['empty-state', className]} role="status">
  <i class:list={['codicon', `codicon-${icon}`, 'empty-state__icon']} aria-hidden="true"></i>
  <h3 class="empty-state__title">{title}</h3>
  {description && <p class="empty-state__description">{description}</p>}
  {actionLabel && actionHref && (
    <a href={actionHref} class="empty-state__action">
      {actionLabel}
      <i class="codicon codicon-arrow-right" aria-hidden="true"></i>
    </a>
  )}
  <slot />
</div>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-12) var(--space-6);
    background: var(--bg-card);
    border: 1px solid var(--stroke-hairline);
  }

  .empty-state__icon {
    font-size: 2rem;
    color: var(--text-quaternary);
    margin-bottom: var(--space-4);
  }

  .empty-state__title {
    margin: 0 0 var(--space-2);
    font-size: var(--text-lg);
    font-family: var(--font-ui);
    font-weight: 600;
    color: var(--text-primary);
  }

  .empty-state__description {
    margin: 0 0 var(--space-4);
    max-width: 28rem;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .empty-state__action {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    min-height: auto;
  }

  .empty-state__action:hover {
    text-decoration: underline;
  }
</style>
