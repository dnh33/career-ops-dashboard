---
import type { SwitchProps } from './types';

interface Props extends SwitchProps {}

const {
  name,
  label,
  description,
  checked = false,
  disabled = false,
  class: className = '',
} = Astro.props;

const inputId = `switch-${Math.random().toString(36).slice(2, 9)}`;
---

<label class:list={['hermes-switch', disabled && 'hermes-switch--disabled', className]}>
  <input
    type="checkbox"
    role="switch"
    id={inputId}
    name={name}
    class="hermes-switch__input"
    checked={checked}
    disabled={disabled}
    aria-checked={checked}
  />
  <span class="hermes-switch__track" aria-hidden="true">
    <span class="hermes-switch__thumb"></span>
  </span>
  <span class="hermes-switch__content">
    <span class="hermes-switch__label">{label}</span>
    {description && <span class="hermes-switch__description">{description}</span>}
  </span>
</label>

<script define:vars={{ inputId }}>
  const input = document.getElementById(inputId);
  input?.addEventListener('change', () => {
    input.setAttribute('aria-checked', input.checked ? 'true' : 'false');
    input.dispatchEvent(new CustomEvent('toggle', { detail: { checked: input.checked }, bubbles: true }));
  });
</script>

<style>
  .hermes-switch {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: var(--border-width) solid var(--border-default);
    cursor: pointer;
    min-height: auto;
  }

  .hermes-switch:last-child {
    border-bottom: none;
  }

  .hermes-switch--disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .hermes-switch__input {
    position: absolute;
    width: var(--border-width);
    height: var(--border-width);
    padding: 0;
    margin: calc(-1 * var(--border-width));
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    min-height: auto;
  }

  .hermes-switch__track {
    flex-shrink: 0;
    position: relative;
    width: var(--size-44);
    height: var(--size-6);
    margin-top: var(--space-0-5);
    background: var(--bg-tertiary);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-full);
    transition: background-color var(--transition-base), border-color var(--transition-base);
  }

  .hermes-switch__thumb {
    position: absolute;
    top: var(--border-width);
    left: var(--border-width);
    width: calc(var(--size-6) - calc(var(--space-1) * 2));
    height: calc(var(--size-6) - calc(var(--space-1) * 2));
    background: var(--bg-elevated);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-base);
  }

  .hermes-switch__input:checked + .hermes-switch__track {
    background: color-mix(in srgb, var(--accent-primary) 20%, transparent);
    border-color: color-mix(in srgb, var(--accent-primary) 40%, transparent);
  }

  .hermes-switch__input:checked + .hermes-switch__track .hermes-switch__thumb {
    transform: translateX(var(--size-20));
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .hermes-switch__input:focus-visible + .hermes-switch__track {
    outline: var(--border-width-thick) solid color-mix(in srgb, var(--accent-primary) 50%, transparent);
    outline-offset: var(--border-width-thick);
  }

  .hermes-switch__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
    min-width: 0;
  }

  .hermes-switch__label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
  }

  .hermes-switch__description {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.4;
  }
</style>