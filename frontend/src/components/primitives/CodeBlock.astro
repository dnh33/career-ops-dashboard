---
import type { CodeBlockProps } from './types'

interface Props extends CodeBlockProps {}

const {
  code,
  language = 'text',
  showLineNumbers = true,
  copyable = true,
  class: className = '',
} = Astro.props;

const lines = code.replace(/\n$/, '').split('\n');
const blockId = `code-block-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class:list={['code-block', className]}>
  <figcaption class="code-block__header">
    <span class="code-block__lang">{language}</span>
    {copyable && (
      <button type="button" class="code-block__copy" data-copy-target={blockId} aria-label="Copy code">
        <i class="codicon codicon-copy" aria-hidden="true"></i>
        <span>Copy</span>
      </button>
    )}
  </figcaption>
  <pre class="code-block__pre" id={blockId} tabindex="0"><code class="code-block__code hermes-mono" data-mono="true">{showLineNumbers ? (
    lines.map((line, index) => (
      <span class="code-block__line">
        <span class="code-block__ln" aria-hidden="true">{index + 1}</span>
        <span class="code-block__text">{line || ' '}</span>
      </span>
    ))
  ) : code}</code></pre>
</figure>

<script define:vars={{ blockId }}>
  const button = document.querySelector(`[data-copy-target="${blockId}"]`);
  const pre = document.getElementById(blockId);
  if (button && pre) {
    button.addEventListener('click', async () => {
      const text = pre.textContent ?? '';
      try {
        await navigator.clipboard.writeText(text);
        button.querySelector('span').textContent = 'Copied';
        setTimeout(() => {
          button.querySelector('span').textContent = 'Copy';
        }, 1500);
      } catch {
        /* clipboard unavailable */
      }
    });
  }
</script>

<style>
  .code-block {
    margin: 0;
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .code-block__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-3);
    border-bottom: var(--border-width) solid var(--border-default);
    background: var(--bg-card);
  }

  .code-block__lang {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
  }

  .code-block__copy {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    border: none;
    background: transparent;
    color: var(--text-secondary);
    font-size: var(--text-xs);
    font-family: var(--font-sans);
    min-height: auto;
    padding: var(--space-1) var(--space-2);
    cursor: pointer;
    border-radius: var(--radius-sm);
  }

  .code-block__copy:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }

  .code-block__pre {
    margin: 0;
    padding: var(--space-3);
    overflow-x: auto;
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .code-block__code {
    display: block;
    color: var(--text-primary);
    font-family: var(--font-mono);
  }

  .code-block__line {
    display: flex;
    gap: var(--space-3);
  }

  .code-block__ln {
    flex-shrink: 0;
    width: 2ch;
    text-align: right;
    color: var(--text-muted);
    user-select: none;
  }

  .code-block__text {
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>