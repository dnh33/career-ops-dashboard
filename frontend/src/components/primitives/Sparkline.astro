---
import type { SparklineProps } from './types';

interface Props extends SparklineProps {}

const {
  data,
  width = 80,
  height = 24,
  strokeWidth = 1.5,
  tooltip = true,
  class: className = '',
} = Astro.props;

const max = Math.max(...data, 1);
const min = Math.min(...data, 0);
const range = max - min || 1;
const points = data
  .map((value, index) => {
    const x = (index / Math.max(data.length - 1, 1)) * width;
    const y = height - ((value - min) / range) * height;
    return `${x},${y}`;
  })
  .join(' ');
const lastValue = data[data.length - 1] ?? 0;
---

<svg
  class:list={['sparkline', className]}
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  role="img"
  aria-label={tooltip ? `Trend ending at ${lastValue}` : undefined}
  preserveAspectRatio="none"
>
  <polyline
    fill="none"
    stroke="var(--color-primary)"
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    points={points}
  />
</svg>

<style>
  .sparkline {
    display: block;
    overflow: visible;
  }
</style>
