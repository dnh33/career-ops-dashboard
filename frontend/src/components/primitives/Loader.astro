---
import type { LoaderProps } from './types'

interface Props extends LoaderProps {}

const {
  label = 'Loading',
  size = 'md',
  class: className = '',
} = Astro.props;
---

<div class:list={['loader', `loader--${size}`, className]} role="status" aria-live="polite" aria-label={label}>
  <span class="loader__spinner" aria-hidden="true"></span>
  {label && <span class="loader__label">{label}</span>}
</div>

<style>
  .loader {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .loader__spinner {
    display: inline-block;
    border: var(--border-width-double) solid var(--border-default);
    border-top-color: var(--accent-primary);
    border-radius: var(--radius-full);
    animation: loader-spin var(--duration-slow) linear infinite;
  }

  .loader--sm .loader__spinner {
    width: var(--size-4);
    height: var(--size-4);
  }

  .loader--md .loader__spinner {
    width: var(--size-5);
    height: var(--size-5);
  }

  .loader--lg .loader__spinner {
    width: var(--size-7);
    height: var(--size-7);
  }

  @keyframes loader-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>