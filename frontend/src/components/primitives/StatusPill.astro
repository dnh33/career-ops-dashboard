---
import type { StatusPillProps } from './types'

interface Props extends StatusPillProps {}

const {
  label,
  variant = 'default',
  mono = false,
  class: className = '',
} = Astro.props;
---

<span class:list={['status-pill', `status-pill--${variant}`, mono && 'hermes-mono', className]} data-mono={mono || undefined}>
  {label}
</span>

<style>
  .status-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    font-family: var(--font-sans);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    background: var(--bg-card);
    white-space: nowrap;
  }

  .status-pill--primary {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
    background: var(--accent-subtle);
  }

  .status-pill--success {
    color: var(--grade-high);
    border-color: var(--grade-high-border);
    background: var(--grade-high-bg);
  }

  .status-pill--warning {
    color: var(--grade-mid);
    border-color: var(--grade-mid-border);
    background: var(--grade-mid-bg);
  }

  .status-pill--error {
    color: var(--grade-low);
    border-color: var(--grade-low-border);
    background: var(--grade-low-bg);
  }

  .status-pill--warm {
    color: var(--grade-mid);
    border-color: var(--grade-mid-border);
    background: var(--grade-mid-bg);
  }

  .status-pill--info {
    color: var(--text-muted);
    border-color: var(--border-hover);
    background: var(--bg-tertiary);
  }

  .status-pill--neutral {
    color: var(--text-muted);
    border-color: var(--border-hover);
    background: var(--bg-surface);
  }
</style>