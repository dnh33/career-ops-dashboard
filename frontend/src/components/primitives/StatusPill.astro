---
import type { StatusPillProps } from './types';

interface Props extends StatusPillProps {}

const {
  label,
  variant = 'default',
  mono = false,
  class: className = '',
} = Astro.props;
---

<span class:list={['status-pill', `status-pill--${variant}`, mono && 'hermes-mono', className]} data-mono={mono || undefined}>
  {label}
</span>

<style>
  .status-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    font-family: var(--font-ui);
    border: 1px solid var(--stroke-hairline);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    background: var(--bg-panel);
    white-space: nowrap;
  }

  .status-pill--primary {
    color: var(--color-primary);
    border-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .status-pill--success {
    color: var(--ui-success);
    border-color: color-mix(in srgb, var(--ui-success) 30%, transparent);
    background: var(--tag-success-bg);
  }

  .status-pill--warning {
    color: var(--ui-warning);
    border-color: color-mix(in srgb, var(--ui-warning) 30%, transparent);
    background: var(--tag-warning-bg);
  }

  .status-pill--error {
    color: var(--ui-error);
    border-color: color-mix(in srgb, var(--ui-error) 30%, transparent);
    background: var(--tag-error-bg);
  }

  .status-pill--warm {
    color: var(--color-warm);
    border-color: color-mix(in srgb, var(--color-warm) 30%, transparent);
    background: color-mix(in srgb, var(--color-warm) 10%, transparent);
  }

  .status-pill--info {
    color: var(--tag-info-fg);
    border-color: color-mix(in srgb, var(--ui-info) 30%, transparent);
    background: var(--tag-info-bg);
  }

  .status-pill--neutral {
    color: var(--tag-muted-fg);
    border-color: color-mix(in srgb, var(--text-tertiary) 30%, transparent);
    background: var(--tag-muted-bg);
  }
</style>
