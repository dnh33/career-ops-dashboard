---
// Nav component — handles both sidebar (desktop) and bottom nav (mobile)
// with "More" dropdown and SSE status indicator
import ThemeToggle from './layout/ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

// Primary nav items (always visible)
const primaryNav = [
  { href: '/', label: 'Dashboard', icon: 'home' },
  { href: '/evaluate', label: 'Evaluate', icon: 'clipboard' },
  { href: '/tracker', label: 'Tracker', icon: 'list-ordered' },
  { href: '/reports', label: 'Reports', icon: 'bar-chart' },
  { href: '/market', label: 'Market', icon: 'chart-bar' },
];

// More dropdown items
const moreNav = [
  { href: '/scan', label: 'Scan', icon: 'search' },
  { href: '/pipeline', label: 'Pipeline', icon: 'git-branch' },
  { href: '/output', label: 'Output', icon: 'file-text' },
  { href: '/profile', label: 'Profile', icon: 'user' },
  { href: '/tools', label: 'Tools', icon: 'wrench' },
];

// Icon SVG paths (Lucide)
const icons: Record<string, string> = {
  home: '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/>',
  clipboard: '<path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>',
  'list-ordered': '<line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/><path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1"/>',
  'bar-chart': '<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>',
  search: '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  'git-branch': '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 01-9 9"/>',
  'file-text': '<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10,9 9,9 8,9"/>',
  user: '<path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  wrench: '<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>',
  'chart-bar': '<line x1="8" y1="8" x2="8" y2="14"/><line x1="12" y1="12" x2="12" y2="18"/><line x1="16" y1="16" x2="16" y2="12"/>',
  more: '<circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>',
};

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

const isMoreActive = moreNav.some(item => isActive(item.href));
---

<!-- Desktop Sidebar -->
<aside class="sidebar" aria-label="Main navigation">
  <div class="sidebar-brand">
    <span class="sidebar-brand-icon">&#9889;</span>
    <span class="sidebar-brand-text">CareerOps</span>
  </div>

  <nav class="sidebar-nav" role="navigation">
    <!-- Primary items -->
    {primaryNav.map((item) => (
      <a
        href={item.href}
        class:list={['sidebar-link', isActive(item.href) && 'sidebar-link-active']}
        aria-current={isActive(item.href) ? 'page' : undefined}
      >
        <svg class="sidebar-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[item.icon]} />
        <span class="sidebar-link-label">{item.label}</span>
      </a>
    ))}

    <!-- More dropdown trigger -->
    <div class="sidebar-more-wrap" id="sidebar-more-wrap">
      <button
        type="button"
        class:list={['sidebar-link', 'sidebar-more-trigger', isMoreActive && 'sidebar-link-active']}
        aria-expanded="false"
        aria-controls="sidebar-more-dropdown"
        id="sidebar-more-btn"
      >
        <svg class="sidebar-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons['more']} />
        <span class="sidebar-link-label">More</span>
        <svg class="sidebar-more-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="14" height="14">
          <polyline points="6,9 12,15 18,9"/>
        </svg>
      </button>
      <div class="sidebar-more-dropdown" id="sidebar-more-dropdown" role="menu" aria-hidden="true">
        {moreNav.map((item) => (
          <a
            href={item.href}
            class:list={['sidebar-more-item', isActive(item.href) && 'sidebar-more-item-active']}
            aria-current={isActive(item.href) ? 'page' : undefined}
            role="menuitem"
          >
            <svg class="sidebar-more-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[item.icon]} />
            <span>{item.label}</span>
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- API Status + Theme -->
  <div class="sidebar-status" aria-label="Sidebar footer">
    <div class="sidebar-status__row" aria-label="API status">
      <span class="status-dot status-dot-connecting" id="api-status-dot" title="Checking..."></span>
      <span class="status-label" id="api-status-label">Checking...</span>
    </div>
    <ThemeToggle />
  </div>
</aside>

<!-- Mobile Bottom Nav -->
<nav class="bottom-nav" role="navigation" aria-label="Main navigation">
  {primaryNav.map((item) => (
    <a
      href={item.href}
      class:list={['bottom-nav-link', isActive(item.href) && 'bottom-nav-link-active']}
      aria-current={isActive(item.href) ? 'page' : undefined}
    >
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[item.icon]} />
      <span class="bottom-nav-label">{item.label}</span>
    </a>
  ))}

  <!-- Mobile More button -->
  <button
    type="button"
    class:list={['bottom-nav-link', 'bottom-nav-more-trigger', isMoreActive && 'bottom-nav-link-active']}
    aria-expanded="false"
    aria-controls="mobile-more-sheet"
    id="mobile-more-btn"
  >
    <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons['more']} />
    <span class="bottom-nav-label">More</span>
  </button>
</nav>

<!-- Mobile More Sheet (overlay) -->
<div class="mobile-more-overlay" id="mobile-more-overlay" aria-hidden="true">
  <div class="mobile-more-sheet" id="mobile-more-sheet" role="dialog" aria-label="More navigation" aria-hidden="true">
    <div class="mobile-more-header">
      <span class="mobile-more-title">More</span>
      <button type="button" class="mobile-more-close" id="mobile-more-close" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <nav class="mobile-more-nav">
      {moreNav.map((item) => (
        <a
          href={item.href}
          class:list={['mobile-more-item', isActive(item.href) && 'mobile-more-item-active']}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          <svg class="mobile-more-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[item.icon]} />
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
  </div>
</div>

<script>
  // Sidebar More dropdown toggle
  const moreWrap = document.getElementById('sidebar-more-wrap') as HTMLElement | null;
  const moreBtn = document.getElementById('sidebar-more-btn') as HTMLElement | null;
  const moreDropdown = document.getElementById('sidebar-more-dropdown') as HTMLElement | null;

  if (moreBtn && moreDropdown && moreWrap) {
    moreBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = moreWrap!.classList.toggle('open');
      moreBtn.setAttribute('aria-expanded', String(isOpen));
      moreDropdown.setAttribute('aria-hidden', String(!isOpen));
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (moreWrap && !moreWrap.contains(e.target as Node)) {
        moreWrap.classList.remove('open');
        moreBtn.setAttribute('aria-expanded', 'false');
        moreDropdown.setAttribute('aria-hidden', 'true');
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && moreWrap.classList.contains('open')) {
        moreWrap.classList.remove('open');
        moreBtn.setAttribute('aria-expanded', 'false');
        moreDropdown.setAttribute('aria-hidden', 'true');
        moreBtn.focus();
      }
    });
  }

  // Mobile More sheet toggle
  const mobileMoreBtn = document.getElementById('mobile-more-btn') as HTMLElement | null;
  const mobileMoreOverlay = document.getElementById('mobile-more-overlay') as HTMLElement | null;
  const mobileMoreClose = document.getElementById('mobile-more-close') as HTMLElement | null;

  function openMobileSheet() {
    if (mobileMoreOverlay) mobileMoreOverlay.classList.add('open');
    if (mobileMoreBtn) mobileMoreBtn.setAttribute('aria-expanded', 'false');
    if (mobileMoreOverlay) mobileMoreOverlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileSheet() {
    if (mobileMoreOverlay) mobileMoreOverlay.classList.remove('open');
    if (mobileMoreBtn) mobileMoreBtn.setAttribute('aria-expanded', 'false');
    if (mobileMoreOverlay) mobileMoreOverlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  if (mobileMoreBtn && mobileMoreOverlay) {
    mobileMoreBtn.addEventListener('click', openMobileSheet);
    mobileMoreOverlay.addEventListener('click', (e) => {
      if (e.target === mobileMoreOverlay) closeMobileSheet();
    });
    if (mobileMoreClose) mobileMoreClose.addEventListener('click', closeMobileSheet);

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && mobileMoreOverlay!.classList.contains('open')) {
        closeMobileSheet();
        mobileMoreBtn.focus();
      }
    });
  }

  // API Status indicator
  function updateAPIStatus() {
    const dot = document.getElementById('api-status-dot');
    const label = document.getElementById('api-status-label');
    if (!dot || !label) return;

    fetch('/api/health', { cache: 'no-store' })
      .then((r) => {
        if (r.ok) {
          dot.className = 'status-dot status-dot-connected';
          label.textContent = 'Online';
        } else {
          dot.className = 'status-dot status-dot-error';
          label.textContent = 'Degraded';
        }
      })
      .catch(() => {
        dot.className = 'status-dot status-dot-error';
        label.textContent = 'Offline';
      });
  }

  // Run on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateAPIStatus);
  } else {
    updateAPIStatus();
  }
</script>
