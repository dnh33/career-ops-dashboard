---
import PageLayout from '../components/layout/PageLayout.astro';

interface Props {
  title?: string;
  pageTitle?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'Career Ops Dashboard',
  pageTitle,
  description,
  currentPath = Astro.url.pathname,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preload" href="/fonts/Collapse-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('hermes-theme');
          var dark =
            stored === 'dark' ||
            (stored !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          if (dark) document.documentElement.classList.add('dark');

          var density = localStorage.getItem('hermes-density') || 'comfortable';
          document.body.classList.add('page-density-' + density);
        } catch (e) {
          /* storage unavailable */
        }
      })();
    </script>
  </head>
  <body>
    <PageLayout title={pageTitle} description={description} currentPath={currentPath}>
      <slot />
    </PageLayout>
  </body>
</html>

<style is:global>
  @import '../styles/globals.css';
</style>
