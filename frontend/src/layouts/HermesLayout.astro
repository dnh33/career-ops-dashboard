---
import PageLayout from '../components/layout/PageLayout.astro';
import CommandLineBar from '../components/layout/CommandLineBar.astro';

interface Props {
  title?: string;
  pageTitle?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'Career Ops Dashboard',
  pageTitle,
  description,
  currentPath = Astro.url.pathname,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preload" href="/fonts/Sora-Variable.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (function () {
        try {
          // Theme: [data-theme] on <html>
          var storedTheme = localStorage.getItem('career-ops-theme');
          var theme = storedTheme || 'dark'; // default: dark observatory
          document.documentElement.setAttribute('data-theme', theme);

          // Density: [data-density] on <html>
          var storedDensity = localStorage.getItem('career-ops-density') || 'comfortable';
          document.documentElement.setAttribute('data-density', storedDensity);
        } catch (e) {
          /* storage unavailable */
        }
      })();
    </script>
  </head>
  <body>
    <PageLayout title={pageTitle} description={description} currentPath={currentPath}>
      <slot />
      <CommandLineBar slot="command-line-bar" />
    </PageLayout>
  </body>
</html>

<style is:global>
  @import '../styles/globals.css';
</style>
