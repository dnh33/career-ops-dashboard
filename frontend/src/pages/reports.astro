---
import PageLayout from '../components/layout/PageLayout.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import Loader from '../components/primitives/Loader.astro';
import EmptyState from '../components/primitives/EmptyState.astro';
---

<PageLayout
  title="Reports"
  pageTitle="All Reports"
  description="Evaluation history with A-G scoring"
  currentPath="/reports"
>
  <div slot="hero" class="reports-page__hero">
    <h1 class="reports-page__title">All Reports</h1>
    <p class="reports-page__subtitle">Evaluation history with A-G scoring</p>
  </div>

  <div slot="actions" class="reports-page__actions">
    <a href="/evaluate" class="toolbar-btn toolbar-btn-primary">+ Evaluate Job</a>
  </div>

  <section class="reports-page__table-section" aria-label="Reports">
    <div class="reports-page__toolbar">
      <SearchField
        id="search-input"
        name="reports-search"
        placeholder="Filter by company or role..."
        class="reports-page__search"
      />
      <select id="sort-select" class="toolbar-btn reports-page__sort">
        <option value="date_desc">Newest</option>
        <option value="date_asc">Oldest</option>
        <option value="score_desc">Best Score</option>
        <option value="score_asc">Worst Score</option>
      </select>
    </div>

    <div class="data-table-panel">
      <div class="data-table-panel__scroll">
        <table class="data-table" id="reports-table">
          <thead>
            <tr>
              <th scope="col" style="width: var(--size-13);">Grade</th>
              <th scope="col">Company</th>
              <th scope="col">Role</th>
              <th scope="col">Archetype</th>
              <th scope="col" style="width: var(--size-18);">Date</th>
              <th scope="col" style="width: var(--size-20);">Legitimacy</th>
              <th scope="col" style="width: var(--size-15);">PDF</th>
            </tr>
          </thead>
          <tbody id="reports-tbody"></tbody>
        </table>
      </div>
    </div>

    <p id="reports-meta" class="reports-page__meta"></p>
  </section>
</PageLayout>

<script>
  import { scoreToGrade, gradeClass, gradeColorVars } from '../utils/colors';

  let allReports = [];

  function relDate(d) {
    if (!d) return '—';
    const diff = (Date.now() - new Date(d).getTime()) / 86400000;
    if (diff < 1) return 'Today';
    if (diff < 2) return 'Yesterday';
    if (diff < 7) return `${Math.floor(diff)}d ago`;
    return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function legitTag(l) {
    const lc = (l || '').toLowerCase();
    if (lc.includes('high') || lc.includes('legit')) return 'tag-high';
    if (lc.includes('scam') || lc.includes('fake')) return 'tag-low';
    if (lc.includes('medium') || lc.includes('medium')) return 'tag-mid';
    return 'tag-neutral';
  }

  async function loadReports() {
    try {
      const res = await fetch('/api/reports?limit=100');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      allReports = data.reports || [];
      renderReports();
      document.getElementById('reports-meta').textContent = `Showing ${allReports.length} reports`;
    } catch {
      const tbody = document.getElementById('reports-tbody');
      tbody.innerHTML = '<tr><td colspan="7" class="empty-row">Failed to load reports <button class="toolbar-btn" id="reports-retry-btn" style="margin-left: var(--space-2);">Retry</button></td></tr>';
      document.getElementById('reports-retry-btn')?.addEventListener('click', loadReports);
    }
  }

  function renderReports() {
    const tbody = document.getElementById('reports-tbody');
    const query = (document.getElementById('search-input').value || '').toLowerCase().trim();
    const sort = document.getElementById('sort-select').value;

    let filtered = allReports.filter(r => {
      if (!query) return true;
      return (r.company || '').toLowerCase().includes(query) || (r.role || '').toLowerCase().includes(query);
    });

    filtered.sort((a, b) => {
      if (sort === 'date_desc') return (b.date || '').localeCompare(a.date || '');
      if (sort === 'date_asc') return (a.date || '').localeCompare(b.date || '');
      if (sort === 'score_desc') return (b.score || 0) - (a.score || 0);
      return (a.score || 0) - (b.score || 0);
    });

    if (filtered.length === 0) {
      tbody.innerHTML = `<tr><td colspan="7" class="empty-row">${query ? 'No matches' : 'No reports yet'}</td></tr>`;
      return;
    }

    tbody.innerHTML = filtered.map(r => {
      const g = scoreToGrade(r.score);
      const cv = gradeColorVars(g);
      return `<tr class="dash-table-row" data-report-id="${r.id}">
        <td style="padding: var(--space-2) var(--space-3); vertical-align: middle;">
          <span class="inline-flex items-center justify-center rounded-full" style="width: var(--size-7); height: var(--size-7); background: ${cv.bg}; color: ${cv.text}; font-size: var(--text-xs); font-weight: 700;">${g}</span>
        </td>
        <td style="padding: var(--space-2) var(--space-3); vertical-align: middle; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: var(--max-width-card);">${r.company || '—'}</td>
        <td style="padding: var(--space-2) var(--space-3); vertical-align: middle; color: var(--text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: var(--max-width-card);">${r.role || '—'}</td>
        <td style="padding: var(--space-2) var(--space-3); vertical-align: middle; color: var(--text-muted);">${r.archetype || '—'}</td>
        <td style="padding: var(--space-2) var(--space-3); vertical-align: middle; color: var(--text-muted);">${relDate(r.date)}</td>
        <td style="padding: var(--space-2) var(--space-3); vertical-align: middle;">
          ${r.legitimacy ? `<span class="tag ${legitTag(r.legitimacy)}">${r.legitimacy.split(' ')[0]}</span>` : '—'}
        </td>
        <td style="padding: var(--space-2) var(--space-3); vertical-align: middle; text-align: center;">${r.pdf ? '✓' : '—'}</td>
      </tr>`;
    }).join('');

    // Add click handler for report rows (delegated)
    tbody.querySelectorAll('tr[data-report-id]').forEach(row => {
      row.addEventListener('click', () => {
        const id = row.getAttribute('data-report-id');
        if (id) window.location.href = '/report?id=' + id;
      });
    });
  }

  document.getElementById('search-input').addEventListener('input', renderReports);
  document.getElementById('sort-select').addEventListener('change', renderReports);
  document.addEventListener('DOMContentLoaded', loadReports);
</script>

<style>
  .reports-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .reports-page__hero {
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .reports-page__title {
    margin: 0 0 var(--space-1);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .reports-page__subtitle {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .reports-page__actions {
    display: flex;
    justify-content: flex-end;
  }

  .reports-page__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .reports-page__search {
    flex: 1;
    min-width: min(100%, var(--size-80));
  }

  .reports-page__sort {
    font-family: var(--font-sans);
    min-width: var(--size-36);
  }

  .reports-page__table-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .reports-page__meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .data-table-panel {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .data-table-panel__scroll {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table thead th {
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-muted);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    background: var(--bg-card);
    white-space: nowrap;
    cursor: pointer;
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right;
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    color: var(--text-primary);
  }

  .data-table tbody tr:hover td {
    background: var(--bg-tertiary);
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    white-space: nowrap;
  }

  .tag-high {
    color: var(--grade-high);
    border-color: var(--grade-high-border);
    background: var(--grade-high-bg);
  }

  .tag-mid {
    color: var(--grade-mid);
    border-color: var(--grade-mid-border);
    background: var(--grade-mid-bg);
  }

  .tag-low {
    color: var(--grade-low);
    border-color: var(--grade-low-border);
    background: var(--grade-low-bg);
  }

  .tag-neutral {
    color: var(--text-muted);
    border-color: var(--border-hover);
    background: var(--bg-surface);
  }

  .empty-row {
    padding: var(--space-8);
    text-align: center;
    color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .reports-page__toolbar {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>