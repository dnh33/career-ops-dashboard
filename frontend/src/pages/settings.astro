---
import PageLayout from '../components/layout/PageLayout.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import SearchField from '../components/primitives/SearchField.astro';
import DataTable from '../components/primitives/DataTable.astro';
import MetricCard from '../components/primitives/MetricCard.astro';
import CodeBlock from '../components/primitives/CodeBlock.astro';
import Switch from '../components/primitives/Switch.astro';

const settingsTabs = [
  { id: 'general', label: 'General', icon: 'settings' },
  { id: 'api-keys', label: 'API Keys', icon: 'key' },
  { id: 'notifications', label: 'Notifications', icon: 'bell' },
  { id: 'appearance', label: 'Appearance', icon: 'color-mode' },
  { id: 'data', label: 'Data', icon: 'database' },
  { id: 'advanced', label: 'Advanced', icon: 'tools' },
];

const currencyOptions = [
  { id: 'DKK', label: 'DKK' },
  { id: 'EUR', label: 'EUR' },
  { id: 'USD', label: 'USD' },
];

const themeOptions = [
  { id: 'light', label: 'Light' },
  { id: 'dark', label: 'Dark' },
  { id: 'system', label: 'System' },
];

const densityOptions = [
  { id: 'compact', label: 'Compact' },
  { id: 'comfortable', label: 'Comfortable' },
];

const apiKeyColumns = [
  { key: 'service', label: 'Service' },
  { key: 'status', label: 'Key Status' },
  { key: 'lastUsed', label: 'Last Used', mono: true },
  { key: 'action', label: 'Action' },
];

const apiKeyRows = [
  {
    id: 'openrouter',
    cells: {
      service: 'OpenRouter',
      status: { kind: 'pill' as const, label: 'Active', variant: 'success' as const },
      lastUsed: '2h ago',
      action: { kind: 'code' as const, code: 'sk-••••••••••••••••••••••••', language: 'key' },
    },
  },
  {
    id: 'nvidia',
    cells: {
      service: 'NVIDIA NIM',
      status: { kind: 'pill' as const, label: 'Fallback', variant: 'warning' as const },
      lastUsed: '3d ago',
      action: { kind: 'code' as const, code: 'nvapi-••••••••••••••••', language: 'key' },
    },
  },
  {
    id: 'telegram',
    cells: {
      service: 'Telegram Bot',
      status: { kind: 'pill' as const, label: 'Missing', variant: 'error' as const },
      lastUsed: '—',
      action: { kind: 'code' as const, code: 'Not configured', language: 'key' },
    },
  },
];

const debugConfig = `{
  "logLevel": "info",
  "apiTimeout": 30000,
  "cacheTtl": 3600,
  "features": {
    "marketSync": true,
    "aiEvaluate": true
  }
}`;
---

<PageLayout
  title="Settings"
  pageTitle="Settings"
  description="Configure location, API keys, notifications, appearance, and data sync preferences."
  currentPath="/settings"
>
  <div slot="hero" class="settings-page__hero">
    <h1 class="settings-page__title">Settings</h1>
    <p class="settings-page__subtitle">Configure location, API keys, notifications, appearance, and data sync preferences.</p>
  </div>

  <div slot="actions" class="settings-page__actions">
    <SegmentedControl
      options={settingsTabs}
      value="general"
      name="settings-tab"
      vertical
      ariaLabel="Settings sections"
      class="settings-page__tabs"
    />
  </div>

  <div class="settings-page__panels">
    <!-- General -->
    <section id="settings-panel-general" class="settings-panel" aria-labelledby="settings-general-heading">
      <h2 id="settings-general-heading" class="settings-panel__title">General</h2>
      <div class="settings-panel__field">
        <label class="settings-panel__label" for="settings-location">Default location</label>
        <SearchField
          name="settings-location"
          placeholder="Copenhagen, Denmark"
          value="Copenhagen, Denmark"
          ariaLabel="Default location"
        />
      </div>
      <div class="settings-panel__field">
        <span class="settings-panel__label">Salary currency</span>
        <SegmentedControl
          options={currencyOptions}
          value="DKK"
          name="salary-currency"
          ariaLabel="Salary currency"
        />
      </div>
    </section>

    <!-- API Keys -->
    <section id="settings-panel-api-keys" class="settings-panel" hidden aria-labelledby="settings-api-heading">
      <h2 id="settings-api-heading" class="settings-panel__title">API Keys</h2>
      <DataTable columns={apiKeyColumns} rows={apiKeyRows} emptyMessage="No API keys configured" />
      <div class="settings-key-actions">
        {apiKeyRows.map((row) => (
          <button type="button" class="settings-key__reveal" data-reveal={row.id} aria-label={`Reveal ${row.cells.service} key`}>
            <i class="codicon codicon-eye" aria-hidden="true"></i>
            <span>Reveal {row.cells.service}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- Notifications -->
    <section id="settings-panel-notifications" class="settings-panel" hidden aria-labelledby="settings-notif-heading">
      <h2 id="settings-notif-heading" class="settings-panel__title">Notifications</h2>
      <div class="settings-panel__switches">
        <Switch name="notify-email" label="Email" description="Evaluation summaries and weekly digest" checked />
        <Switch name="notify-telegram" label="Telegram" description="Instant alerts for high-score matches" />
        <Switch name="notify-inapp" label="In-app" description="Toast notifications in the dashboard" checked />
      </div>
    </section>

    <!-- Appearance -->
    <section id="settings-panel-appearance" class="settings-panel" hidden aria-labelledby="settings-appearance-heading">
      <h2 id="settings-appearance-heading" class="settings-panel__title">Appearance</h2>
      <div class="settings-panel__field">
        <span class="settings-panel__label">Theme</span>
        <SegmentedControl
          options={themeOptions}
          value="system"
          name="theme-mode"
          ariaLabel="Theme mode"
          class="settings-theme-control"
        />
      </div>
      <div class="settings-panel__field">
        <span class="settings-panel__label">Density</span>
        <SegmentedControl
          options={densityOptions}
          value="compact"
          name="page-density"
          ariaLabel="Page density"
          class="settings-density-control"
        />
      </div>
    </section>

    <!-- Data -->
    <section id="settings-panel-data" class="settings-panel" hidden aria-labelledby="settings-data-heading">
      <h2 id="settings-data-heading" class="settings-panel__title">Data</h2>
      <div class="settings-panel__field">
        <span class="settings-panel__label">Auto-sync interval</span>
        <SegmentedControl
          options={[
            { id: '15m', label: '15 min' },
            { id: '1h', label: '1 hour' },
            { id: '6h', label: '6 hours' },
            { id: '24h', label: '24 hours' },
          ]}
          value="1h"
          name="sync-interval"
          ariaLabel="Auto-sync interval"
        />
      </div>
      <div class="settings-panel__actions">
        <button type="button" class="toolbar-btn" data-action="data-refresh">Refresh Now</button>
        <button type="button" class="toolbar-btn" data-action="data-export">Export Data</button>
      </div>
    </section>

    <!-- Advanced -->
    <section id="settings-panel-advanced" class="settings-panel" hidden aria-labelledby="settings-advanced-heading">
      <h2 id="settings-advanced-heading" class="settings-panel__title">Advanced</h2>
      <div class="settings-panel__field">
        <span class="settings-panel__label">Debug Config</span>
        <CodeBlock code={debugConfig} language="json" showLineNumbers={false} copyable={true} />
      </div>
      <div class="settings-panel__actions">
        <button type="button" class="toolbar-btn" data-action="debug-reset">Reset to Defaults</button>
      </div>
    </section>
  </div>
</PageLayout>

<script>
  // Settings page client-side logic
  const tabs = document.querySelector('.settings-page__tabs');
  const panels = document.querySelectorAll('.settings-panel');

  function showPanel(tabId) {
    panels.forEach(p => p.hidden = true);
    const panel = document.getElementById(`settings-panel-${tabId}`);
    if (panel) panel.hidden = false;
  }

  tabs?.addEventListener('change', (event) => {
    const detail = (event as CustomEvent<{ value: string }>).detail;
    if (detail?.value) showPanel(detail.value);
  });

  // Theme sync
  const themeControl = document.querySelector('.settings-theme-control');
  themeControl?.addEventListener('change', (event) => {
    const detail = (event as CustomEvent<{ value: string }>).detail;
    if (detail?.value) {
      document.documentElement.setAttribute('data-theme', detail.value);
      localStorage.setItem('career-ops-theme', detail.value);
      window.dispatchEvent(new CustomEvent('theme:change', { detail: { theme: detail.value } }));
    }
  });

  // Density sync
  const densityControl = document.querySelector('.settings-density-control');
  densityControl?.addEventListener('change', (event) => {
    const detail = (event as CustomEvent<{ value: string }>).detail;
    if (detail?.value) {
      document.documentElement.setAttribute('data-density', detail.value);
      localStorage.setItem('career-ops-density', detail.value);
      window.dispatchEvent(new CustomEvent('density:change', { detail: { density: detail.value } }));
    }
  });

  // API key reveal
  document.querySelectorAll('.settings-key__reveal').forEach(btn => {
    btn.addEventListener('click', () => {
      const service = btn.getAttribute('data-reveal');
      alert(`Reveal logic for ${service} - not implemented in demo`);
    });
  });

  // Data actions
  document.querySelector('[data-action="data-refresh"]')?.addEventListener('click', () => {
    console.log('Refresh data - not implemented in demo');
  });

  document.querySelector('[data-action="data-export"]')?.addEventListener('click', () => {
    console.log('Export data - not implemented in demo');
  });

  // Advanced actions
  document.querySelector('[data-action="debug-reset"]')?.addEventListener('click', () => {
    console.log('Reset to defaults - not implemented in demo');
  });

  // Show default panel
  showPanel('general');
</script>

<style>
  .settings-page {
    display: grid;
    grid-template-columns: var(--size-56) minmax(0, 1fr);
    gap: var(--space-5);
    min-height: var(--size-128);
  }

  @media (max-width: 1024px) {
    .settings-page {
      grid-template-columns: 1fr;
    }

    .settings-page__nav {
      position: fixed;
      sticky;
      top: calc(var(--space-6) + var(--space-4));
      z-index: var(--z-sticky);
    }
  }

  .settings-page__hero {
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .settings-page__title {
    margin: 0 0 var(--space-1);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .settings-page__subtitle {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .settings-page__tabs {
    width: 100%;
  }

  .settings-page__panels {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .settings-panel {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
    padding: var(--space-5);
  }

  .settings-panel__title {
    margin: 0 0 var(--space-5);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
  }

  .settings-panel__field {
    margin-bottom: var(--space-4);
  }

  .settings-panel__label {
    display: block;
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
  }

  .settings-panel__switches {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .settings-panel__actions {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .settings-key-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .settings-key__reveal {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    border: var(--border-width) solid var(--border-default);
    background: var(--bg-elevated);
    box-shadow: var(--shadow-md);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    min-height: auto;
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition-base), background-color var(--transition-base);
  }

  .settings-key__reveal:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }

  .settings-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    background: var(--bg-surface);
  }

  .settings-overlay__dialog {
    width: 100%;
    max-width: var(--size-112);
    background: var(--bg-elevated);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .settings-overlay__message {
    margin: 0 0 var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .settings-overlay__actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-2);
  }

  .overlay__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .overlay__title {
    margin: 0;
    font-size: var(--text-lg);
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--text-primary);
  }

  .overlay__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--size-8);
    height: var(--size-8);
    min-height: auto;
    border: none;
    background: none;
    color: var(--text-muted);
    cursor: pointer;
    border-radius: var(--radius-sm);
  }

  .overlay__close:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }

  .overlay__body {
    padding: var(--space-4);
  }

  @media (max-width: 1024px) {
    .settings-page {
      grid-template-columns: 1fr;
    }

    .settings-page__nav {
      position: sticky;
      top: calc(var(--space-6) + var(--space-4));
      z-index: var(--z-sticky);
    }
  }
</style>