---
import PageLayout from '../components/layout/PageLayout.astro';
import MarketScoreBadge from '../components/market/MarketScoreBadge.astro';
import GapAnalysisPanel from '../components/market/GapAnalysisPanel.astro';
import Loader from '../components/primitives/Loader.astro';
import ErrorState from '../components/primitives/ErrorState.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import EmptyState from '../components/primitives/EmptyState.astro';
---

<PageLayout
  title="Evaluate"
  pageTitle="Job Evaluation"
  description="Paste a job description or fetch one from a URL to get an A-G evaluation report."
  currentPath="/evaluate"
>
  <div slot="hero" class="evaluate-page__hero">
    <h1 class="evaluate-page__title">Job Evaluation</h1>
    <p class="evaluate-page__subtitle">Paste a job description or fetch one from a URL to get an A-G evaluation report.</p>
  </div>

  <div slot="actions" class="evaluate-page__actions">
    <SearchField
      id="company-select"
      name="company-select"
      placeholder="Re-evaluate for target company..."
      class="evaluate-page__company-search"
    />
  </div>

  <div class="evaluate-page__grid">
    <!-- LEFT: Input form -->
    <section class="evaluate-page__input-section" aria-labelledby="input-heading">
      <h2 id="input-heading" class="evaluate-page__section-title">Input</h2>

      <div class="evaluate-page__tabs" role="tablist" aria-label="Input method">
        <button id="tab-paste" role="tab" aria-selected="true" aria-controls="panel-paste" class="evaluate-page__tab evaluate-page__tab--active">Paste Text</button>
        <button id="tab-url" role="tab" aria-selected="false" aria-controls="panel-url" class="evaluate-page__tab">From URL</button>
      </div>

      <div id="panel-paste" role="tabpanel" aria-labelledby="tab-paste">
        <label for="jd-textarea" class="evaluate-page__label">Job Description</label>
        <textarea id="jd-textarea" rows="12" placeholder="Paste the full job description here..." class="evaluate-page__textarea"></textarea>
        <div class="evaluate-page__textarea-footer">
          <span id="char-count" class="evaluate-page__char-count">0 characters</span>
          <button type="button" id="clear-btn" class="evaluate-page__clear-btn hidden">Clear</button>
        </div>
      </div>

      <div id="panel-url" role="tabpanel" aria-labelledby="tab-url" hidden>
        <label for="jd-url" class="evaluate-page__label">Job Posting URL</label>
        <div class="evaluate-page__url-input-group">
          <input id="jd-url" type="url" placeholder="https://careers.company.com/jobs/12345" class="evaluate-page__url-input" />
          <button type="button" id="fetch-btn" class="evaluate-page__fetch-btn">Fetch</button>
        </div>
        <p id="fetch-error" class="evaluate-page__error hidden" role="alert">Could not fetch from this URL. Check the link or paste the text directly.</p>
      </div>

      <div class="evaluate-page__evaluate-wrapper">
        <button type="button" id="evaluate-btn" class="evaluate-page__evaluate-btn">Evaluate Job Description</button>
        <p class="evaluate-page__hint hidden" id="evaluate-hint">Enter at least 50 characters to evaluate</p>
      </div>
    </section>

    <!-- RIGHT: Results area -->
    <section class="evaluate-page__results-section" aria-labelledby="results-heading">
      <h2 id="results-heading" class="sr-only">Results</h2>

      <div id="eval-empty" class="evaluate-page__state evaluate-page__state--empty">
        <svg class="evaluate-page__empty-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
        <p class="evaluate-page__state-title">Paste a JD to get started</p>
        <p class="evaluate-page__state-desc">Enter a job description and click Evaluate to see your A-G score and detailed feedback.</p>
      </div>

      <div id="eval-loading" class="evaluate-page__state evaluate-page__state--loading hidden" aria-busy="true" aria-label="Evaluating job description">
        <div class="evaluate-page__loading-content">
          <div class="evaluate-page__loading-header">
            <div class="evaluate-page__spinner"></div>
            <span class="evaluate-page__loading-title">Analyzing job description...</span>
          </div>
          <div class="evaluate-page__progress-bar-container">
            <div id="loading-bar" class="evaluate-page__progress-bar" style="width: 0%;"></div>
          </div>
          <p id="loading-status" class="evaluate-page__loading-status">Parsing content...</p>
        </div>
        <div class="evaluate-page__skeleton-grid">
          <div class="evaluate-page__skeleton-card"></div>
          <div class="evaluate-page__skeleton-card"></div>
          <div class="evaluate-page__skeleton-card"></div>
        </div>
        <div class="evaluate-page__skeleton-text-group">
          <div class="evaluate-page__skeleton-text"></div>
          <div class="evaluate-page__skeleton-text"></div>
          <div class="evaluate-page__skeleton-text"></div>
        </div>
      </div>

      <div id="eval-results" class="hidden" aria-label="Evaluation results">
        <!-- Market Score & Gap Analysis -->
        <div class="evaluate-page__market-insights hidden" id="market-insights">
          <div>
            <MarketScoreBadge id="market-badge" score={0} grade={null} visible={false} />
          </div>
          <div>
            <GapAnalysisPanel id="gap-panel" gaps={[]} suggestions={[]} strengths={[]} visible={false} />
          </div>
        </div>

        <!-- Company Fit Section -->
        <div id="company-fit-section" class="hidden">
          <div class="evaluate-page__company-fit">
            <div class="evaluate-page__company-fit-header">
              <h3 class="evaluate-page__company-fit-title">Company Fit</h3>
              <div class="evaluate-page__company-select-wrapper">
                <label for="company-select" class="evaluate-page__company-select-label">Re-evaluate for:</label>
                <select id="company-select" class="evaluate-page__company-select">
                  <option value="">Select a target company...</option>
                </select>
              </div>
            </div>
            <div id="company-fit-content" class="evaluate-page__company-fit-content"></div>
          </div>
        </div>

        <div class="evaluate-page__score-section">
          <div class="evaluate-page__score-card" role="img" aria-label="Overall grade">
            <div id="grade-ring" class="evaluate-page__grade-ring">
              <svg width="120" height="120" class="evaluate-page__grade-ring-svg" viewBox="0 0 120 120">
                <circle cx="60" cy="60" r="54" fill="none" stroke="var(--border-default)" stroke-width="6" />
                <circle id="grade-progress" cx="60" cy="60" r="54" fill="none" stroke="var(--grade-mid)" stroke-width="6" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="339.292" class="evaluate-page__grade-ring-progress" />
              </svg>
              <span id="grade-letter" class="evaluate-page__grade-letter">C</span>
            </div>
            <span id="score-value" class="evaluate-page__score-value">50 / 100</span>
          </div>
          <div class="evaluate-page__score-summary">
            <h3 class="evaluate-page__score-title">Overall Evaluation Score</h3>
            <p id="score-summary" class="evaluate-page__score-desc">This job description covers most key areas but has room for improvement.</p>
            <div class="evaluate-page__score-tags" id="score-tags"></div>
          </div>
        </div>

        <div class="evaluate-page__breakdown-section">
          <h3 class="evaluate-page__section-title">Detailed Breakdown</h3>
          <div id="report-sections" class="evaluate-page__breakdown-content"></div>
        </div>

        <div class="evaluate-page__action-bar">
          <button type="button" id="re-evaluate-btn" class="evaluate-page__re-evaluate-btn">Re-evaluate</button>
          <a href="/output" class="evaluate-page__output-link">Generate Tailored Resume</a>
        </div>
      </div>

      <div id="eval-error" class="evaluate-page__state evaluate-page__state--error hidden" role="alert">
        <div class="evaluate-page__error-content">
          <svg class="evaluate-page__error-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16c-.77.833.192 2.5 1.732 2.5z" /></svg>
          <div class="evaluate-page__error-text">
            <h4 class="evaluate-page__error-title">Evaluation failed</h4>
            <p class="evaluate-page__error-message">Could not process the job description. Ensure the content is valid and try again.</p>
            <button type="button" id="error-retry-btn" class="evaluate-page__error-retry-btn hidden">Retry Evaluation</button>
            <button type="button" id="error-back-btn" class="evaluate-page__error-back-btn">Try Again</button>
          </div>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

<script>
  import { scoreToGrade, gradeClass, gradeColorVars } from '../utils/colors';

  const CIRC = 2 * Math.PI * 54; // grade ring circumference (r=54)

  // ===== Element refs =====
  const tabPaste = document.getElementById('tab-paste') as HTMLButtonElement;
  const tabUrl = document.getElementById('tab-url') as HTMLButtonElement;
  const panelPaste = document.getElementById('panel-paste')!;
  const panelUrl = document.getElementById('panel-url')!;
  const textarea = document.getElementById('jd-textarea') as HTMLTextAreaElement;
  const urlInput = document.getElementById('jd-url') as HTMLInputElement;
  const fetchBtn = document.getElementById('fetch-btn') as HTMLButtonElement;
  const fetchError = document.getElementById('fetch-error')!;
  const charCount = document.getElementById('char-count')!;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const evaluateBtn = document.getElementById('evaluate-btn') as HTMLButtonElement;
  const evaluateHint = document.getElementById('evaluate-hint')!;
  const emptyState = document.getElementById('eval-empty')!;
  const loadingSection = document.getElementById('eval-loading')!;
  const loadingBar = document.getElementById('loading-bar')!;
  const loadingStatus = document.getElementById('loading-status')!;
  const resultsSection = document.getElementById('eval-results')!;
  const errorSection = document.getElementById('eval-error')!;
  const gradeRing = document.getElementById('grade-ring')!;
  const gradeProgress = document.getElementById('grade-progress')!;
  const gradeLetter = document.getElementById('grade-letter')!;
  const scoreValue = document.getElementById('score-value')!;
  const scoreSummary = document.getElementById('score-summary')!;
  const scoreTags = document.getElementById('score-tags')!;
  const marketBadgeContainer = document.getElementById('market-badge')!;
  const gapPanelContainer = document.getElementById('gap-panel')!;
  const companyFitSection = document.getElementById('company-fit-section')!;
  const companyFitContent = document.getElementById('company-fit-content')!;
  const companySelect = document.getElementById('company-select')!;
  const reportSections = document.getElementById('report-sections')!;
  const reEvaluateBtn = document.getElementById('re-evaluate-btn') as HTMLButtonElement;
  const errorRetryBtn = document.getElementById('error-retry-btn') as HTMLButtonElement;
  const errorBackBtn = document.getElementById('error-back-btn') as HTMLButtonElement;

  // ===== Tab switching =====
  function switchTab(which: string): void {
    const isPaste = which === 'paste';
    tabPaste.setAttribute('aria-selected', String(isPaste));
    tabUrl.setAttribute('aria-selected', String(!isPaste));
    tabPaste.classList.toggle('evaluate-page__tab--active', isPaste);
    tabUrl.classList.toggle('evaluate-page__tab--active', !isPaste);
    panelPaste.hidden = !isPaste;
    panelUrl.hidden = isPaste;
  }

  tabPaste.addEventListener('click', () => switchTab('paste'));
  tabUrl.addEventListener('click', () => switchTab('url'));

  // ===== Textarea input handling =====
  textarea.addEventListener('input', () => {
    const len = textarea.value.length;
    charCount.textContent = len + ' character' + (len !== 1 ? 's' : '');
    clearBtn.hidden = len === 0;
    evaluateHint.hidden = len >= 50;
  });

  clearBtn.addEventListener('click', () => {
    textarea.value = '';
    charCount.textContent = '0 characters';
    clearBtn.hidden = true;
    textarea.focus();
  });

  // ===== URL fetch (client-side simulation) =====
  fetchBtn.addEventListener('click', () => {
    const url = urlInput.value.trim();
    if (!url) return;
    fetchBtn.disabled = true;
    fetchBtn.textContent = 'Fetching...';
    fetchError.hidden = true;
    setTimeout(() => {
      textarea.value = '[Fetched from ' + url + ']\n\nSenior Software Engineer\n\nWe are looking for an experienced software engineer to join our growing team.\n\nRequirements:\n- 5+ years TypeScript\n- React and Node.js\n- Strong problem-solving skills\n\nBenefits:\n- Competitive salary\n- Flexible hours\n- Remote-first';
      charCount.textContent = textarea.value.length + ' characters';
      clearBtn.hidden = false;
      switchTab('paste');
      fetchBtn.disabled = false;
      fetchBtn.textContent = 'Fetch';
    }, 800);
  });

  // ===== Company select =====
  let targetCompany = null;

  async function populateCompanySelect(): Promise<void> {
    try {
      const resp = await fetch('/api/market/overview');
      if (!resp.ok) throw new Error('Failed to fetch companies');
      const data = await resp.json();
      const companies = data.companies || [];
      // Sort by priority descending, then name
      companies.sort((a, b) => (b.priority || 0) - (a.priority || 0) || a.name.localeCompare(b.name));
      const options = companies.map(company => `<option value="${company.slug}">${company.name}</option>`).join('');
      companySelect.innerHTML = `<option value="">Select a target company...</option>` + options;
    } catch (err) {
      console.error('Failed to populate company select:', err);
      // Fallback to a static list
      companySelect.innerHTML = `
        <option value="">Select a target company...</option>
        <option value="corti">Corti</option>
        <option value="zendesk">Zendesk</option>
        <option value="novonordisk">Novo Nordisk</option>
        <option value="maersk">Maersk</option>
        <option value="universalrobots">Universal Robots</option>
        <option value="microsoft">Microsoft DK</option>
        <option value="spotify">Spotify</option>
        <option value="trustpilot">Trustpilot</option>
      `;
    }
  }

  // Populate company select on DOM load
  document.addEventListener('DOMContentLoaded', populateCompanySelect);

  // Handle company select change
  companySelect.addEventListener('change', (e) => {
    const selected = e.target.value;
    targetCompany = selected ? selected : null;
  });

  // ===== Section visibility =====
  function showSection(id: string): void {
    [emptyState, loadingSection, resultsSection, errorSection].forEach((el) => el.hidden = true);
    const el = document.getElementById(id);
    if (el) el.hidden = false;
  }

  // ===== Score coloring — uses shared utility =====
  function scoreColors(score: number): { stroke: string; text: string; bg: string } {
    return gradeColorVars(scoreToGrade(score));
  }

  // ===== Loading animation =====
  let loadingInterval: ReturnType<typeof setInterval> | null = null;
  let loadingTimeout: ReturnType<typeof setTimeout> | null = null;
  let abortController: AbortController | null = null;

  // Progress phases mapped to elapsed time (seconds) — estimates for long evaluations
  const PROGRESS_PHASES = [
    { at: 0,    status: 'Parsing content...',         bar: 5  },
    { at: 2,    status: 'Analyzing job description...', bar: 15 },
    { at: 10,   status: 'Matching against CV...',       bar: 35 },
    { at: 30,   status: 'Scoring A-G sections...',      bar: 60 },
    { at: 90,   status: 'Generating report...',         bar: 80 },
    { at: 180,  status: 'Almost done...',               bar: 90 },
  ];
  const STALL_THRESHOLD_MS = 5 * 60 * 1000; // 5 minutes
  const FETCH_TIMEOUT_MS   = 8 * 60 * 1000; // hard browser kill at 8 min (before any proxy gives up)

  function animateLoading(): void {
    showSection('eval-loading');
    const start = Date.now();
    let lastPhaseIdx = -1;

    loadingInterval = setInterval(() => {
      const elapsed = Date.now() - start;
      const elapsedSec = elapsed / 1000;

      // Find current phase
      let phaseIdx = 0;
      for (let i = 0; i < PROGRESS_PHASES.length; i++) {
        if (elapsedSec >= PROGRESS_PHASES[i].at) phaseIdx = i;
      }
      if (phaseIdx !== lastPhaseIdx) {
        lastPhaseIdx = phaseIdx;
        loadingStatus.textContent = PROGRESS_PHASES[phaseIdx].status;
      }

      // Smoothly animate bar toward phase target
      const target = PROGRESS_PHASES[phaseIdx].bar;
      const current = parseFloat(loadingBar.style.width) || 0;
      if (current < target) {
        loadingBar.style.width = Math.min(current + 3, target) + '%';
      }
    }, 300);

    // 5-minute stall warning
    loadingTimeout = setTimeout(() => {
      if (loadingInterval) {
        loadingStatus.textContent = 'Still evaluating — this can take several minutes. Check back later.';
        loadingStatus.classList.add('text-[var(--grade-mid)]');
        loadingStatus.classList.remove('text-[var(--text-muted)]');
      }
    }, STALL_THRESHOLD_MS);
  }

  function stopLoading(): void {
    if (loadingInterval) { clearInterval(loadingInterval); loadingInterval = null; }
    if (loadingTimeout)   { clearTimeout(loadingTimeout);   loadingTimeout = null; }
    abortController = null;
    loadingBar.style.width = '100%';
    loadingStatus.textContent = 'Done!';
    loadingStatus.classList.remove('text-[var(--grade-mid)]');
    loadingStatus.classList.add('text-[var(--text-muted)]');
  }

  // ===== Evaluation flow =====
  async function runEvaluation(targetCompanyOverride = null): Promise<void> {
    const companyToUse = targetCompanyOverride ?? targetCompany;

    const content = textarea.value.trim();
    if (content.length < 50) { evaluateHint.hidden = false; textarea.focus(); return; }

    evaluateBtn.disabled = true;
    evaluateBtn.textContent = 'Evaluating...';

    // Start async evaluation and get job_id
    try {
      const resp = await fetch('/api/evaluate/async', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: content, target_role: 'FE-DEV', target_company: companyToUse }),
      });

      if (!resp.ok) {
        let errMsg = `Server error (${resp.status})`;
        try { const err = await resp.json(); if (err.detail) errMsg = err.detail; } catch {}
        throw new Error(errMsg);
      }

      const data = await resp.json();
      const jobId = data.job_id;
      if (!jobId) throw new Error('No job_id returned from server');

      // Connect to SSE stream
      await connectToSSEStream(jobId);
    } catch (e: any) {
      stopLoading();
      setTimeout(() => renderError(e.message || 'Evaluation failed'), 350);
    }
  }

  // ===== SSE Streaming =====
  let eventSource: EventSource | null = null;
  let sseReconnectAttempts = 0;
  const MAX_SSE_RECONNECT_ATTEMPTS = 5;
  const SSE_RECONNECT_BASE_DELAY = 1000; // 1 second

  async function connectToSSEStream(jobId: string): Promise<void> {
    animateLoading();

    const streamUrl = `/api/evaluate/${jobId}/stream`;

    function createEventSource(): EventSource {
      const es = new EventSource(streamUrl);

      es.onopen = () => {
        console.log('[SSE] Connected to stream');
        sseReconnectAttempts = 0;
      };

      es.onmessage = (event) => {
        try {
          const data = JSON.parse(event.data);
          handleSSEEvent(data);
        } catch (e) {
          console.warn('[SSE] Failed to parse event:', event.data);
        }
      };

      es.onerror = (err) => {
        console.error('[SSE] Connection error:', err);
        es.close();

        if (sseReconnectAttempts < MAX_SSE_RECONNECT_ATTEMPTS) {
          const delay = SSE_RECONNECT_BASE_DELAY * Math.pow(2, sseReconnectAttempts);
          sseReconnectAttempts++;
          console.log(`[SSE] Reconnecting in ${delay}ms (attempt ${sseReconnectAttempts}/${MAX_SSE_RECONNECT_ATTEMPTS})`);
          setTimeout(() => {
            eventSource = createEventSource();
          }, delay);
        } else {
          // Max retries exceeded - fallback to polling
          console.warn('[SSE] Max reconnect attempts reached, falling back to polling');
          fallbackToPolling(jobId);
        }
      };

      return es;
    }

    eventSource = createEventSource();
  }

  function handleSSEEvent(data: any): void {
    const { type, stage, progress, message, content, job_id } = data;

    console.log('[SSE] Event:', type, stage, progress, message);

    switch (type) {
      case 'init':
        // Initial connection - update loading status
        loadingStatus.textContent = message || 'Connected to evaluation stream...';
        break;

      case 'stage':
        // Stage update - update progress bar and status
        if (progress !== undefined) {
          loadingBar.style.width = Math.min(progress, 95) + '%';
        }
        if (message) {
          loadingStatus.textContent = message;
        }
        // Update stage badge if needed
        updateStageBadge(stage);
        break;

      case 'token':
        // Token streaming - append to live display
        if (content) {
          appendTokenToLiveDisplay(content);
        }
        break;

      case 'complete':
        // Evaluation complete - stop loading, show results
        stopLoading();
        // Fetch final result
        fetchFinalResult(job_id);
        break;

      case 'error':
        stopLoading();
        setTimeout(() => renderError(message || 'Evaluation failed'), 350);
        break;
    }
  }

  function updateStageBadge(stage: string): void {
    // Could update a visual stage indicator in the loading section
    const stageLabels: Record<string, string> = {
      'init': 'Initializing...',
      'owl_alpha': 'Analyzing with owl-alpha...',
      'cursor_eval': 'Running Cursor evaluation...',
      'validating': 'Validating report...',
      'saving': 'Saving report...',
      'market_scoring': 'Computing market score...',
      'complete': 'Complete!',
    };
    if (stageLabels[stage]) {
      loadingStatus.textContent = stageLabels[stage];
    }
  }

  let liveDisplayBuffer = '';
  let liveDisplayElement: HTMLElement | null = null;

  function appendTokenToLiveDisplay(token: string): void {
    liveDisplayBuffer += token;

    if (!liveDisplayElement) {
      // Create live display element in the loading section
      const loadingSection = document.getElementById('eval-loading')!;
      liveDisplayElement = document.createElement('div');
      liveDisplayElement.className = 'mt-4 p-4 bg-[var(--bg-elevated)] rounded-lg font-mono text-sm text-[var(--text-primary)] whitespace-pre-wrap max-h-64 overflow-y-auto border border-[var(--border-default)]';
      liveDisplayElement.style.fontFamily = 'monospace';
      liveDisplayElement.textContent = 'Streaming evaluation...\n\n';
      loadingSection.appendChild(liveDisplayElement);
    }

    liveDisplayElement.textContent = liveDisplayBuffer;
    // Auto-scroll to bottom
    liveDisplayElement.scrollTop = liveDisplayElement.scrollHeight;
  }

  function fallbackToPolling(jobId: string): void {
    loadingStatus.textContent = 'SSE unavailable, falling back to polling...';
    loadingStatus.classList.add('text-[var(--grade-mid)]');
    loadingStatus.classList.remove('text-[var(--text-muted)]');

    // Poll for completion every 3 seconds using the status endpoint
    const pollInterval = setInterval(async () => {
      try {
        const jobResp = await fetch(`/api/evaluate/${jobId}/status`);
        if (!jobResp.ok) return;

        const job = await jobResp.json();
        if (job.status === 'completed' || job.status === 'failed') {
          clearInterval(pollInterval);
          stopLoading();
          if (job.status === 'completed') {
            // Convert job to result format
            const resultData = {
              report: job.report,
              company: job.company,
              role: job.role,
              report_path: job.report_path,
              legitimacy: job.legitimacy,
              scam_warning: job.scam_warning,
              market_score: job.market_score,
              market_grade: job.market_grade,
              top_gaps: job.top_gaps,
              top_strengths: job.top_strengths,
              company_fit: job.company_fit,
            };
            renderResults(resultData);
          } else {
            renderError(job.error || 'Evaluation failed');
          }
        }
      } catch (e) {
        console.warn('[Polling] Error:', e);
      }
    }, 3000);

    // Cleanup after 10 minutes max
    setTimeout(() => clearInterval(pollInterval), 10 * 60 * 1000);
  }

  async function fetchFinalResult(jobId: string): Promise<void> {
    try {
      // We could either get the result from the SSE complete event or fetch it
      // For now, we'll use the buffered content if we have it
      if (liveDisplayBuffer && liveDisplayBuffer.length > 50) {
        // Create a mock result from the streamed content
        const mockData = {
          report: liveDisplayBuffer,
          company: 'Streamed Result',
          role: '',
          report_path: '',
          legitimacy: { tier: 'uncertain', score: 3, reasoning: '' },
          scam_warning: false,
          market_score: null,
          market_grade: null,
          top_gaps: [],
          top_strengths: [],
          company_fit: null,
        };
        setTimeout(() => renderResults(mockData), 350);
      } else {
        // Fallback: we'd need a job status endpoint
        console.warn('[SSE] No buffered content, would need job status endpoint');
        setTimeout(() => renderError('Evaluation completed but no content received'), 350);
      }
    } catch (e) {
      setTimeout(() => renderError('Failed to fetch final result'), 350);
    }
  }

  // ===== Render results from backend response =====
  function renderResults(data: any): void {
    const scoreMatch = (data.report || '').match(/\*\*Score:\*\*\s*(\d+(?:\.\d+)?)\s*\/\s*5/);
    const score = scoreMatch ? parseFloat(scoreMatch[1]) : 0;
    const colors = scoreColors(score);

    const grade = scoreToGrade(score);

    // Apply colors via CSS custom properties on the ring container
    gradeRing.style.background = colors.bg;
    gradeProgress.setAttribute('stroke', colors.stroke);
    gradeProgress.setAttribute('stroke-dashoffset', String(CIRC - (score / 5) * CIRC));
    gradeLetter.textContent = grade;
    gradeLetter.style.color = colors.text;
    scoreValue.textContent = score.toFixed(1) + ' / 5';

    scoreSummary.textContent = data.company
    // Show market insights if we have market_score
    const marketInsightsSection = document.getElementById('market-insights');
    if (marketInsightsSection) {
      if (data.market_score !== null && data.market_score !== undefined) {
        marketInsightsSection.hidden = false;
        // Update the MarketScoreBadge container
        marketBadgeContainer.innerHTML = `<MarketScoreBadge score="${data.market_score}" grade="${data.market_grade || ''}" visible="true" />`;
      } else {
        marketInsightsSection.hidden = true;
      }
    }

    // Show gap analysis panel if we have gaps or strengths
    const gapAnalysisSection = document.getElementById('gap-panel');
    if (gapAnalysisSection) {
      const hasGaps = data.top_gaps && data.top_gaps.length > 0;
      const hasStrengths = data.top_strengths && data.top_strengths.length > 0;
      if (hasGaps || hasStrengths) {
        gapAnalysisSection.hidden = false;
        // Update the GapAnalysisPanel container
        gapPanelContainer.innerHTML = `<GapAnalysisPanel gaps="${JSON.stringify(data.top_gaps)}" suggestions="[]" strengths="${JSON.stringify(data.top_strengths)}" visible="true" />`;
      } else {
        gapAnalysisSection.hidden = true;
      }
    }

    // Show company fit section if we have company_fit
    if (companyFitSection) {
      if (data.company_fit) {
        companyFitSection.hidden = false;
        // Render company fit content
        const cf = data.company_fit;
        const fitColor = cf.cultureFitScore >= 80 ? 'var(--success)' : cf.cultureFitScore >= 60 ? 'var(--warning)' : 'var(--error)';
        const salaryDiffClass = cf.salaryComparison.difference >= 0 ? 'positive' : 'negative';
        companyFitContent.innerHTML = `
          <div class="company-fit">
            <div class="fit-score">
              <h3 class="section-title">Culture Fit Score</h3>
              <div class="score-container">
                <div class="score-bar">
                  <div class="score-fill" style="width: ${cf.cultureFitScore}%; background-color: ${fitColor};"></div>
                </div>
                <div class="score-value">${cf.cultureFitScore}/100</div>
              </div>
            </div>
            <div class="fit-factors">
              <h3 class="section-title">Culture Fit Factors</h3>
              <ul class="factors-list">
                ${cf.cultureFitFactors.map(factor => `<li>${factor}</li>`).join('')}
              </ul>
            </div>
            <div class="open-roles">
              <h3 class="section-title">Roles Hiring</h3>
              <div class="roles-tags">
                ${cf.openRoles.map(role => `<span class="role-tag">${role}</span>`).join('')}
              </div>
            </div>
            <div class="salary-comparison">
              <h3 class="section-title">Salary Comparison</h3>
              <div class="salary-chart">
                <div class="salary-bar company">
                  <label>Company Median</label>
                  <div class="bar" style="height: ${Math.min(cf.salaryComparison.companyMedian / 1000 * 10, 80)}px;"></div>
                  <span class="value">${cf.salaryComparison.companyMedian} DKK</span>
                </div>
                <div class="salary-bar market">
                  <label>Market Average</label>
                  <div class="bar" style="height: ${Math.min(cf.salaryComparison.marketAverage / 1000 * 10, 80)}px;"></div>
                  <span class="value">${cf.salaryComparison.marketAverage} DKK</span>
                </div>
              </div>
              <p class="salary-diff ${salaryDiffClass}">
                ${cf.salaryComparison.difference >= 0
                  ? `Above market by ${cf.salaryComparison.difference} DKK (${cf.salaryComparison.vsMarketPct}%)`
                  : `Below market by ${Math.abs(cf.salaryComparison.difference)} DKK (${cf.salaryComparison.vsMarketPct}%)`}
              </p>
            </div>
            <div class="apply-section">
              <a href="${cf.applyUrl}" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                Apply Now
              </a>
            </div>
          </div>
        `;
      } else {
        companyFitSection.hidden = true;
        companyFitContent.innerHTML = '';
      }
    }
      scoreSummary.textContent = data.company ? 'Evaluation for ' + data.company + (data.role ? ' — ' + data.role : '') : 'Review the breakdown below.';

    const tagLabels = ['A) Role Summary', 'B) Match with CV', 'C) Level & Strategy', 'D) Comp & Demand', 'E) Customization Plan', 'F) Interview Plan', 'G) Legitimacy'];
    const tagRow: string[] = [];
    for (const label of tagLabels) {
      if ((data.report || '').includes('## ' + label.split(') ')[0] + ')')) {
        tagRow.push('<span class="px-2 py-0.5 text-xs rounded-full border border-[var(--border-hover)] text-[var(--text-primary)] bg-[var(--bg-tertiary)]/40">' + label + '</span>');
      }
    }
    scoreTags.innerHTML = tagRow.join('');

    const sectionRe = /##\s+([A-H]\)\s+.+?)\s*\n([\s\S]*?)(?=\n##\s+[A-H]\)|\n---\s*$|$)/g;
    const blocks: string[] = [];
    let match;
    while ((match = sectionRe.exec(data.report || '')) !== null) {
      const name = match[1].trim();
      const content = match[2].trim();
      const preview = content.split('\n').filter(l => l.trim() && !l.startsWith('|') && !l.startsWith('---'))[0] || '';
      blocks.push(
        '<details class="group">' +
          '<summary class="flex items-center justify-between cursor-pointer py-2 px-3 rounded-md hover:bg-[var(--bg-tertiary)]/50 transition-colors list-none">' +
            '<span class="text-sm font-medium text-[var(--text-primary)]">' + name + '</span>' +
            '<svg class="w-4 h-4 text-[var(--text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>' +
          '</summary>' +
          '<div class="px-3 pb-3 pt-1 text-xs text-[var(--text-secondary)] whitespace-pre-wrap max-h-64 overflow-y-auto">' + (content || 'No content.') + '</div>' +
        '</details>'
      );
    }
    reportSections.innerHTML = blocks.length ? blocks.join('') : '<p class="text-sm text-[var(--text-muted)]">No section breakdown available.</p>';

    showSection('eval-results');
    evaluateBtn.disabled = false;
    evaluateBtn.textContent = 'Evaluate Job Description';
  }

  // ===== Render error =====
  function renderError(message: string, isTimeout: boolean = false): void {
    const msgEl = errorSection.querySelector('.evaluate-page__error-message') as HTMLElement;
    msgEl.textContent = message;

    // Update heading based on error type
    const headingEl = errorSection.querySelector('.evaluate-page__error-title') as HTMLElement;
    headingEl.textContent = isTimeout ? 'Evaluation timed out' : 'Evaluation failed';

    // Show/hide retry button (only for timeout)
    errorRetryBtn.hidden = !isTimeout;
    if (isTimeout) {
      errorRetryBtn.textContent = 'Retry Evaluation';
      errorRetryBtn.dataset.action = 'eval-retry';
    } else {
      errorRetryBtn.textContent = 'Try Again';
      errorRetryBtn.dataset.action = 'eval-empty';
    }

    showSection('eval-error');
    evaluateBtn.disabled = false;
    evaluateBtn.textContent = 'Evaluate Job Description';
  }

  // ===== Event wiring =====
  evaluateBtn.addEventListener('click', () => runEvaluation());
  reEvaluateBtn.addEventListener('click', () => showSection('eval-empty'));
  errorRetryBtn.addEventListener('click', () => {
    const action = errorRetryBtn.dataset.action;
    if (action === 'eval-retry') {
      errorSection.hidden = true;
      runEvaluation();
    } else if (action === 'eval-empty') {
      errorSection.hidden = true;
      showSection('eval-empty');
    }
  });
  errorBackBtn.addEventListener('click', () => {
    errorSection.hidden = true;
    showSection('eval-empty');
  });
  textarea.addEventListener('keydown', (e: KeyboardEvent) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') runEvaluation();
  });
</script>

