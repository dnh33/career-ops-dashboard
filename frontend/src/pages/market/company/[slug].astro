---
import PageLayout from '../../../components/layout/PageLayout.astro';
import Loader from '../../../components/primitives/Loader.astro';
import ErrorState from '../../../components/primitives/ErrorState.astro';
import CompanyFit from '../../../components/market/CompanyFit.astro';
import SearchField from '../../../components/primitives/SearchField.astro';
import SegmentedControl from '../../../components/primitives/SegmentedControl.astro';
import StatusPill from '../../../components/primitives/StatusPill.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'corti' } },
    { params: { slug: 'zendesk' } },
    { params: { slug: 'novonordisk' } },
    { params: { slug: 'maersk' } },
    { params: { slug: 'universalrobots' } },
    { params: { slug: 'microsoft' } },
    { params: { slug: 'spotify' } },
    { params: { slug: 'trustpilot' } },
  ]
}

const { slug } = Astro.params
---

<PageLayout
  title="Company Deep-Dive"
  pageTitle="Company Deep-Dive"
  description="Deep-dive into company hiring signals, velocity, and fit scoring."
  currentPath="/market"
>
  <div slot="hero" class="company-page__hero">
    <h1 class="company-page__title" id="company-name">—</h1>
    <p class="company-page__location" id="company-location"></p>
  </div>

  <div slot="actions" class="company-page__toolbar">
    <div class="company-page__metrics" id="company-metrics"></div>
  </div>

  <div class="company-page__content">
    <div id="company-loading" class="company-page__state">
      <Loader label="Loading company intelligence" size="lg" />
    </div>

    <div id="company-error" class="company-page__state" hidden>
      <ErrorState title="Company data unavailable" message="Could not fetch company profile." />
    </div>

    <div id="company-content" hidden>
      <section class="company-page__velocity" aria-label="Hiring velocity">
        <header class="company-page__section-header">
          <h2 class="company-page__section-title">Hiring Velocity</h2>
          <span class="company-page__section-meta hermes-mono" data-mono="true">12 months</span>
        </header>
        <div class="company-page__sparkline-wrap" id="company-velocity"></div>
      </section>

      <section class="company-page__fit" aria-label="Company fit analysis">
        <CompanyFit id="company-fit" company={null} visible={false} />
      </section>

      <section class="company-page__postings" aria-label="Their postings">
        <header class="company-page__section-header">
          <h2 class="company-page__section-title">Their Postings</h2>
          <span class="company-page__section-meta hermes-mono" data-mono="true" id="company-role-count">0</span>
        </header>
        <div class="data-table-panel">
          <div class="data-table-panel__scroll">
            <table class="data-table" aria-label="Company postings">
              <thead>
                <tr>
                  <th scope="col">Role</th>
                  <th scope="col">Seniority</th>
                  <th scope="col" class="data-table__th--right hermes-mono" data-mono="true">Salary</th>
                  <th scope="col">Your Skills</th>
                  <th scope="col" class="data-table__th--right hermes-mono" data-mono="true">Gap</th>
                  <th scope="col" class="data-table__th--right hermes-mono" data-mono="true">Fit Score</th>
                  <th scope="col">Action</th>
                </tr>
              </thead>
              <tbody id="company-table-body"></tbody>
            </table>
          </div>
        </div>
      </section>
    </div>
  </div>
</PageLayout>

<script is:inline define:vars={{ slug }}>
  const loadingEl = document.getElementById('company-loading')
  const errorEl = document.getElementById('company-error')
  const contentEl = document.getElementById('company-content')
  const metricsEl = document.getElementById('company-metrics')
  const velocityEl = document.getElementById('company-velocity')
  const tableBody = document.getElementById('company-table-body')
  const countEl = document.getElementById('company-role-count')
  const fitComponent = document.getElementById('company-fit')

  function gapVariant(gap) {
    if (gap > 20) return 'warm'
    if (gap >= 10) return 'warning'
    return 'success'
  }

  function fitVariant(score) {
    if (score >= 80) return 'success'
    if (score >= 60) return 'warning'
    return 'error'
  }

  function actionVariant(action) {
    if (action === 'Apply') return 'success'
    if (action === 'Tailor') return 'warning'
    return 'default'
  }

  function sparklineSvg(data) {
    const width = 640
    const height = 72
    const max = Math.max(...data, 1)
    const min = Math.min(...data, 0)
    const range = max - min || 1
    const points = data.map((value, index) => {
      const x = (index / Math.max(data.length - 1, 1)) * width
      const y = height - ((value - min) / range) * height
      return `${x},${y}`
    }).join(' ')
    return `<svg class="company-page__sparkline" width="100%" height="${height}" viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" role="none" role="img" aria-label="12 month hiring velocity"><polyline fill="none" stroke="var(--accent-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="${points}"></polyline></svg>`
  }

  function renderMetrics(company) {
      if (!metricsEl) return
      metricsEl.innerHTML = `
        <div class="metric-card metric-card--primary"><header class="metric-card__header"><span class="metric-card__label">Tier</span></header><div class="metric-card__body"><span class="metric-card__value hermes-mono" data-mono="true">${company.tier}</span></div></div>
        <div class="metric-card"><header class="metric-card__header"><span class="metric-card__label">Employees</span></header><div class="metric-card__body"><span class="metric-card__value hermes-mono" data-mono="true">${company.employees}</span></div></div>
        <div class="metric-card metric-card--primary"><header class="metric-card__header"><span class="metric-card__label">Avg Salary</span></header><div class="metric-card__body"><span class="metric-card__value hermes-mono" data-mono="true">${Number(company.avgSalary).toLocaleString('en-DK')}</span><span class="metric-card__unit hermes-mono" data-mono="true">DKK/mo</span></div></div>
        <div class="metric-card"><header class="metric-card__header"><span class="metric-card__label">Open Roles</span></header><div class="metric-card__body"><span class="metric-card__value hermes-mono" data-mono="true">${company.openRoles}</span></div></div>
      `
    }

  function renderTable(postings) {
    if (!tableBody) return
    tableBody.innerHTML = postings.map((p) => `
      <tr>
        <td>${p.role}</td>
        <td>${p.seniority}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true">${p.salaryLabel}</td>
        <td>${p.yourSkills}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true"><StatusPill label={p.gapLabel} variant={gapVariant(p.gap)} class="hermes-mono" data-mono="true" /></td>
        <td class="hermes-mono data-table__td--right" data-mono="true"><StatusPill label={String(p.fitScore)} variant={fitVariant(p.fitScore)} class="hermes-mono" data-mono="true" /></td>
        <td><StatusPill label={p.action} variant={actionVariant(p.action)} class="hermes-mono" data-mono="true" /></td>
      </tr>
    `).join('')
    if (countEl) countEl.textContent = String(postings.length)
  }

  async function loadCompany() {
    try {
      const response = await fetch(`/api/market/company/${slug}`, { cache: 'no-store' })
      if (!response.ok) throw new Error(`HTTP ${response.status}`)
      const data = await response.json()
      const company = data.company
      document.getElementById('company-name').textContent = company.name
      document.getElementById('company-location').textContent = company.location || data.profile?.location || ''
      renderMetrics(company)
      if (velocityEl) velocityEl.innerHTML = sparklineSvg(company.hiringVelocity || [])
      renderTable(data.postings || [])

      // Update CompanyFit component
      if (fitComponent && company.fit) {
        fitComponent.setAttribute('company', JSON.stringify(company.fit))
        fitComponent.setAttribute('visible', 'true')
        fitComponent.hidden = false
      }

      loadingEl?.setAttribute('hidden', '')
      errorEl?.setAttribute('hidden', '')
      contentEl?.removeAttribute('hidden')
    } catch (error) {
      loadingEl?.setAttribute('hidden', '')
      contentEl?.setAttribute('hidden', '')
      errorEl?.removeAttribute('hidden')
      const msg = errorEl?.querySelector('.error-state__message')
      if (msg) msg.textContent = error instanceof Error ? error.message : 'Could not fetch company profile.'
    }
  }

  document.querySelector('#company-error [data-retry]')?.addEventListener('click', loadCompany)
  loadCompany()
</script>

<style>
  .company-page {
    display: flex
    flex-direction: column
    gap: var(--space-5)
  }

  .company-page__hero {
    display: flex
    flex-direction: column
    gap: var(--space-1)
  }

  .company-page__title {
    margin: 0
    font-size: var(--text-2xl)
    font-weight: 700
    font-family: var(--font-display)
    color: var(--text-primary)
  }

  .company-page__location {
    margin: 0
    font-size: var(--text-sm)
    color: var(--text-secondary)
  }

  .company-page__toolbar {
    display: flex
    flex-wrap: wrap
    align-items: center
    gap: var(--space-3)
    padding-bottom: var(--space-3)
    border-bottom: var(--border-width) solid var(--border-default)
  }

  .company-page__metrics {
    display: grid
    grid-template-columns: repeat(4, minmax(0, 1fr))
    gap: var(--space-3)
  }

  .company-page__metrics :global(.metric-card) {
    background: var(--bg-card)
    border: var(--border-width) solid var(--border-default)
    box-shadow: var(--shadow-md)
    padding: var(--space-4)
    display: flex
    flex-direction: column
    gap: var(--space-2)
  }

  .company-page__metrics :global(.metric-card--primary) {
    border-left: var(--border-width-thick) solid var(--accent-primary)
  }

  .company-page__metrics :global(.metric-card__label) {
    font-size: var(--text-sm)
    color: var(--text-secondary)
  }

  .company-page__metrics :global(.metric-card__value) {
    font-size: var(--text-2xl)
    font-weight: 700
    color: var(--text-primary)
  }

  .company-page__metrics :global(.metric-card__unit) {
    font-size: var(--text-sm)
    color: var(--text-muted)
  }

  @media (max-width: 1024px) {
    .company-page__metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr))
    }
  }

  @media (max-width: 768px) {
    .company-page__metrics {
      grid-template-columns: 1fr
    }
  }

  .company-page__content {
    display: flex
    flex-direction: column
    gap: var(--space-5)
  }

  .company-page__state {
    display: flex
    justify-content: center
    padding: var(--space-10)
  }

  .company-page__velocity {
    background: var(--bg-card)
    border: var(--border-width) solid var(--border-default)
    box-shadow: var(--shadow-md)
    padding: var(--space-4)
  }

  .company-page__fit {
    background: var(--bg-card)
    border: var(--border-width) solid var(--border-default)
    box-shadow: var(--shadow-md)
    padding: var(--space-4)
  }

  .company-page__postings {
    background: var(--bg-card)
    border: var(--border-width) solid var(--border-default)
    box-shadow: var(--shadow-md)
    padding: var(--space-4)
  }

  .company-page__section-header {
    display: flex
    align-items: baseline
    justify-content: space-between
    gap: var(--space-3)
    margin-bottom: var(--space-4)
    padding-bottom: var(--space-3)
    border-bottom: var(--border-width) solid var(--border-default)
  }

  .company-page__section-title {
    margin: 0
    font-size: var(--text-lg)
    font-weight: 600
    color: var(--text-primary)
  }

  .company-page__section-meta {
    font-size: var(--text-sm)
    color: var(--text-muted)
  }

  .company-page__sparkline-wrap {
    padding: var(--space-2) 0
  }

  .company-page__sparkline {
    display: block
  }

  .data-table-panel__scroll {
    overflow-x: auto
  }

  .data-table {
    width: 100%
    border-collapse: collapse
    font-size: var(--text-sm)
  }

  .data-table thead th {
    text-align: left
    font-weight: 600
    font-size: var(--text-xs)
    text-transform: uppercase
    letter-spacing: var(--letter-spacing-tight)
    color: var(--text-muted)
    padding: var(--space-3) var(--space-4)
    border-bottom: var(--border-width) solid var(--border-default)
    background: var(--bg-card)
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4)
    border-bottom: var(--border-width) solid var(--border-default)
  }

  .data-table tbody tr:hover td {
    background: var(--bg-tertiary)
  }

  .status-pill {
    display: inline-flex
    align-items: center
    padding: var(--space-1) var(--space-2)
    font-size: var(--text-xs)
    font-weight: 500
    border: var(--border-width) solid var(--border-default)
    border-radius: var(--radius-sm)
    background: var(--bg-card)
    white-space: nowrap
  }

  .status-pill--success {
    color: var(--grade-high)
    border-color: var(--grade-high-border)
    background: var(--grade-high-bg)
  }

  .status-pill--warning {
    color: var(--grade-mid)
    border-color: var(--grade-mid-border)
    background: var(--grade-mid-bg)
  }

  .status-pill--error {
    color: var(--grade-low)
    border-color: var(--grade-low-border)
    background: var(--grade-low-bg)
  }

  .status-pill--warm {
    color: var(--grade-mid)
    border-color: var(--grade-mid-border)
    background: var(--grade-mid-bg)
  }

  .status-pill--default {
    color: var(--text-secondary)
  }
</style>