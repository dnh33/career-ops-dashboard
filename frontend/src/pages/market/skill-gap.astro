---
import PageLayout from '../../components/layout/PageLayout.astro';
import SkillGapRadar from '../../components/market/SkillGapRadar.astro';
---

<PageLayout
  title="Skill Gap Radar"
  pageTitle="Skill Gap Radar"
  description="Visualize your skill gaps against market targets with the signature Radar Sweep."
  currentPath="/market/skill-gap"
>
  <div slot="hero" class="skill-gap-page__hero">
    <h1 class="skill-gap-page__title">Skill Gap Radar</h1>
    <p class="skill-gap-page__subtitle">Visualize your skill gaps against market targets with the signature Radar Sweep.</p>
  </div>

  <section class="skill-gap-page__content">
    <SkillGapRadar id="skill-gap-radar" />
  </section>
</PageLayout>