---
import HermesLayout from '../../layouts/HermesLayout.astro';
import SegmentedControl from '../../components/primitives/SegmentedControl.astro';
import Loader from '../../components/primitives/Loader.astro';
import ErrorState from '../../components/primitives/ErrorState.astro';

const viewOptions = [
  { id: 'radar', label: 'Radar', icon: 'graph' },
  { id: 'table', label: 'Table', icon: 'list-unordered' },
];
---

<HermesLayout
  title="Skill Gap Radar"
  pageTitle="Skill Gap Analysis"
  description="Market demand vs your profile coverage across 20 core skills."
  currentPath="/market/skill-gap"
>
  <section class="skill-gap-page">
    <div class="skill-gap-page__toolbar">
      <SegmentedControl
        options={viewOptions}
        value="radar"
        name="skill-gap-view"
        ariaLabel="View mode"
        class="skill-gap-page__view-toggle"
      />
    </div>

    <div id="skill-gap-loading" class="skill-gap-page__state">
      <Loader label="Loading skill gap data" size="lg" />
    </div>

    <div id="skill-gap-error" class="skill-gap-page__state" hidden>
      <ErrorState title="Skill gap data unavailable" message="Could not fetch skill gap analysis." />
    </div>

    <div id="skill-gap-radar-view" class="skill-gap-page__panel" hidden>
      <header class="skill-gap-page__panel-header">
        <h2 class="skill-gap-page__panel-title">Market Demand vs Your Coverage</h2>
        <div class="skill-gap-page__legend">
          <span class="skill-gap-page__legend-item"><span class="skill-gap-page__swatch skill-gap-page__swatch--demand"></span>Market demand</span>
          <span class="skill-gap-page__legend-item"><span class="skill-gap-page__swatch skill-gap-page__swatch--coverage"></span>Your coverage</span>
          <span class="skill-gap-page__legend-item"><span class="skill-gap-page__swatch skill-gap-page__swatch--gap"></span>Gap delta</span>
        </div>
      </header>
      <div class="skill-gap-page__radar-wrap">
        <svg id="skill-gap-radar" viewBox="0 0 520 520" role="img" aria-label="Skill gap radar chart"></svg>
        <div id="skill-gap-tooltip" class="skill-gap-page__tooltip" hidden></div>
      </div>
    </div>

    <div id="skill-gap-table-view" class="skill-gap-page__panel" hidden>
      <header class="skill-gap-page__panel-header">
        <h2 class="skill-gap-page__panel-title">Gap Breakdown</h2>
      </header>
      <div class="data-table-panel">
        <div class="data-table-panel__scroll">
          <table class="data-table" aria-label="Skill gap breakdown">
            <thead>
              <tr>
                <th scope="col" data-sort-key="skill">Skill</th>
                <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="demand" data-mono="true">Demand%</th>
                <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="your" data-mono="true">Your%</th>
                <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="gap" data-mono="true">Gap</th>
                <th scope="col" data-sort-key="trend">Trend</th>
              </tr>
            </thead>
            <tbody id="skill-gap-table-body"></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</HermesLayout>

<script>
  let radarData = [];
  let skillRows = [];
  let activeView = 'radar';
  let sortKey = 'gap';
  let sortDir = 'desc';

  const loadingEl = document.getElementById('skill-gap-loading');
  const errorEl = document.getElementById('skill-gap-error');
  const radarView = document.getElementById('skill-gap-radar-view');
  const tableView = document.getElementById('skill-gap-table-view');
  const radarSvg = document.getElementById('skill-gap-radar');
  const tooltip = document.getElementById('skill-gap-tooltip');
  const tableBody = document.getElementById('skill-gap-table-body');
  const viewToggle = document.querySelector('.skill-gap-page__view-toggle');

  function gapVariant(gap) {
    if (gap > 20) return 'warm';
    if (gap >= 10) return 'warning';
    return 'success';
  }

  function trendLabel(trend) {
    if (trend === 'up') return '↑ Rising';
    if (trend === 'down') return '↓ Falling';
    return '→ Flat';
  }

  function showView(view) {
    activeView = view;
    radarView?.toggleAttribute('hidden', view !== 'radar');
    tableView?.toggleAttribute('hidden', view !== 'table');
  }

  function renderTable() {
    if (!tableBody) return;
    const sorted = [...skillRows].sort((a, b) => {
      const map = { skill: 'skill', demand: 'demandPct', your: 'yourPct', gap: 'gap', trend: 'trend' };
      const field = map[sortKey] || 'gap';
      const av = a[field];
      const bv = b[field];
      if (typeof av === 'number' && typeof bv === 'number') {
        return sortDir === 'asc' ? av - bv : bv - av;
      }
      return sortDir === 'asc' ? String(av).localeCompare(String(bv)) : String(bv).localeCompare(String(av));
    });

    tableBody.innerHTML = sorted.map((row) => `
      <tr>
        <td>${row.skill}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true">${row.demandPct.toFixed(1)}%</td>
        <td class="hermes-mono data-table__td--right" data-mono="true">${row.yourPct}%</td>
        <td class="hermes-mono data-table__td--right" data-mono="true"><span class="status-pill status-pill--${gapVariant(row.gap)} hermes-mono" data-mono="true">${row.gap}%</span></td>
        <td class="hermes-mono" data-mono="true">${trendLabel(row.trend)}</td>
      </tr>
    `).join('');
  }

  function polar(cx, cy, radius, index, total) {
    const angle = (Math.PI * 2 * index) / total - Math.PI / 2;
    return [cx + radius * Math.cos(angle), cy + radius * Math.sin(angle)];
  }

  function polygonPoints(values, cx, cy, maxRadius, total) {
    return values.map((value, index) => {
      const radius = (value / 100) * maxRadius;
      const [x, y] = polar(cx, cy, radius, index, total);
      return `${x},${y}`;
    }).join(' ');
  }

  function renderRadar() {
    if (!radarSvg || !radarData.length) return;
    const cx = 260;
    const cy = 260;
    const maxR = 190;
    const total = radarData.length;
    const rings = [0.25, 0.5, 0.75, 1];

    let svg = '';
    rings.forEach((scale) => {
      const ringPoints = Array.from({ length: total }, (_, i) => {
        const [x, y] = polar(cx, cy, maxR * scale, i, total);
        return `${x},${y}`;
      }).join(' ');
      svg += `<polygon points="${ringPoints}" fill="none" stroke="var(--stroke-hairline)" stroke-width="1"></polygon>`;
    });

    for (let i = 0; i < total; i += 1) {
      const [x, y] = polar(cx, cy, maxR, i, total);
      svg += `<line x1="${cx}" y1="${cy}" x2="${x}" y2="${y}" stroke="var(--stroke-hairline)" stroke-width="1"></line>`;
    }

    const demandValues = radarData.map((d) => d.demand);
    const coverageValues = radarData.map((d) => d.coverage);
    const gapValues = radarData.map((d) => Math.min(d.gap * 2.5, 100));

    svg += `<polygon points="${polygonPoints(demandValues, cx, cy, maxR, total)}" fill="var(--color-primary)" fill-opacity="0.15" stroke="var(--color-primary)" stroke-opacity="0.35" stroke-width="1"></polygon>`;
    svg += `<polygon points="${polygonPoints(coverageValues, cx, cy, maxR, total)}" fill="var(--color-primary)" fill-opacity="0.35" stroke="var(--color-primary)" stroke-width="1.5"></polygon>`;
    svg += `<polygon points="${polygonPoints(gapValues, cx, cy, maxR * 0.55, total)}" fill="var(--color-warm)" fill-opacity="0.25" stroke="none"></polygon>`;

    radarData.forEach((point, index) => {
      const [lx, ly] = polar(cx, cy, maxR + 24, index, total);
      const anchor = lx >= cx ? 'start' : 'end';
      svg += `<text x="${lx}" y="${ly}" text-anchor="${anchor}" dominant-baseline="middle" class="skill-gap-page__axis-label" data-index="${index}">${point.skill}</text>`;
    });

    radarSvg.innerHTML = svg;

    radarSvg.querySelectorAll('.skill-gap-page__axis-label').forEach((label) => {
      label.addEventListener('mouseenter', (event) => {
        const index = Number(label.getAttribute('data-index'));
        const point = radarData[index];
        if (!tooltip || !point) return;
        tooltip.innerHTML = `<strong>${point.skill}</strong><span class="hermes-mono" data-mono="true">Demand ${point.demand}% · Your ${point.coverage}% · Gap ${point.gap}%</span>`;
        tooltip.removeAttribute('hidden');
        tooltip.style.left = `${event.clientX + 12}px`;
        tooltip.style.top = `${event.clientY + 12}px`;
      });
      label.addEventListener('mousemove', (event) => {
        if (!tooltip) return;
        tooltip.style.left = `${event.clientX + 12}px`;
        tooltip.style.top = `${event.clientY + 12}px`;
      });
      label.addEventListener('mouseleave', () => tooltip?.setAttribute('hidden', ''));
    });
  }

  async function loadSkillGap() {
    try {
      const response = await fetch('/api/market/skill-gap', { cache: 'no-store' });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      radarData = data.radarData || [];
      skillRows = data.skills || [];
      loadingEl?.setAttribute('hidden', '');
      errorEl?.setAttribute('hidden', '');
      showView(activeView);
      renderRadar();
      renderTable();
    } catch (error) {
      loadingEl?.setAttribute('hidden', '');
      radarView?.setAttribute('hidden', '');
      tableView?.setAttribute('hidden', '');
      errorEl?.removeAttribute('hidden');
      const msg = errorEl?.querySelector('.error-state__message');
      if (msg) msg.textContent = error instanceof Error ? error.message : 'Could not fetch skill gap analysis.';
    }
  }

  viewToggle?.addEventListener('change', (event) => {
    const value = event.detail?.value || 'radar';
    showView(value);
  });

  document.querySelectorAll('#skill-gap-table-view [data-sort-key]').forEach((header) => {
    header.addEventListener('click', () => {
      const key = header.getAttribute('data-sort-key');
      if (!key) return;
      if (sortKey === key) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
      else {
        sortKey = key;
        sortDir = key === 'gap' || key === 'demand' ? 'desc' : 'asc';
      }
      renderTable();
    });
  });

  document.querySelector('#skill-gap-error [data-retry]')?.addEventListener('click', loadSkillGap);
  loadSkillGap();
</script>

<style>
  .skill-gap-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .skill-gap-page__toolbar {
    display: flex;
    justify-content: flex-end;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--stroke-hairline);
  }

  .skill-gap-page__state {
    display: flex;
    justify-content: center;
    padding: var(--space-10);
  }

  .skill-gap-page__panel {
    background: var(--bg-card);
    border: 1px solid var(--stroke-hairline);
    box-shadow: var(--shadow-nous);
    padding: var(--space-4);
  }

  .skill-gap-page__panel-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--stroke-hairline);
  }

  .skill-gap-page__panel-title {
    margin: 0;
    font-size: var(--text-lg);
  }

  .skill-gap-page__legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }

  .skill-gap-page__legend-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .skill-gap-page__swatch {
    width: 0.75rem;
    height: 0.75rem;
    border: 1px solid var(--stroke-hairline);
  }

  .skill-gap-page__swatch--demand {
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .skill-gap-page__swatch--coverage {
    background: color-mix(in srgb, var(--color-primary) 35%, transparent);
  }

  .skill-gap-page__swatch--gap {
    background: color-mix(in srgb, var(--color-warm) 25%, transparent);
  }

  .skill-gap-page__radar-wrap {
    position: relative;
    display: flex;
    justify-content: center;
    padding: var(--space-4);
  }

  #skill-gap-radar {
    width: min(100%, 32rem);
    height: auto;
  }

  :global(.skill-gap-page__axis-label) {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    fill: var(--text-tertiary);
    cursor: default;
  }

  .skill-gap-page__tooltip {
    position: fixed;
    z-index: var(--z-tooltip);
    padding: var(--space-2) var(--space-3);
    background: var(--bg-elevated);
    border: 1px solid var(--stroke-nous);
    box-shadow: var(--shadow-nous);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    transition: opacity var(--transition-base);
  }

  .skill-gap-page__tooltip strong {
    color: var(--text-primary);
    font-family: var(--font-ui);
  }

  .data-table-panel__scroll {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table thead th {
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--stroke-hairline);
    background: var(--bg-panel);
    cursor: pointer;
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right;
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--stroke-hairline);
  }

  .data-table tbody tr:hover td {
    background: var(--bg-hover);
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    border: 1px solid var(--stroke-hairline);
    border-radius: var(--radius-sm);
    background: var(--bg-panel);
  }

  .status-pill--success {
    color: var(--ui-success);
    border-color: color-mix(in srgb, var(--ui-success) 30%, transparent);
    background: var(--tag-success-bg);
  }

  .status-pill--warning {
    color: var(--ui-warning);
    border-color: color-mix(in srgb, var(--ui-warning) 30%, transparent);
    background: var(--tag-warning-bg);
  }

  .status-pill--warm {
    color: var(--color-warm);
    border-color: color-mix(in srgb, var(--color-warm) 30%, transparent);
    background: color-mix(in srgb, var(--color-warm) 10%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-gap-page__tooltip {
      transition: none;
    }
  }
</style>
