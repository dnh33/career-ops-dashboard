---
import PageLayout from '../../components/layout/PageLayout.astro';
import SegmentedControl from '../../components/primitives/SegmentedControl.astro';
import Loader from '../../components/primitives/Loader.astro';
import ErrorState from '../../components/primitives/ErrorState.astro';

const roleOptions = [
  { id: 'frontend', label: 'Frontend' },
  { id: 'ai-engineer', label: 'AI Engineer' },
  { id: 'fullstack', label: 'Fullstack' },
  { id: 'all', label: 'All' },
];
---
<PageLayout
  title="CV Optimization"
  pageTitle="CV Optimization Rules"
  description="Market-fit scoring and gap rules — apply diffs to align your CV with Danish tech hiring signals."
  currentPath="/cv/optimize"
>
  <section class="cv-optimize">
    <div class="cv-optimize__metrics" id="cv-optimize-metrics">
      <Loader label="Loading scores" size="sm" />
    </div>

    <div class="cv-optimize__toolbar">
      <SegmentedControl
        options={roleOptions}
        value="all"
        name="cv-optimize-role"
        ariaLabel="Target role filter"
        class="cv-optimize__role"
      />
    </div>

    <div id="cv-optimize-loading" class="cv-optimize__state">
      <Loader label="Loading optimization rules" size="lg" />
    </div>

    <div id="cv-optimize-error" class="cv-optimize__state" hidden>
      <ErrorState title="Optimization data unavailable" message="Could not fetch CV optimization rules." />
    </div>

    <section id="cv-optimize-content" class="cv-optimize__table-section" aria-label="Optimization rules" hidden>
      <header class="cv-optimize__section-header">
        <h2 class="cv-optimize__section-title">Gap Rules</h2>
        <span class="cv-optimize__count hermes-mono" data-mono="true" id="cv-optimize-row-count">0</span>
      </header>
      <div class="data-table-panel">
        <div class="data-table-panel__scroll">
          <table class="data-table" id="cv-optimize-table" aria-label="CV optimization rules">
            <thead>
              <tr>
                <th scope="col" data-sort-key="rule">Rule</th>
                <th scope="col" data-sort-key="category">Category</th>
                <th scope="col" data-sort-key="currentCv">Current CV</th>
                <th scope="col" data-sort-key="target">Target</th>
                <th scope="col" class="data-table__td--right hermes-mono" data-sort-key="gap" data-mono="true">Gap</th>
                <th scope="col" data-sort-key="priority">Priority</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody id="cv-optimize-table-body"></tbody>
          </table>
        </div>
      </div>
    </section>
  </section>

  <div id="cv-diff-overlay" class="cv-optimize__overlay-backdrop" hidden role="presentation">
    <div class="cv-optimize__overlay" role="dialog" aria-modal="true" aria-labelledby="cv-diff-title">
      <header class="cv-optimize__overlay-header">
        <h2 class="cv-optimize__overlay-title" id="cv-diff-title">Apply Rule</h2>
        <button type="button" class="cv-optimize__overlay-close" id="cv-diff-close" aria-label="Close">
          <i class="codicon codicon-close" aria-hidden="true"></i>
        </button>
      </header>
      <div class="cv-optimize__overlay-body">
        <div class="cv-optimize__diff">
          <div class="cv-optimize__diff-col">
            <span class="cv-optimize__diff-label">Before</span>
            <pre class="cv-optimize__diff-code hermes-mono" data-mono="true" id="cv-diff-before"></pre>
          </div>
          <div class="cv-optimize__diff-col">
            <span class="cv-optimize__diff-label">After</span>
            <pre class="cv-optimize__diff-code cv-optimize__diff-code--after hermes-mono" data-mono="true" id="cv-diff-after"></pre>
          </div>
        </div>
      </div>
      <footer class="cv-optimize__overlay-footer">
        <button type="button" class="cv-optimize__apply-btn" id="cv-diff-apply">Apply to CV Builder</button>
      </footer>
    </div>
  </div>
</PageLayout>

<script>
  let allRules = [];
  let activeRole = 'all';
  let activeRule = null;
  let sortKey = 'gap';
  let sortDir = 'desc';

  const metricsEl = document.getElementById('cv-optimize-metrics');
  const loadingEl = document.getElementById('cv-optimize-loading');
  const errorEl = document.getElementById('cv-optimize-error');
  const contentEl = document.getElementById('cv-optimize-content');
  const tbody = document.getElementById('cv-optimize-table-body');
  const countEl = document.getElementById('cv-optimize-row-count');
  const roleControl = document.querySelector('.cv-optimize__role');
  const table = document.getElementById('cv-optimize-table');
  const overlay = document.getElementById('cv-diff-overlay');

  function scoreVariant(score, invert = false) {
    const effective = invert ? 100 - score : score;
    if (effective >= 80) return 'primary';
    if (effective >= 60) return 'default';
    if (effective >= 40) return 'warning';
    return 'warm';
  }

  function renderMetrics(data) {
    if (!metricsEl) return;
    metricsEl.innerHTML = `
      <article class="metric-card metric-card--${scoreVariant(data.overallScore)}">
        <header class="metric-card__header"><span class="metric-card__label">Market Fit</span></header>
        <div class="metric-card__body">
          <span class="metric-card__value hermes-mono" data-mono="true">${data.overallScore}</span>
          <span class="metric-card__unit hermes-mono" data-mono="true">/100</span>
        </div>
      </article>
      <article class="metric-card metric-card--${scoreVariant(data.keywordCoverage)}">
        <header class="metric-card__header"><span class="metric-card__label">Keyword Coverage</span></header>
        <div class="metric-card__body">
          <span class="metric-card__value hermes-mono" data-mono="true">${data.keywordCoverage}</span>
          <span class="metric-card__unit hermes-mono" data-mono="true">%</span>
        </div>
      </article>
      <article class="metric-card metric-card--${data.criticalGaps >= 3 ? 'warm' : data.criticalGaps >= 1 ? 'warning' : 'success'}">
        <header class="metric-card__header"><span class="metric-card__label">Gap Count</span></header>
        <div class="metric-card__body">
          <span class="metric-card__value hermes-mono" data-mono="true">${data.criticalGaps}</span>
          <span class="metric-card__unit hermes-mono" data-mono="true">critical</span>
        </div>
      </article>
      <article class="metric-card metric-card--primary">
        <header class="metric-card__header"><span class="metric-card__label">Role Match</span></header>
        <div class="metric-card__body">
          <span class="metric-card__value hermes-mono" data-mono="true">${data.roleMatches}</span>
          <span class="metric-card__unit hermes-mono" data-mono="true">roles ≥70</span>
        </div>
      </article>
    `;
  }

  function sortRules(items) {
    const keyMap = { rule: 'rule', category: 'category', currentCv: 'currentCv', target: 'target', gap: 'gap', priority: 'priority' };
    const priorityOrder = { Critical: 4, High: 3, Medium: 2, Low: 1 };
    const field = keyMap[sortKey] || 'gap';
    return [...items].sort((a, b) => {
      if (field === 'priority') {
        const av = priorityOrder[a.priority] || 0;
        const bv = priorityOrder[b.priority] || 0;
        return sortDir === 'asc' ? av - bv : bv - av;
      }
      const av = a[field];
      const bv = b[field];
      if (typeof av === 'number' && typeof bv === 'number') {
        return sortDir === 'asc' ? av - bv : bv - av;
      }
      return sortDir === 'asc' ? String(av).localeCompare(String(bv)) : String(bv).localeCompare(String(av));
    });
  }

  function renderTable() {
    if (!tbody) return;
    const items = sortRules(allRules);
    tbody.innerHTML = items.map((rule) => `
      <tr>
        <td>${rule.rule}</td>
        <td>${rule.category}</td>
        <td class="cv-optimize__truncate">${rule.currentCv}</td>
        <td class="cv-optimize__truncate">${rule.target}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true">${rule.gapLabel}</td>
        <td><span class="status-pill status-pill--${rule.priorityVariant} hermes-mono" data-mono="true">${rule.priority}</span></td>
        <td><button type="button" class="cv-optimize__apply-btn" data-rule-id="${rule.id}">Apply</button></td>
      </tr>
    `).join('');
    if (countEl) countEl.textContent = String(items.length);

    tbody.querySelectorAll('[data-rule-id]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const rule = allRules.find((r) => r.id === btn.getAttribute('data-rule-id'));
        if (rule) openDiff(rule);
      });
    });
  }

  function openDiff(rule) {
    activeRule = rule;
    document.getElementById('cv-diff-title').textContent = rule.rule;
    document.getElementById('cv-diff-before').textContent = rule.before;
    document.getElementById('cv-diff-after').textContent = rule.after;
    overlay?.removeAttribute('hidden');
  }

  function closeDiff() {
    overlay?.setAttribute('hidden', '');
    activeRule = null;
  }

  document.getElementById('cv-diff-close')?.addEventListener('click', closeDiff);
  overlay?.addEventListener('click', (event) => {
    if (event.target?.id === 'cv-diff-overlay') closeDiff();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeDiff();
  });

  document.getElementById('cv-diff-apply')?.addEventListener('click', () => {
    if (!activeRule) return;
    window.location.href = '/cv/builder';
  });

  async function loadOptimize(role = 'all') {
    activeRole = role;
    loadingEl?.removeAttribute('hidden');
    contentEl?.setAttribute('hidden', '');
    try {
      const response = await fetch(`/api/cv/optimize?role=${encodeURIComponent(role)}`, { cache: 'no-store' });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      allRules = data.rules || [];
      renderMetrics(data);
      loadingEl?.setAttribute('hidden', '');
      errorEl?.setAttribute('hidden', '');
      contentEl?.removeAttribute('hidden');
      renderTable();
    } catch (error) {
      loadingEl?.setAttribute('hidden', '');
      contentEl?.setAttribute('hidden', '');
      errorEl?.removeAttribute('hidden');
      const msg = errorEl?.querySelector('.error-state__message');
      if (msg) msg.textContent = error instanceof Error ? error.message : 'Could not fetch optimization rules.';
    }
  }

  roleControl?.addEventListener('change', (event) => {
    loadOptimize(event.detail?.value || 'all');
  });

  table?.querySelectorAll('[data-sort-key]').forEach((header) => {
    header.addEventListener('click', () => {
      const key = header.getAttribute('data-sort-key');
      if (!key) return;
      if (sortKey === key) {
        sortDir = sortDir === 'asc' ? 'desc' : 'asc';
      } else {
        sortKey = key;
        sortDir = key === 'gap' || key === 'priority' ? 'desc' : 'asc';
      }
      renderTable();
    });
    header.setAttribute('tabindex', '0');
    header.setAttribute('role', 'button');
    header.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        header.click();
      }
    });
  });

  document.querySelector('#cv-optimize-error [data-retry]')?.addEventListener('click', () => loadOptimize(activeRole));
  loadOptimize('all');
</script>

<style>
  .cv-optimize {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .cv-optimize__metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .cv-optimize__metrics :global(.metric-card) {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cv-optimize__metrics :global(.metric-card--primary) {
    border-left: var(--border-width-thick) solid var(--accent-primary);
  }

  .cv-optimize__metrics :global(.metric-card--warm) {
    border-left: var(--border-width-thick) solid var(--grade-low);
  }

  .cv-optimize__metrics :global(.metric-card--warning) {
    border-left: var(--border-width-thick) solid var(--grade-mid);
  }

  .cv-optimize__metrics :global(.metric-card--success) {
    border-left: var(--border-width-thick) solid var(--grade-high);
  }

  .cv-optimize__metrics :global(.metric-card__label) {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .cv-optimize__metrics :global(.metric-card__value) {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
  }

  .cv-optimize__metrics :global(.metric-card__unit) {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .cv-optimize__metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .cv-optimize__metrics {
      grid-template-columns: 1fr;
    }
  }

  .cv-optimize__toolbar {
    display: flex;
    justify-content: flex-start;
    padding-bottom: var(--space-3);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .cv-optimize__state {
    display: flex;
    justify-content: center;
    padding: var(--space-10);
  }

  .cv-optimize__table-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cv-optimize__section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .cv-optimize__section-title {
    margin: 0;
    font-size: var(--text-lg);
  }

  .cv-optimize__count {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .data-table-panel {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .data-table-panel__scroll {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table thead th {
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-muted);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    background: var(--bg-card);
    white-space: nowrap;
    cursor: pointer;
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right;
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    color: var(--text-primary);
  }

  .data-table tbody tr:hover td {
    background: var(--bg-tertiary);
  }

  .cv-optimize__truncate {
    max-width: var(--size-40);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    white-space: nowrap;
  }

  .status-pill--warm {
    color: var(--grade-low);
    border-color: var(--grade-low-border);
    background: var(--grade-low-bg);
  }

  .status-pill--error {
    color: var(--grade-low);
    border-color: var(--grade-low-border);
    background: var(--grade-low-bg);
  }

  .status-pill--warning {
    color: var(--grade-mid);
    border-color: var(--grade-mid-border);
    background: var(--grade-mid-bg);
  }

  .status-pill--default {
    color: var(--text-secondary);
  }

  .cv-optimize__apply-btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    border: var(--border-width) solid var(--accent-primary);
    background: var(--accent-subtle);
    color: var(--accent-primary);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    min-height: var(--size-8);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-base);
  }

  .cv-optimize__apply-btn:hover {
    background: var(--accent-primary);
    color: var(--text-inverse);
  }

  .cv-optimize__overlay-backdrop {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    background: color-mix(in srgb, var(--bg-surface) 55%, transparent);
  }

  .cv-optimize__overlay {
    width: 100%;
    max-width: var(--size-160);
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    max-height: 90vh;
    overflow: auto;
  }

  .cv-optimize__overlay-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .cv-optimize__overlay-title {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
  }

  .cv-optimize__overlay-close {
    background: transparent;
    border: none;
    font-size: var(--text-lg);
    line-height: 1;
    color: var(--text-muted);
    cursor: pointer;
    padding: var(--space-1);
  }

  .cv-optimize__overlay-close:hover {
    color: var(--text-primary);
  }

  .cv-optimize__diff {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4);
  }

  .cv-optimize__diff-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cv-optimize__diff-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-muted);
  }

  .cv-optimize__diff-code {
    flex: 1;
    min-height: var(--size-40);
    background: var(--bg-input);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-2-5);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    overflow: auto;
  }

  .cv-optimize__diff-code--after {
    background: var(--bg-success);
    color: var(--text-inverse);
  }

  .cv-optimize__apply-btn {
    width: 100%;
    padding: var(--space-3);
    font-size: var(--text-sm);
    font-weight: 600;
  }
</style>