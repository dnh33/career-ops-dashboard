---
import PageLayout from '../../components/layout/PageLayout.astro';
import SegmentedControl from '../../components/primitives/SegmentedControl.astro';
import SearchField from '../../components/primitives/SearchField.astro';
import Loader from '../../components/primitives/Loader.astro';
import EmptyState from '../../components/primitives/EmptyState.astro';
import StatusPill from '../../components/primitives/StatusPill.astro';
import CodeBlock from '../../components/ui/CodeBlock.astro';
---

<PageLayout
  title="CV Builder"
  pageTitle="CV Builder"
  description="Build and maintain your master CV — progressive disclosure, live preview, and market-fit scoring."
  currentPath="/cv/builder"
>
  <section class="cv-builder">
    <!-- STEPS PANEL (left sidebar) -->
    <aside class="cv-builder__steps" aria-label="CV sections">
      <nav class="cv-builder__nav">
        <h2 class="cv-builder__panel-title">Sections</h2>
        <ul id="cv-builder-steps" class="cv-builder__step-list" role="list" aria-label="CV section steps">
          <!-- populated by JS -->
        </ul>
      </nav>
    </aside>

    <!-- WORKSPACE (center) -->
    <main class="cv-builder__workspace" role="main">
      <header class="cv-builder__toolbar">
        <div class="cv-builder__search-wrapper">
          <SearchField
            id="cv-builder-search"
            name="cv-builder-search"
            placeholder="Search fields, skills, roles…"
            ariaLabel="Search CV content"
            class="cv-builder__search"
          />
        </div>
        <div class="cv-builder__toolbar-actions">
          <button type="button" id="cv-builder-import" class="cv-builder__btn" data-action="cv-import">Import</button>
          <button type="button" id="cv-builder-export" class="cv-builder__btn cv-builder__btn--strong" data-action="cv-export">Export PDF</button>
        </div>
      </header>

      <div id="cv-builder-loading" class="cv-builder__loader" hidden>
        <Loader label="Loading CV data" size="lg" />
      </div>

      <div id="cv-builder-error" class="cv-builder__error" hidden>
        <EmptyState
          title="CV data unavailable"
          description="Could not load your CV. Check the API or create a new profile."
          icon="alert-circle"
          actionLabel="Retry"
          actionHref="#"
        />
      </div>

      <form id="cv-builder-form" class="cv-builder__form" hidden novalidate>
        <section class="cv-builder__panel" id="cv-panel-basics" aria-labelledby="cv-panel-basics-heading">
          <header class="cv-builder__panel-header">
            <h3 id="cv-panel-basics-heading" class="cv-builder__panel-title">Basics</h3>
          </header>
          <div class="cv-builder__fields">
            <div class="cv-builder__field">
              <label for="cv-full-name">Full name</label>
              <input type="text" id="cv-full-name" name="fullName" autocomplete="name" required />
            </div>
            <div class="cv-builder__field">
              <label for="cv-headline">Professional headline</label>
              <input type="text" id="cv-headline" name="headline" placeholder="Senior Frontend Engineer · AI/ML" />
            </div>
            <div class="cv-builder__field cv-builder__field--full">
              <label for="cv-summary">Summary</label>
              <textarea id="cv-summary" name="summary" rows="3" placeholder="3–5 lines: scope, stack, impact, what you're targeting"></textarea>
            </div>
            <div class="cv-builder__field">
              <label for="cv-email">Email</label>
              <input type="email" id="cv-email" name="email" autocomplete="email" />
            </div>
            <div class="cv-builder__field">
              <label for="cv-phone">Phone</label>
              <input type="tel" id="cv-phone" name="phone" autocomplete="tel" />
            </div>
            <div class="cv-builder__field">
              <label for="cv-location">Location</label>
              <input type="text" id="cv-location" name="location" placeholder="Copenhagen, DK" />
            </div>
            <div class="cv-builder__field cv-builder__field--full">
              <label for="cv-links">Links (one per line)</label>
              <textarea id="cv-links" name="links" rows="3" placeholder="https://linkedin.com/in/…\nhttps://github.com/…\nhttps://portfolio.dev"></textarea>
            </div>
          </div>
        </section>

        <section class="cv-builder__panel" id="cv-panel-experience" aria-labelledby="cv-panel-experience-heading">
          <header class="cv-builder__panel-header">
            <h3 id="cv-panel-experience-heading" class="cv-builder__panel-title">Experience</h3>
            <button type="button" class="cv-builder__btn" data-action="add-experience">+ Add role</button>
          </header>
          <div id="cv-experience-list" class="cv-builder__entries"></div>
        </section>

        <section class="cv-builder__panel" id="cv-panel-education" aria-labelledby="cv-panel-education-heading">
          <header class="cv-builder__panel-header">
            <h3 id="cv-panel-education-heading" class="cv-builder__panel-title">Education</h3>
            <button type="button" class="cv-builder__btn" data-action="add-education">+ Add degree</button>
          </header>
          <div id="cv-education-list" class="cv-builder__entries"></div>
        </section>

        <section class="cv-builder__panel" id="cv-panel-skills" aria-labelledby="cv-panel-skills-heading">
          <header class="cv-builder__panel-header">
            <h3 id="cv-panel-skills-heading" class="cv-builder__panel-title">Skills</h3>
            <button type="button" class="cv-builder__btn" data-action="add-skill">+ Add skill</button>
          </header>
          <div id="cv-skills-list" class="cv-builder__tags"></div>
        </section>

        <section class="cv-builder__panel" id="cv-panel-projects" aria-labelledby="cv-panel-projects-heading">
          <header class="cv-builder__panel-header">
            <h3 id="cv-panel-projects-heading" class="cv-builder__panel-title">Projects</h3>
            <button type="button" class="cv-builder__btn" data-action="add-project">+ Add project</button>
          </header>
          <div id="cv-projects-list" class="cv-builder__entries"></div>
        </section>

        <footer class="cv-builder__export">
          <button type="submit" class="cv-builder__btn cv-builder__btn--strong">Save CV</button>
          <button type="button" id="cv-builder-preview-toggle" class="cv-builder__btn" data-action="toggle-preview">Preview</button>
        </footer>
      </form>
    </main>

    <!-- PREVIEW PANEL (right, desktop only) -->
    <aside class="cv-builder__preview" id="cv-builder-preview" aria-label="Live preview">
      <header class="cv-builder__preview-header">
        <span class="cv-builder__preview-label">Live preview</span>
      </header>
      <div class="cv-builder__preview-doc" id="cv-builder-preview-doc">
        <div class="cv-builder__preview-placeholder">
          <p>Fill in the form to see a live preview.</p>
        </div>
      </div>
    </aside>
  </section>

  <!-- Overlay for editing entries -->
  <div class="cv-builder__overlay-backdrop" id="cv-builder-overlay" hidden role="presentation">
    <div class="cv-builder__overlay" role="dialog" aria-modal="true" aria-labelledby="cv-builder-overlay-title">
      <header class="cv-builder__overlay-header">
        <h3 class="cv-builder__overlay-title" id="cv-builder-overlay-title">Edit entry</h3>
        <button type="button" class="cv-builder__overlay-close" id="cv-builder-overlay-close" aria-label="Close">
          <i class="codicon codicon-close" aria-hidden="true"></i>
        </button>
      </header>
      <div class="cv-builder__overlay-body" id="cv-builder-overlay-body"></div>
      <footer class="cv-builder__overlay-footer">
        <button type="button" class="cv-builder__btn" id="cv-builder-overlay-cancel">Cancel</button>
        <button type="button" class="cv-builder__btn cv-builder__btn--strong" id="cv-builder-overlay-save">Save</button>
      </footer>
    </div>
  </div>
</PageLayout>

<script>
  // ===== CV Builder — full module script =====
  interface CVEntry {
    id: string;
    type: 'experience' | 'education' | 'skill' | 'project';
    data: Record<string, string>;
  }

  let cvData: {
    basics: Record<string, string>;
    experience: CVEntry[];
    education: CVEntry[];
    skills: CVEntry[];
    projects: CVEntry[];
  } = {
    basics: {},
    experience: [],
    education: [],
    skills: [],
    projects: [],
  };

  let activeEditId: string | null = null;
  let activeEditType: string | null = null;

  // ===== Element refs =====
  const stepsNav = document.getElementById('cv-builder-steps')!;
  const loadingEl = document.getElementById('cv-builder-loading')!;
  const errorEl = document.getElementById('cv-builder-error')!;
  const formEl = document.getElementById('cv-builder-form') as HTMLFormElement;
  const previewDoc = document.getElementById('cv-builder-preview-doc')!;
  const previewToggle = document.getElementById('cv-builder-preview-toggle') as HTMLButtonElement;
  const overlay = document.getElementById('cv-builder-overlay') as HTMLDivElement;
  const overlayBody = document.getElementById('cv-builder-overlay-body')!;
  const overlayTitle = document.getElementById('cv-builder-overlay-title')!;
  const overlayCancel = document.getElementById('cv-builder-overlay-cancel')!;
  const overlaySave = document.getElementById('cv-builder-overlay-save')!;
  const overlayClose = document.getElementById('cv-builder-overlay-close')!;

  // Experience/education/projects lists
  const expList = document.getElementById('cv-experience-list')!;
  const eduList = document.getElementById('cv-education-list')!;
  const skillList = document.getElementById('cv-skills-list')!;
  const projList = document.getElementById('cv-projects-list')!;

  // ===== Field definitions for each section =====
  const EXP_FIELDS = [
    { name: 'company', label: 'Company', type: 'text', required: true },
    { name: 'role', label: 'Role', type: 'text', required: true },
    { name: 'start', label: 'Start date', type: 'month', required: true },
    { name: 'end', label: 'End date', type: 'month' },
    { name: 'current', label: 'Current', type: 'checkbox' },
    { name: 'description', label: 'Description', type: 'textarea', rows: 4 },
    { name: 'highlights', label: 'Highlights (one per line)', type: 'textarea', rows: 3 },
  ];

  const EDU_FIELDS = [
    { name: 'institution', label: 'Institution', type: 'text', required: true },
    { name: 'degree', label: 'Degree', type: 'text', required: true },
    { name: 'field', label: 'Field of study', type: 'text' },
    { name: 'start', label: 'Start', type: 'month' },
    { name: 'end', label: 'End', type: 'month' },
  ];

  const PROJ_FIELDS = [
    { name: 'name', label: 'Project name', type: 'text', required: true },
    { name: 'description', label: 'Description', type: 'textarea', rows: 3 },
    { name: 'tech', label: 'Tech stack', type: 'text', placeholder: 'TypeScript, React, Node.js' },
    { name: 'link', label: 'URL', type: 'url', placeholder: 'https://github.com/…' },
  ];

  // ===== Helpers =====
  function uid(): string {
    return Math.random().toString(36).substring(2, 10);
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&').replace(/</g, '<').replace(/>/g, '>').replace(/"/g, '"');
  }

  // ===== Load / Save =====
  async function loadCV(): Promise<void> {
    loadingEl.hidden = false;
    errorEl.hidden = true;
    formEl.hidden = true;
    try {
      const resp = await fetch('/api/cv');
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
      const data = await resp.json();
      cvData = data.cv || cvData;
      renderAll();
      loadingEl.hidden = true;
      formEl.hidden = false;
    } catch (e) {
      loadingEl.hidden = true;
      errorEl.hidden = false;
      console.error('CV load failed:', e);
    }
  }

  async function saveCV(): Promise<void> {
    const basics = Object.fromEntries(new FormData(formEl).entries());
    cvData.basics = basics;
    try {
      await fetch('/api/cv', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cv: cvData }),
      });
      // TODO: toast success
    } catch (e) {
      console.error('CV save failed:', e);
    }
  }

  // ===== Render =====
  function renderAll(): void {
    renderSteps();
    renderBasics();
    renderEntries('experience', expList, EXP_FIELDS);
    renderEntries('education', eduList, EDU_FIELDS);
    renderSkills();
    renderEntries('projects', projList, PROJ_FIELDS);
    renderPreview();
  }

  function renderSteps(): void {
    const sections = [
      { id: 'basics', label: 'Basics' },
      { id: 'experience', label: 'Experience', count: cvData.experience.length },
      { id: 'education', label: 'Education', count: cvData.education.length },
      { id: 'skills', label: 'Skills', count: cvData.skills.length },
      { id: 'projects', label: 'Projects', count: cvData.projects.length },
    ];
    stepsNav.innerHTML = sections.map(s => `
      <li>
        <a href="#cv-panel-${s.id}" class="cv-builder__step-link" data-panel="${s.id}">
          <span class="cv-builder__step-label">${s.label}</span>
          ${s.count !== undefined ? `<span class="cv-builder__step-count">${s.count}</span>` : ''}
        </a>
      </li>
    `).join('');
  }

  function renderBasics(): void {
    const fields = ['fullName', 'headline', 'summary', 'email', 'phone', 'location', 'links'];
    for (const field of fields) {
      const el = document.getElementById(`cv-${field}`) as HTMLInputElement | HTMLTextAreaElement;
      if (el) el.value = cvData.basics[field] || '';
    }
  }

  function renderEntries(type: keyof typeof cvData, container: HTMLElement, fields: any[]): void {
    const entries = cvData[type] as CVEntry[];
    if (entries.length === 0) {
      container.innerHTML = `<p class="cv-builder__empty">No ${type} yet. Click "Add" to create one.</p>`;
      return;
    }
    container.innerHTML = entries.map((entry, i) => `
      <article class="cv-builder__entry" data-id="${entry.id}" data-type="${type}" data-index="${i}">
        <header class="cv-builder__entry-header">
          <span class="cv-builder__entry-title">${getEntryTitle(entry)}</span>
          <div class="cv-builder__entry-actions">
            <button type="button" class="cv-builder__edit" data-action="edit" data-id="${entry.id}" data-type="${type}" aria-label="Edit ${getEntryTitle(entry)}">
              <i class="codicon codicon-edit" aria-hidden="true"></i>
            </button>
            <button type="button" class="cv-builder__remove" data-action="delete" data-id="${entry.id}" data-type="${type}" aria-label="Delete ${getEntryTitle(entry)}">
              <i class="codicon codicon-trash" aria-hidden="true"></i>
            </button>
          </div>
        </header>
      </article>
    `).join('');
  }

  function getEntryTitle(entry: CVEntry): string {
    if (entry.data.company) return `${entry.data.role} @ ${entry.data.company}`;
    if (entry.data.institution) return `${entry.data.degree}, ${entry.data.institution}`;
    if (entry.data.name) return entry.data.name;
    return entry.data.field || entry.data.skill || 'Untitled';
  }

  function renderSkills(): void {
    const skills = cvData.skills as CVEntry[];
    if (skills.length === 0) {
      skillList.innerHTML = '<p class="cv-builder__empty">No skills yet. Click "Add" to create one.</p>';
      return;
    }
    skillList.innerHTML = skills.map((skill) => `
      <span class="cv-builder__skill-tag" data-id="${skill.id}">
        ${escapeHtml(skill.data.skill || skill.data.name || 'Skill')}
        <button type="button" class="cv-builder__skill-remove" data-action="delete" data-id="${skill.id}" data-type="skills" aria-label="Remove skill">
          <i class="codicon codicon-close" aria-hidden="true"></i>
        </button>
      </span>
    `).join('');
  }

  // ===== Overlay for editing =====
  function openOverlay(type: string, entry: CVEntry | null): void {
    activeEditType = type;
    activeEditId = entry?.id || null;
    const fields = type === 'experience' ? EXP_FIELDS : type === 'education' ? EDU_FIELDS : PROJ_FIELDS;
    const isNew = !entry;

    overlayTitle.textContent = isNew ? `Add ${type.slice(0, -1)}` : `Edit ${getEntryTitle(entry!)}`;

    overlayBody.innerHTML = fields.map(f => `
      <div class="cv-builder__field">
        <label for="ov-${f.name}">${f.label}${f.required ? ' *' : ''}</label>
        ${f.type === 'textarea' ? `
          <textarea id="ov-${f.name}" name="${f.name}" rows="${f.rows || 3}" placeholder="${f.placeholder || ''}">${escapeHtml(entry?.data[f.name] || '')}</textarea>
        ` : f.type === 'checkbox' ? `
          <label class="cv-builder__checkbox">
            <input type="checkbox" id="ov-${f.name}" name="${f.name}" ${entry?.data[f.name] === 'true' ? 'checked' : ''} />
            <span>${f.label}</span>
          </label>
        ` : `
          <input type="${f.type}" id="ov-${f.name}" name="${f.name}" value="${escapeHtml(entry?.data[f.name] || '')}" placeholder="${f.placeholder || ''}" ${f.required ? 'required' : ''} />
        `}
      </div>
    `).join('');

    overlay.hidden = false;
    (overlayBody.querySelector('input, textarea') as HTMLElement)?.focus();
  }

  function closeOverlay(): void {
    overlay.hidden = true;
    activeEditId = null;
    activeEditType = null;
  }

  async function saveOverlay(): Promise<void> {
    if (!activeEditType) return;
    const formData = new FormData(overlayBody.querySelector('form') || overlayBody);
    const data: Record<string, string> = {};
    for (const [k, v] of formData.entries()) data[k] = v.toString();
    // Handle checkboxes not in formData
    overlayBody.querySelectorAll('input[type="checkbox"]').forEach(cb => {
      data[cb.name] = (cb as HTMLInputElement).checked ? 'true' : 'false';
    });

    const entries = cvData[activeEditType as keyof typeof cvData] as CVEntry[];
    if (activeEditId) {
      const idx = entries.findIndex(e => e.id === activeEditId);
      if (idx >= 0) entries[idx].data = data;
    } else {
      entries.push({ id: uid(), type: activeEditType as any, data });
    }

    closeOverlay();
    renderAll();
  }

  // ===== Preview =====
  function renderPreview(): void {
    const b = cvData.basics;
    const hasContent = Object.values(b).some(v => v && v.length > 0) ||
      cvData.experience.length > 0 || cvData.education.length > 0 || cvData.skills.length > 0 || cvData.projects.length > 0;

    if (!hasContent) {
      previewDoc.innerHTML = '<p class="cv-builder__preview-placeholder">Fill in the form to see a live preview.</p>';
      return;
    }

    previewDoc.innerHTML = `
      <header class="cv-builder__preview-name">${escapeHtml(b.fullName || 'Your Name')}</header>
      <p class="cv-builder__preview-target">${escapeHtml(b.headline || 'Target role')}</p>
      <p class="cv-builder__preview-contact">
        ${b.email ? `<a href="mailto:${escapeHtml(b.email)}">${escapeHtml(b.email)}</a>` : ''}
        ${b.phone ? ` · ${escapeHtml(b.phone)}` : ''}
        ${b.location ? ` · ${escapeHtml(b.location)}` : ''}
      </p>
      ${b.links ? `<p class="cv-builder__preview-links">${b.links.split('\n').filter(l => l.trim()).map(l => `<a href="${escapeHtml(l.trim())}" target="_blank" rel="noopener">${escapeHtml(l.trim())}</a>`).join(' · ')}</p>` : ''}

      ${b.summary ? `
        <h3>Summary</h3>
        <p>${escapeHtml(b.summary)}</p>
      ` : ''}

      ${cvData.experience.length > 0 ? `
        <h3>Experience</h3>
        ${cvData.experience.map(e => `
          <div class="cv-builder__preview-entry">
            <div class="cv-builder__preview-entry-head">
              <strong>${escapeHtml(e.data.role)}</strong>
              <span>${escapeHtml(e.data.company)}</span>
            </div>
            <p class="cv-builder__preview-meta">${formatDate(e.data.start)} – ${e.data.current ? 'Present' : formatDate(e.data.end)}</p>
            ${e.data.description ? `<p>${escapeHtml(e.data.description)}</p>` : ''}
            ${e.data.highlights ? `<ul>${e.data.highlights.split('\n').filter(h => h.trim()).map(h => `<li>${escapeHtml(h.trim())}</li>`).join('')}</ul>` : ''}
          </div>
        `).join('')}
      ` : ''}

      ${cvData.education.length > 0 ? `
        <h3>Education</h3>
        ${cvData.education.map(e => `
          <div class="cv-builder__preview-entry">
            <div class="cv-builder__preview-entry-head">
              <strong>${escapeHtml(e.data.degree)}</strong>
              <span>${escapeHtml(e.data.institution)}</span>
            </div>
            ${e.data.field ? `<p>${escapeHtml(e.data.field)}</p>` : ''}
            <p class="cv-builder__preview-meta">${formatDate(e.data.start)} – ${formatDate(e.data.end)}</p>
          </div>
        `).join('')}
      ` : ''}

      ${cvData.skills.length > 0 ? `
        <h3>Skills</h3>
        <div class="cv-builder__skills-cloud">
          ${cvData.skills.map(s => `<span class="cv-builder__skill-tag">${escapeHtml(s.data.skill || s.data.name)}</span>`).join('')}
        </div>
      ` : ''}

      ${cvData.projects.length > 0 ? `
        <h3>Projects</h3>
        ${cvData.projects.map(p => `
          <div class="cv-builder__preview-entry">
            <div class="cv-builder__preview-entry-head">
              <strong>${escapeHtml(p.data.name)}</strong>
              ${p.data.link ? `<a href="${escapeHtml(p.data.link)}" target="_blank" rel="noopener"><i class="codicon codicon-link-external" aria-hidden="true"></i></a>` : ''}
            </div>
            ${p.data.description ? `<p>${escapeHtml(p.data.description)}</p>` : ''}
            ${p.data.tech ? `<p class="cv-builder__preview-meta">${escapeHtml(p.data.tech)}</p>` : ''}
          </div>
        `).join('')}
      ` : ''}
    `;
  }

  function formatDate(d: string): string {
    if (!d) return '';
    const [y, m] = d.split('-');
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    return `${months[parseInt(m) - 1] || m} ${y}`;
  }

  // ===== Event delegation =====
  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;

    // Add buttons
    if (target.matches('[data-action="add-experience"]')) openOverlay('experience', null);
    if (target.matches('[data-action="add-education"]')) openOverlay('education', null);
    if (target.matches('[data-action="add-project"]')) openOverlay('projects', null);
    if (target.matches('[data-action="add-skill"]')) {
      const skill = prompt('Skill name:');
      if (skill) {
        cvData.skills.push({ id: uid(), type: 'skill', data: { skill } });
        renderAll();
      }
    }

    // Edit/Delete
    const editBtn = target.closest('[data-action="edit"]');
    if (editBtn) {
      const id = editBtn.getAttribute('data-id')!;
      const type = editBtn.getAttribute('data-type')!;
      const entries = cvData[type as keyof typeof cvData] as CVEntry[];
      const entry = entries.find(e => e.id === id);
      if (entry) openOverlay(type, entry);
    }

    const delBtn = target.closest('[data-action="delete"]');
    if (delBtn) {
      const id = delBtn.getAttribute('data-id')!;
      const type = delBtn.getAttribute('data-type')!;
      const entries = cvData[type as keyof typeof cvData] as CVEntry[];
      const idx = entries.findIndex(e => e.id === id);
      if (idx >= 0) {
        entries.splice(idx, 1);
        renderAll();
      }
    }

    // Overlay actions
    if (target.id === 'cv-builder-overlay-save' || target.id === 'cv-builder-overlay-cancel' || target.id === 'cv-builder-overlay-close') {
      if (target.id === 'cv-builder-overlay-save') saveOverlay();
      closeOverlay();
    }

    // Preview toggle
    if (target.id === 'cv-builder-preview-toggle') {
      const preview = document.getElementById('cv-builder-preview')!;
      preview.style.display = preview.style.display === 'none' ? 'flex' : 'none';
    }
  });

  // Form submit
  formEl.addEventListener('submit', (e) => {
    e.preventDefault();
    saveCV();
  });

  // Search (basic filter)
  const searchInput = document.getElementById('cv-builder-search') as HTMLInputElement;
  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase();
    document.querySelectorAll('.cv-builder__entry, .cv-builder__skill-tag').forEach(el => {
      const text = el.textContent?.toLowerCase() || '';
      (el as HTMLElement).style.display = text.includes(q) ? '' : 'none';
    });
  });

  // Init
  loadCV();
</script>

