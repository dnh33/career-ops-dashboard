---
import PageLayout from '../components/layout/PageLayout.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import MetricCard from '../components/primitives/MetricCard.astro';
import DataTable from '../components/primitives/DataTable.astro';
import EmptyState from '../components/primitives/EmptyState.astro';
import StatusPill from '../components/primitives/StatusPill.astro';
import Loader from '../components/primitives/Loader.astro';
import ErrorState from '../components/primitives/ErrorState.astro';
---

<PageLayout
  title="Tools"
  pageTitle="Tools"
  description="Utility tools for job search and market analysis."
  currentPath="/tools"
>
  <div slot="hero" class="tools-page__hero">
    <h1 class="tools-page__title">Tools</h1>
    <p class="tools-page__subtitle">Utility tools for job search and market analysis.</p>
  </div>

  <div slot="actions" class="tools-page__actions">
    <SearchField
      id="tools-search"
      name="tools-search"
      placeholder="Search tools..."
      class="tools-page__search"
    />
  </div>

  <section class="tools-page__table-section" aria-label="Available tools">
    <div class="data-table-panel">
      <div class="data-table-panel__scroll">
        <table class="data-table" id="tools-table" aria-label="Available tools">
          <thead>
            <tr>
              <th scope="col" data-sort-key="name" tabindex="0" role="button">Name</th>
              <th scope="col" data-sort-key="category" tabindex="0" role="button">Category</th>
              <th scope="col" data-sort-key="description" tabindex="0" role="button">Description</th>
              <th scope="col" class="data-table__th--right">Status</th>
              <th scope="col" class="data-table__th--right">Action</th>
            </tr>
          </thead>
          <tbody id="tools-table-body"></tbody>
        </table>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  interface Tool {
    id: string;
    name: string;
    category: string;
    description: string;
    status: 'active' | 'beta' | 'deprecated';
    actionUrl: string;
    actionLabel: string;
  }

  const tools: Tool[] = [
    {
      id: 'salary-calculator',
      name: 'Salary Calculator',
      category: 'Compensation',
      description: 'Calculate expected salary based on role, location, and experience',
      status: 'active',
      actionUrl: '/tools/salary-calculator',
      actionLabel: 'Open',
    },
    {
      id: 'skill-gap-analyzer',
      name: 'Skill Gap Analyzer',
      category: 'Analysis',
      description: 'Compare your skills against market demand',
      status: 'active',
      actionUrl: '/market/skill-gap',
      actionLabel: 'Open',
    },
    {
      id: 'cv-optimizer',
      name: 'CV Optimizer',
      category: 'Application',
      description: 'Optimize your CV for specific roles and ATS',
      status: 'beta',
      actionUrl: '/cv/optimize',
      actionLabel: 'Open',
    },
    {
      id: 'interview-prep',
      name: 'Interview Prep Generator',
      category: 'Preparation',
      description: 'Generate tailored interview questions for target roles',
      status: 'beta',
      actionUrl: '/tools/interview-prep',
      actionLabel: 'Open',
    },
    {
      id: 'company-research',
      name: 'Company Research',
      category: 'Research',
      description: 'Deep-dive company profiles with hiring signals',
      status: 'active',
      actionUrl: '/companies',
      actionLabel: 'Open',
    },
    {
      id: 'market-trends',
      name: 'Market Trends',
      category: 'Analysis',
      description: 'Track hiring velocity and skill demand over time',
      status: 'active',
      actionUrl: '/market',
      actionLabel: 'Open',
    },
  ];

  function statusVariant(status: string): 'high' | 'mid' | 'low' {
    return status === 'active' ? 'high' : status === 'beta' ? 'mid' : 'low';
  }

  function renderTools(filter = '') {
    const tbody = document.getElementById('tools-table-body');
    if (!tbody) return;

    const filtered = tools.filter(t =>
      t.name.toLowerCase().includes(filter.toLowerCase()) ||
      t.category.toLowerCase().includes(filter.toLowerCase()) ||
      t.description.toLowerCase().includes(filter.toLowerCase())
    );

    if (filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" class="empty-row">No tools match your search</td></tr>';
      return;
    }

    tbody.innerHTML = filtered.map(t => `
      <tr>
        <td>${t.name}</td>
        <td>${t.category}</td>
        <td style="color: var(--text-secondary); max-width: var(--max-width-card); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${t.description}</td>
        <td class="hermes-mono data-table__td--right">
          <span class="status-pill status-pill--${statusVariant(t.status)}">${t.status}</span>
        </td>
        <td class="hermes-mono data-table__td--right">
          <a href="${t.actionUrl}" class="data-table__link">${t.actionLabel}</a>
        </td>
      </tr>
    `).join('');
  }

  document.getElementById('tools-search')?.addEventListener('input', (e) => {
    const value = (e.target as HTMLInputElement).value;
    renderTools(value);
  });

  document.addEventListener('DOMContentLoaded', () => {
    renderTools();
  });
</script>

<style>
  .tools-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .tools-page__hero {
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .tools-page__title {
    margin: 0 0 var(--space-1);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .tools-page__subtitle {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .tools-page__actions {
    display: flex;
    justify-content: flex-end;
  }

  .tools-page__search {
    min-width: min(100%, var(--size-80));
    flex: 1;
  }

  .tools-page__table-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .data-table-panel {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .data-table-panel__scroll {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table thead th {
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-muted);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    background: var(--bg-card);
    white-space: nowrap;
    cursor: pointer;
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right;
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    color: var(--text-primary);
  }

  .data-table tbody tr:hover td {
    background: var(--bg-tertiary);
  }

  .data-table__link {
    color: var(--accent-primary);
    text-decoration: none;
    min-height: auto;
  }

  .data-table__link:hover {
    text-decoration: underline;
  }

  .empty-row {
    padding: var(--space-8);
    text-align: center;
    color: var(--text-muted);
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    white-space: nowrap;
  }

  .status-pill--high {
    color: var(--grade-high);
    border-color: var(--grade-high-border);
    background: var(--grade-high-bg);
  }

  .status-pill--mid {
    color: var(--grade-mid);
    border-color: var(--grade-mid-border);
    background: var(--grade-mid-bg);
  }

  .status-pill--low {
    color: var(--grade-low);
    border-color: var(--grade-low-border);
    background: var(--grade-low-bg);
  }

  @media (max-width: 1024px) {
    .tools-page__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>