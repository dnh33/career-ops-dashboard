---
import PageLayout from '../components/layout/PageLayout.astro';
import MetricCard from '../components/primitives/MetricCard.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import Loader from '../components/primitives/Loader.astro';
import EmptyState from '../components/primitives/EmptyState.astro';
import StatusPill from '../components/primitives/StatusPill.astro';

const quickActions = [
  { id: '/evaluate', label: 'Evaluate', icon: 'beaker' },
  { id: '/scan', label: 'Scan', icon: 'search' },
  { id: '/tracker', label: 'Tracker', icon: 'list-unordered' },
  { id: '/pipeline', label: 'Pipeline', icon: 'git-branch' },
];

const filterOptions = [
  { id: 'all', label: 'All' },
  { id: 'A', label: 'Grade A' },
  { id: 'B', label: 'Grade B' },
  { id: 'C', label: 'Grade C' },
  { id: 'D', label: 'Grade D' },
  { id: 'E', label: 'Grade E' },
  { id: 'F', label: 'Grade F' },
];
---

<PageLayout
  title="Career Ops Dashboard"
  pageTitle="Career Ops Dashboard"
  description="Evaluation pipeline, market signals, and application tracking — one terminal for the job search."
  currentPath="/"
>
  <div slot="hero" class="dashboard__hero">
    <h1 class="dashboard__headline">Career Ops</h1>
    <p class="dashboard__subheadline">Evaluation pipeline, market signals, and application tracking — one terminal for the job search.</p>
  </div>

  <div slot="actions" class="dashboard__actions-header">
    <SegmentedControl
      options={quickActions}
      value="/evaluate"
      name="quick-action"
      vertical
      ariaLabel="Quick actions"
      class="dashboard__quick-actions"
    />
  </div>

  <div slot="sidebar" class="dashboard__sidebar">
    <div class="dashboard__pipeline-status">
      <span class="dashboard__pipeline-label">Pipeline status</span>
      <span id="pipeline-status-pill"><StatusPill label="—" variant="neutral" /></span>
    </div>
  </div>

  <section class="dashboard__activity" aria-labelledby="activity-heading">
    <header class="dashboard__section-header">
      <h2 id="activity-heading" class="dashboard__section-title">Recent Activity</h2>
      <SearchField
        name="activity-filter"
        placeholder="Filter evaluations…"
        ariaLabel="Filter recent evaluations"
        class="dashboard__activity-search"
      />
    </header>

    <div id="activity-loading" class="dashboard__loader">
      <Loader label="Loading evaluations" />
    </div>

    <div id="activity-content" hidden>
      <div id="activity-table-host"></div>
    </div>

    <div id="activity-empty" hidden>
      <EmptyState
        title="No evaluations yet"
        description="Run your first job posting evaluation to populate this feed."
        icon="beaker"
        actionLabel="Evaluate posting"
        actionHref="/evaluate"
      />
    </div>
  </section>
</PageLayout>

<script>
  import { scoreToGrade } from '../utils/colors';

  /** @type {any[]} */
  let allReports: any[] = [];

  async function fetchJSON(path: string): Promise<any> {
    const res = await fetch(path);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
  }

  function relDate(d: string | null | undefined): string {
    if (!d) return '—';
    const diff = (Date.now() - new Date(d).getTime()) / 86400000;
    if (diff < 1) return 'Today';
    if (diff < 2) return 'Yesterday';
    if (diff < 7) return `${Math.floor(diff)}d ago`;
    return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function legitVariant(l: string): 'success' | 'error' | 'warning' | 'neutral' {
    const lc = l.toLowerCase();
    if (lc.includes('high') || lc.includes('legit')) return 'success';
    if (lc.includes('scam') || lc.includes('fake')) return 'error';
    return 'warning';
  }

  function updateMetrics(stats: any) {
    const cards = document.querySelectorAll('#dashboard-metrics .metric-card__value');
    if (cards[0]) cards[0].textContent = String(stats.total_applications ?? 0);
    if (cards[1]) cards[1].textContent = stats.avg_score != null ? stats.avg_score.toFixed(1) : '—';
    if (cards[2]) cards[2].textContent = String(stats.total_reports ?? 0);
    if (cards[3]) cards[3].textContent = String(stats.active_pipeline_count ?? 0);

    const pillWrap = document.getElementById('pipeline-status-pill');
    const pill = pillWrap?.querySelector('.status-pill');
    if (pill) {
      const count = stats.active_pipeline_count ?? 0;
      pill.textContent = count > 0 ? `${count} active` : 'empty';
      pill.className = `status-pill status-pill--${count > 0 ? 'high' : 'neutral'}`;
    }
  }

  function renderActivityTable(filter = '') {
    const host = document.getElementById('activity-table-host');
    const loading = document.getElementById('activity-loading');
    const content = document.getElementById('activity-content');
    const empty = document.getElementById('activity-empty');
    if (!host || !loading || !content || !empty) return;

    const query = filter.trim().toLowerCase();
    const filtered = allReports.filter((r) => {
      if (!query) return true;
      return (
        (r.company || '').toLowerCase().includes(query) ||
        (r.role || '').toLowerCase().includes(query) ||
        scoreToGrade(r.score).toLowerCase().includes(query)
      );
    }).slice(0, 10);

    loading.hidden = true;

    if (filtered.length === 0) {
      content.hidden = true;
      empty.hidden = false;
      return;
    }

    empty.hidden = true;
    content.hidden = false;

    host.innerHTML = `
      <div class="data-table-panel" data-component="data-table">
        <div class="data-table-panel__scroll">
          <table class="data-table" aria-label="Recent evaluations">
            <thead>
              <tr>
                <th scope="col" class="data-table__th--center">Score</th>
                <th scope="col">Company</th>
                <th scope="col">Role</th>
                <th scope="col" class="hermes-mono" data-mono="true">Date</th>
                <th scope="col">Legit</th>
              </tr>
            </thead>
            <tbody>
              ${filtered.map((r) => {
                const grade = scoreToGrade(r.score);
                const tier = ['A', 'B'].includes(grade) ? 'high' : grade === 'C' ? 'mid' : 'low';
                const legit = r.legitimacy ? r.legitimacy.split(' ')[0] : '—';
                const legitTier = r.legitimacy ? legitVariant(r.legitimacy) : 'neutral';
                return `<tr>
                  <td class="data-table__td--center">
                    <span class="status-pill status-pill--${tier} hermes-mono" data-mono="true">${grade}</span>
                  </td>
                  <td><a href="/report?id=${r.id}" class="data-table__link">${r.company || '—'}</a></td>
                  <td>${r.role || '—'}</td>
                  <td class="hermes-mono" data-mono="true">${relDate(r.date)}</td>
                  <td>${r.legitimacy ? `<span class="status-pill status-pill--${legitTier}">${legit}</span>` : '—'}</td>
                </tr>`;
              }).join('')}
            </tbody>
          </table>
        </div>
      </div>`;
  }

  async function loadDashboard() {
    try {
      const [stats, reportsData] = await Promise.all([
        fetchJSON('/api/stats'),
        fetchJSON('/api/reports?limit=100'),
      ]);
      allReports = reportsData.reports ?? [];
      updateMetrics(stats);
      renderActivityTable();
    } catch (e) {
      console.error('Dashboard load failed:', e);
      document.getElementById('activity-loading')!.hidden = true;
      document.getElementById('activity-empty')!.hidden = false;
    }
  }

  document.querySelector('.dashboard__activity-search input')?.addEventListener('input', (event) => {
    const value = (event.target as HTMLInputElement).value;
    renderActivityTable(value);
  });

  document.querySelector('.dashboard__quick-actions')?.addEventListener('change', (event) => {
    const detail = (event as CustomEvent<{ value: string }>).detail;
    if (detail?.value) window.location.href = detail.value;
  });

  loadDashboard();
</script>

<style>
  .dashboard {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .dashboard__hero {
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .dashboard__headline {
    margin: 0 0 var(--space-2);
    font-size: var(--text-3xl);
    letter-spacing: var(--letter-spacing-tighter);
  }

  .dashboard__subheadline {
    margin: 0;
    max-width: var(--size-160);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .dashboard__metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--size-44), 1fr));
    gap: var(--space-3);
  }

  .dashboard__grid {
    display: grid;
    grid-template-columns: 1fr var(--size-56);
    gap: var(--space-6);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .dashboard__grid {
      grid-template-columns: 1fr;
    }
  }

  .dashboard__section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .dashboard__section-title {
    margin: 0;
    font-size: var(--text-lg);
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--text-primary);
  }

  .dashboard__activity-filter {
    min-width: var(--size-48);
    max-width: var(--size-80);
    flex: 1;
  }

  .dashboard__loader {
    padding: var(--space-8);
    display: flex;
    justify-content: center;
  }

  .dashboard__actions {
    position: sticky;
    top: calc(var(--space-6) + var(--space-4));
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .dashboard__quick-actions {
    width: 100%;
  }

  .dashboard__pipeline-status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding-top: var(--space-3);
    border-top: var(--border-width) solid var(--border-default);
  }

  .dashboard__pipeline-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
  }
</style>