---
import PageLayout from '../components/layout/PageLayout.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import Loader from '../components/primitives/Loader.astro';
import ErrorState from '../components/primitives/ErrorState.astro';
import MetricCard from '../components/primitives/MetricCard.astro';

const tierFilters = [
  { id: 'all', label: 'All' },
  { id: '1', label: 'Tier 1' },
  { id: '2', label: 'Tier 2' },
  { id: '3', label: 'Tier 3' },
  { id: 'Watchlist', label: 'Watchlist' },
];
---

<PageLayout
  title="Company Targets"
  pageTitle="Company Targets"
  description="40 target companies across 4 tiers — salary bands, open roles, and skill signals from DK market research."
  currentPath="/companies"
>
  <div slot="hero" class="companies-page__hero">
    <h1 class="companies-page__title">Company Targets</h1>
    <p class="companies-page__subtitle">40 target companies across 4 tiers — salary bands, open roles, and skill signals from DK market research.</p>
  </div>

  <div slot="actions" class="companies-page__toolbar">
    <SearchField
      name="companies-search"
      placeholder="Filter companies..."
      ariaLabel="Filter companies"
      class="companies-page__search"
    />
    <SegmentedControl
      options={tierFilters}
      value="all"
      name="companies-tier"
      compact
      ariaLabel="Filter by tier"
      class="companies-page__tier"
    />
  </div>

  <div id="companies-loading" class="companies-page__state">
    <Loader label="Loading company targets" size="lg" />
  </div>

  <div id="companies-error" class="companies-page__state" hidden>
    <ErrorState title="Company data unavailable" message="Could not fetch company targets." />
  </div>

  <section id="companies-content" class="companies-page__table-section" aria-label="Company targets" hidden>
    <header class="companies-page__section-header">
      <h2 class="companies-page__section-title">Target Companies</h2>
      <span class="companies-page__count hermes-mono" data-mono="true" id="companies-row-count">0</span>
    </header>
    <div class="data-table-panel">
      <div class="data-table-panel__scroll">
        <table class="data-table" id="companies-table" aria-label="Company targets">
          <thead>
            <tr>
              <th scope="col" data-sort-key="name" tabindex="0" role="button">Company</th>
              <th scope="col" data-sort-key="tier" tabindex="0" role="button">Tier</th>
              <th scope="col" data-sort-key="location" tabindex="0" role="button">Location</th>
              <th scope="col" class="hermes-mono" data-sort-key="size" tabindex="0" role="button" data-mono="true">Size</th>
              <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="avgSalary" tabindex="0" role="button" data-mono="true">Avg Salary</th>
              <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="openRoles" tabindex="0" role="button" data-mono="true">Open Roles</th>
              <th scope="col" data-sort-key="skills" tabindex="0" role="button">Skills</th>
              <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="lastPosted" tabindex="0" role="button" data-mono="true">Last Posted</th>
            </tr>
          </thead>
          <tbody id="companies-table-body"></tbody>
        </table>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  let allCompanies = [];
  let sortKey = 'tier';
  let sortDir = 'asc';

  const metricsEl = document.getElementById('companies-metrics');
  const loadingEl = document.getElementById('companies-loading');
  const errorEl = document.getElementById('companies-error');
  const contentEl = document.getElementById('companies-content');
  const tbody = document.getElementById('companies-table-body');
  const countEl = document.getElementById('companies-row-count');
  const searchInput = document.querySelector('.companies-page__search input');
  const tierControl = document.querySelector('.companies-page__tier');
  const table = document.getElementById('companies-table');

  const TIER_VARIANT = {
    '1': 'primary',
    '2': 'info',
    '3': 'neutral',
    Watchlist: 'warning',
  };

  const TIER_LABEL = {
    '1': 'Tier 1',
    '2': 'Tier 2',
    '3': 'Tier 3',
    Watchlist: 'Watch',
  };

  function formatSalary(value) {
    if (value == null) return '—';
    return Number(value).toLocaleString('en-DK');
  }

  function sparklineSvg(data) {
    if (!data?.length) return '';
    const width = 120;
    const height = 28;
    const max = Math.max(...data, 1);
    const min = Math.min(...data, 0);
    const range = max - min || 1;
    const points = data.map((value, index) => {
      const x = (index / Math.max(data.length - 1, 1)) * width;
      const y = height - ((value - min) / range) * height;
      return `${x},${y}`;
    }).join(' ');
    return `<svg class="sparkline" width="${width}" height="${height}" viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" role="img" aria-hidden="true"><polyline fill="none" stroke="var(--accent-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="${points}"></polyline></svg>`;
  }

  function renderMetrics(summary) {
    if (!metricsEl || !summary) return;
    const tiers = [
      { key: 'tier1', label: 'Tier 1', variant: 'primary' },
      { key: 'tier2', label: 'Tier 2', variant: 'default' },
      { key: 'tier3', label: 'Tier 3', variant: 'default' },
      { key: 'watchlist', label: 'Watchlist', variant: 'warning' },
    ];
    metricsEl.innerHTML = tiers.map(({ key, label, variant }) => {
      const item = summary[key];
      const spark = [item.count, item.openRoles, item.avgSalary / 1000, item.count + 2, item.openRoles - 1, item.count, item.openRoles].map(Math.round);
      return `
        <MetricCard label="${label}" value="${item.count}" unit="cos" variant="${variant}" sparklineData=${JSON.stringify(spark)}>
          <span slot="trend" class="metric-card__trend hermes-mono" data-mono="true">${formatSalary(item.avgSalary)} DKK · ${item.openRoles} roles</span>
        </MetricCard>
      `;
    }).join('');
  }

  function getFiltered() {
    const query = (searchInput?.value || '').trim().toLowerCase();
    const tier = tierControl?.querySelector('.segmented-control__option--active')?.getAttribute('data-value') || 'all';
    return allCompanies.filter((company) => {
      const haystack = [company.name, company.location, company.skillsLabel, company.tier].join(' ').toLowerCase();
      const tierMatch = tier === 'all' || company.tier === tier;
      return tierMatch && (!query || haystack.includes(query));
    });
  }

  function sortCompanies(items) {
    const keyMap = {
      name: 'name',
      tier: 'tier',
      location: 'location',
      size: 'size',
      avgSalary: 'avgSalary',
      openRoles: 'openRoles',
      skills: 'skillsLabel',
      lastPosted: 'lastPostedDays',
    };
    const field = keyMap[sortKey] || 'tier';
    return [...items].sort((a, b) => {
      const av = a[field] ?? '';
      const bv = b[field] ?? '';
      if (typeof av === 'number' && typeof bv === 'number') {
        return sortDir === 'asc' ? av - bv : bv - av;
      }
      return sortDir === 'asc' ? String(av).localeCompare(String(bv)) : String(bv).localeCompare(String(av));
    });
  }

  function renderTable() {
    if (!tbody) return;
    const items = sortCompanies(getFiltered());
    tbody.innerHTML = items.map((company) => {
      const variant = TIER_VARIANT[company.tier] || 'default';
      const label = TIER_LABEL[company.tier] || company.tier;
      return `
        <tr data-slug="${company.slug}" tabindex="0" role="link" aria-label="View ${company.name}">
          <td>${company.name}</td>
          <td><span class="status-pill status-pill--${variant}">${label}</span></td>
          <td>${company.location}</td>
          <td class="hermes-mono" data-mono="true">${company.size}</td>
          <td class="hermes-mono data-table__td--right" data-mono="true">${formatSalary(company.avgSalary)}</td>
          <td class="hermes-mono data-table__td--right" data-mono="true">${company.openRoles}</td>
          <td class="companies-page__skills">${company.skillsLabel}</td>
          <td class="hermes-mono data-table__td--right" data-mono="true">${company.lastPosted}</td>
        </tr>
      `;
    }).join('');
    if (countEl) countEl.textContent = String(items.length);

    tbody.querySelectorAll('tr[data-slug]').forEach((row) => {
      const navigate = () => {
        const slug = row.getAttribute('data-slug');
        if (slug) window.location.href = `/market/company/${slug}`;
      };
      row.addEventListener('click', navigate);
      row.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          navigate();
        }
      });
    });
  }

  async function loadCompanies() {
    try {
      const response = await fetch('/api/companies', { cache: 'no-store' });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      allCompanies = data.companies || [];
      renderMetrics(data.tierSummary);
      loadingEl?.setAttribute('hidden', '');
      errorEl?.setAttribute('hidden', '');
      contentEl?.removeAttribute('hidden');
      renderTable();
    } catch (error) {
      loadingEl?.setAttribute('hidden', '');
      contentEl?.setAttribute('hidden', '');
      errorEl?.removeAttribute('hidden');
      const msg = errorEl?.querySelector('.error-state__message');
      if (msg) msg.textContent = error instanceof Error ? error.message : 'Could not fetch company targets.';
    }
  }

  searchInput?.addEventListener('input', renderTable);
  tierControl?.addEventListener('change', renderTable);

  table?.querySelectorAll('[data-sort-key]').forEach((header) => {
    header.addEventListener('click', () => {
      const key = header.getAttribute('data-sort-key');
      if (!key) return;
      if (sortKey === key) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
      else {
        sortKey = key;
        sortDir = ['avgSalary', 'openRoles', 'lastPosted'].includes(key) ? 'desc' : 'asc';
      }
      renderTable();
    });
    header.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        header.click();
      }
    });
  });

  document.querySelector('#companies-error [data-retry]')?.addEventListener('click', loadCompanies);
  loadCompanies();
</script>

<style>
  .companies-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .companies-page__hero {
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .companies-page__title {
    margin: 0 0 var(--space-1);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .companies-page__subtitle {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .companies-page__metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .companies-page__metrics :global(.metric-card) {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .companies-page__metrics :global(.metric-card--primary) {
    border-left: var(--border-width-thick) solid var(--accent-primary);
  }

  .companies-page__metrics :global(.metric-card--warning) {
    border-left: var(--border-width-thick) solid var(--grade-mid);
  }

  .companies-page__metrics :global(.metric-card__label) {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .companies-page__metrics :global(.metric-card__value) {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
  }

  .companies-page__metrics :global(.metric-card__unit),
  .companies-page__metrics :global(.metric-card__trend) {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .companies-page__metrics :global(.metric-card__trend) {
    margin-left: auto;
  }

  @media (max-width: 1024px) {
    .companies-page__metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .companies-page__metrics {
      grid-template-columns: 1fr;
    }
  }

  .companies-page__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .companies-page__search {
    flex: 1;
    min-width: min(100%, var(--size-80));
  }

  .companies-page__state {
    display: flex;
    justify-content: center;
    padding: var(--space-10);
  }

  .companies-page__table-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .companies-page__section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .companies-page__section-title {
    margin: 0;
    font-size: var(--text-lg);
  }

  .companies-page__count {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .data-table-panel {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .data-table-panel__scroll {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table thead th {
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-muted);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    background: var(--bg-card);
    white-space: nowrap;
    cursor: pointer;
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right;
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    color: var(--text-primary);
  }

  .data-table tbody tr {
    cursor: pointer;
    transition: background-color var(--transition-base);
  }

  .data-table tbody tr:hover td,
  .data-table tbody tr:focus-visible td {
    background: var(--bg-tertiary);
  }

  .companies-page__skills {
    max-width: var(--size-56);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    white-space: nowrap;
  }

  .status-pill--primary {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
    background: var(--accent-subtle);
  }

  .status-pill--info {
    color: var(--text-muted);
    border-color: var(--border-hover);
    background: var(--bg-tertiary);
  }

  .status-pill--neutral {
    color: var(--text-muted);
    border-color: var(--border-hover);
    background: var(--bg-surface);
  }

  .status-pill--warning {
    color: var(--grade-mid);
    border-color: var(--grade-mid-border);
    background: var(--grade-mid-bg);
  }

  @media (max-width: 1024px) {
    .companies-page__metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .companies-page__metrics {
      grid-template-columns: 1fr;
    }
  }
</style>