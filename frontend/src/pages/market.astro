---
import PageLayout from '../components/layout/PageLayout.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import Loader from '../components/primitives/Loader.astro';
import ErrorState from '../components/primitives/ErrorState.astro';
import MetricCard from '../components/primitives/MetricCard.astro';

const timeRanges = [
  { id: '30d', label: '30d' },
  { id: '90d', label: '90d' },
  { id: '6m', label: '6m' },
  { id: '1y', label: '1y' },
];
---

<PageLayout
  title="Market Overview"
  pageTitle="Market Intelligence"
  description="69 active postings across Danish tech — salary bands, skill demand, and gap signals."
  currentPath="/market"
>
  <div slot="hero" class="market-page__hero">
    <h1 class="market-page__title">Market Intelligence</h1>
    <p class="market-page__subtitle">69 active postings across Danish tech — salary bands, skill demand, and gap signals.</p>
  </div>

  <div slot="actions" class="market-page__toolbar">
    <SearchField
      name="market-search"
      placeholder="Filter companies, roles, locations, skills…"
      ariaLabel="Filter market postings"
      class="market-page__search"
    />
    <SegmentedControl
      options={timeRanges}
      value="90d"
      name="market-range"
      compact
      ariaLabel="Filter by time range"
      class="market-page__range"
    />
  </div>

  <div id="market-loading" class="market-page__state">
    <Loader label="Loading market overview" size="lg" />
  </div>

  <div id="market-error" class="market-page__state" hidden>
    <ErrorState title="Market data unavailable" message="Could not fetch market overview." />
  </div>

  <section id="market-content" class="market-page__table-section" aria-label="Market postings" hidden>
    <header class="market-page__section-header">
      <h2 class="market-page__section-title">Active Postings</h2>
      <span class="market-page__count hermes-mono" data-mono="true" id="market-row-count">0</span>
    </header>
    <div class="data-table-panel">
      <div class="data-table-panel__scroll">
        <table class="data-table" id="market-table" aria-label="Market postings">
          <thead>
            <tr>
              <th scope="col" data-sort-key="company" tabindex="0" role="button">Company</th>
              <th scope="col" data-sort-key="role" tabindex="0" role="button">Role</th>
              <th scope="col" data-sort-key="seniority" tabindex="0" role="button">Seniority</th>
              <th scope="col" data-sort-key="location" tabindex="0" role="button">Location</th>
              <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="salary" tabindex="0" role="button" data-mono="true">Salary</th>
              <th scope="col" data-sort-key="skills" tabindex="0" role="button">Skills</th>
              <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="posted" tabindex="0" role="button" data-mono="true">Posted</th>
              <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="gap" tabindex="0" role="button" data-mono="true">Gap</th>
            </tr>
          </thead>
          <tbody id="market-table-body"></tbody>
        </table>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const RANGE_DAYS = { '30d': 30, '90d': 90, '6m': 180, '1y': 365 };

  let allPostings = [];
  let sortKey = 'posted';
  let sortDir = 'desc';

  const loadingEl = document.getElementById('market-loading');
  const errorEl = document.getElementById('market-error');
  const contentEl = document.getElementById('market-content');
  const metricsEl = document.getElementById('market-metrics');
  const tbody = document.getElementById('market-table-body');
  const countEl = document.getElementById('market-row-count');
  const searchInput = document.querySelector('.market-page__search input');
  const rangeControl = document.querySelector('.market-page__range');
  const table = document.getElementById('market-table');

  function gapVariant(gap) {
    if (gap > 20) return 'warm';
    if (gap >= 10) return 'warning';
    return 'success';
  }

  function formatSalary(value) {
    if (value == null) return '—';
    return Number(value).toLocaleString('en-DK');
  }

  function sparklineSvg(data) {
    if (!data?.length) return '';
    const width = 120;
    const height = 28;
    const max = Math.max(...data, 1);
    const min = Math.min(...data, 0);
    const range = max - min || 1;
    const points = data.map((value, index) => {
      const x = (index / Math.max(data.length - 1, 1)) * width;
      const y = height - ((value - min) / range) * height;
      return `${x},${y}`;
    }).join(' ');
    return `<svg class="sparkline" width="${width}" height="${height}" viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" role="img" aria-hidden="true"><polyline fill="none" stroke="var(--accent-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="${points}"></polyline></svg>`;
  }

  function renderMetrics(metrics) {
    if (!metricsEl || !metrics) return;
    metricsEl.innerHTML = `
      <MetricCard label="Avg Salary" value="${formatSalary(metrics.avgSalary)}" unit="DKK/mo" sparklineData=${JSON.stringify(metrics.avgSalarySparkline || [])} />
      <MetricCard label="Top Skill" value="${metrics.topSkill}" sparklineData=${JSON.stringify(metrics.topSkillSparkline || [])} />
      <MetricCard label="Top City" value="${metrics.topCity}" sparklineData=${JSON.stringify(metrics.topCitySparkline || [])} />
      <MetricCard label="Velocity" value="${metrics.velocity}" unit="postings" variant="primary" sparklineData=${JSON.stringify(metrics.velocitySparkline || [])} />
    `;
  }

  function getFilteredPostings() {
    const query = (searchInput?.value || '').trim().toLowerCase();
    const range = rangeControl?.querySelector('.segmented-control__option--active')?.getAttribute('data-value') || '90d';
    const maxDays = RANGE_DAYS[range] ?? 90;

    return allPostings.filter((p) => {
      const haystack = [p.company, p.role, p.location, p.skillsLabel].join(' ').toLowerCase();
      return (!query || haystack.includes(query)) && p.postedDaysAgo <= maxDays;
    });
  }

  function sortPostings(items) {
    const keyMap = {
      company: 'company',
      role: 'role',
      seniority: 'seniority',
      location: 'location',
      salary: 'salary',
      skills: 'skillsLabel',
      posted: 'postedDaysAgo',
      gap: 'gap',
    };
    const field = keyMap[sortKey] || 'postedDaysAgo';
    return [...items].sort((a, b) => {
      const av = a[field] ?? '';
      const bv = b[field] ?? '';
      if (typeof av === 'number' && typeof bv === 'number') {
        return sortDir === 'asc' ? av - bv : bv - av;
      }
      return sortDir === 'asc' ? String(av).localeCompare(String(bv)) : String(bv).localeCompare(String(av));
    });
  }

  function renderTable() {
    if (!tbody) return;
    const items = sortPostings(getFilteredPostings());
    tbody.innerHTML = items.map((p) => `
      <tr>
        <td><a href="/market/company/${p.companySlug}" class="data-table__link">${p.company}</a></td>
        <td>${p.role}</td>
        <td>${p.seniority}</td>
        <td>${p.location}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true">${formatSalary(p.salary)}</td>
        <td>${p.skillsLabel}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true">${p.postedLabel}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true"><span class="status-pill status-pill--${gapVariant(p.gap)} hermes-mono" data-mono="true">${p.gapLabel}</span></td>
      </tr>
    `).join('');
    if (countEl) countEl.textContent = String(items.length);
  }

  async function loadMarket() {
    try {
      const response = await fetch('/api/market/overview', { cache: 'no-store' });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      allPostings = data.postings || [];
      renderMetrics(data.metrics);
      loadingEl?.setAttribute('hidden', '');
      errorEl?.setAttribute('hidden', '');
      contentEl?.removeAttribute('hidden');
      renderTable();
    } catch (error) {
      loadingEl?.setAttribute('hidden', '');
      contentEl?.setAttribute('hidden', '');
      errorEl?.removeAttribute('hidden');
      const msg = errorEl?.querySelector('.error-state__message');
      if (msg) msg.textContent = error instanceof Error ? error.message : 'Could not fetch market overview.';
    }
  }

  searchInput?.addEventListener('input', renderTable);
  rangeControl?.addEventListener('change', renderTable);

  table?.querySelectorAll('[data-sort-key]').forEach((header) => {
    header.addEventListener('click', () => {
      const key = header.getAttribute('data-sort-key');
      if (!key) return;
      if (sortKey === key) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
      else {
        sortKey = key;
        sortDir = key === 'posted' || key === 'gap' || key === 'salary' ? 'desc' : 'asc';
      }
      renderTable();
    });
    header.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        header.click();
      }
    });
  });

  document.querySelector('#market-error [data-retry]')?.addEventListener('click', loadMarket);
  loadMarket();
</script>

<style>
  .market-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .market-page__hero {
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .market-page__title {
    margin: 0 0 var(--space-1);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .market-page__subtitle {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .market-page__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .market-page__search {
    flex: 1;
    min-width: min(100%, var(--size-80));
  }

  .market-page__state {
    display: flex;
    justify-content: center;
    padding: var(--space-10);
  }

  .market-page__table-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .market-page__section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .market-page__section-title {
    margin: 0;
    font-size: var(--text-lg);
  }

  .market-page__count {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .data-table-panel {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .data-table-panel__scroll {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table thead th {
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-muted);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    background: var(--bg-card);
    white-space: nowrap;
    cursor: pointer;
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right;
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    color: var(--text-primary);
  }

  .data-table tbody tr:hover td {
    background: var(--bg-tertiary);
  }

  .data-table__link {
    color: var(--accent-primary);
    text-decoration: none;
    min-height: auto;
  }

  .data-table__link:hover {
    text-decoration: underline;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    white-space: nowrap;
  }

  .status-pill--success {
    color: var(--grade-high);
    border-color: var(--grade-high-border);
    background: var(--grade-high-bg);
  }

  .status-pill--warning {
    color: var(--grade-mid);
    border-color: var(--grade-mid-border);
    background: var(--grade-mid-bg);
  }

  .status-pill--warm {
    color: var(--grade-mid);
    border-color: var(--grade-mid-border);
    background: var(--grade-mid-bg);
  }

  @media (max-width: 1024px) {
    .market-page__metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .market-page__metrics {
      grid-template-columns: 1fr;
    }
  }
</style>