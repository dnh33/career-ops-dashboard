---
import HermesLayout from '../layouts/HermesLayout.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import Loader from '../components/primitives/Loader.astro';
import ErrorState from '../components/primitives/ErrorState.astro';

const timeRanges = [
  { id: '30d', label: '30d' },
  { id: '90d', label: '90d' },
  { id: '6m', label: '6m' },
  { id: '1y', label: '1y' },
];
---

<HermesLayout
  title="Market Overview"
  pageTitle="Market Intelligence"
  description="69 active postings across Danish tech — salary bands, skill demand, and gap signals."
  currentPath="/market"
>
  <section class="market-page">
    <div class="market-page__toolbar">
      <SearchField
        name="market-search"
        placeholder="Filter companies, roles, locations, skills…"
        ariaLabel="Filter market postings"
        class="market-page__search"
      />
      <SegmentedControl
        options={timeRanges}
        value="90d"
        name="market-range"
        compact
        ariaLabel="Time range"
        class="market-page__range"
      />
    </div>

    <div id="market-loading" class="market-page__loader-wrap">
      <Loader label="Loading market overview" size="lg" />
    </div>

    <div id="market-error" class="market-page__error" hidden>
      <ErrorState title="Market data unavailable" message="Could not fetch market overview." />
    </div>

    <div id="market-content" hidden>
      <div class="market-page__metrics" id="market-metrics"></div>

      <section class="market-page__table-section" aria-label="Market postings">
        <header class="market-page__section-header">
          <h2 class="market-page__section-title">Active Postings</h2>
          <span class="market-page__count hermes-mono" data-mono="true" id="market-row-count">0</span>
        </header>
        <div class="data-table-panel" id="market-table-panel">
          <div class="data-table-panel__scroll">
            <table class="data-table" id="market-table" aria-label="Market postings">
              <thead>
                <tr>
                  <th scope="col" data-sort-key="company" tabindex="0" role="button">Company</th>
                  <th scope="col" data-sort-key="role" tabindex="0" role="button">Role</th>
                  <th scope="col" data-sort-key="seniority" tabindex="0" role="button">Seniority</th>
                  <th scope="col" data-sort-key="location" tabindex="0" role="button">Location</th>
                  <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="salary" tabindex="0" role="button" data-mono="true">Salary</th>
                  <th scope="col" data-sort-key="skills" tabindex="0" role="button">Skills</th>
                  <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="posted" tabindex="0" role="button" data-mono="true">Posted</th>
                  <th scope="col" class="data-table__th--right hermes-mono" data-sort-key="gap" tabindex="0" role="button" data-mono="true">Gap</th>
                </tr>
              </thead>
              <tbody id="market-table-body"></tbody>
            </table>
          </div>
        </div>
      </section>
    </div>
  </section>
</HermesLayout>

<script>
  const RANGE_DAYS = { '30d': 30, '90d': 90, '6m': 180, '1y': 365 };

  let allPostings = [];
  let sortKey = 'posted';
  let sortDir = 'desc';

  const loadingEl = document.getElementById('market-loading');
  const errorEl = document.getElementById('market-error');
  const contentEl = document.getElementById('market-content');
  const metricsEl = document.getElementById('market-metrics');
  const tbody = document.getElementById('market-table-body');
  const countEl = document.getElementById('market-row-count');
  const searchInput = document.querySelector('.market-page__search input');
  const rangeControl = document.querySelector('.market-page__range');
  const table = document.getElementById('market-table');

  function gapVariant(gap) {
    if (gap > 20) return 'warm';
    if (gap >= 10) return 'warning';
    return 'success';
  }

  function formatSalary(value) {
    if (value == null) return '—';
    return Number(value).toLocaleString('en-DK');
  }

  function renderMetrics(metrics) {
    if (!metricsEl) return;
    metricsEl.innerHTML = `
      <article class="metric-card metric-card--primary">
        <header class="metric-card__header"><span class="metric-card__label">Avg Salary</span></header>
        <div class="metric-card__body">
          <span class="metric-card__value hermes-mono" data-mono="true">${formatSalary(metrics.avgSalary)}</span>
          <span class="metric-card__unit hermes-mono" data-mono="true">DKK/mo</span>
        </div>
        <footer class="metric-card__sparkline">${sparklineSvg(metrics.avgSalarySparkline)}</footer>
      </article>
      <article class="metric-card">
        <header class="metric-card__header"><span class="metric-card__label">Top Skill</span></header>
        <div class="metric-card__body">
          <span class="metric-card__value hermes-mono" data-mono="true">${metrics.topSkill}</span>
        </div>
        <footer class="metric-card__sparkline">${sparklineSvg(metrics.topSkillSparkline)}</footer>
      </article>
      <article class="metric-card">
        <header class="metric-card__header"><span class="metric-card__label">Top City</span></header>
        <div class="metric-card__body">
          <span class="metric-card__value hermes-mono" data-mono="true">${metrics.topCity}</span>
        </div>
        <footer class="metric-card__sparkline">${sparklineSvg(metrics.topCitySparkline)}</footer>
      </article>
      <article class="metric-card metric-card--primary">
        <header class="metric-card__header"><span class="metric-card__label">Velocity</span></header>
        <div class="metric-card__body">
          <span class="metric-card__value hermes-mono" data-mono="true">${metrics.velocity}</span>
          <span class="metric-card__unit hermes-mono" data-mono="true">postings</span>
          <span class="metric-card__trend metric-card__trend--up hermes-mono" data-mono="true">${metrics.postingCount} total</span>
        </div>
        <footer class="metric-card__sparkline">${sparklineSvg(metrics.velocitySparkline)}</footer>
      </article>
    `;
  }

  function sparklineSvg(data) {
    if (!data?.length) return '';
    const width = 120;
    const height = 28;
    const max = Math.max(...data, 1);
    const min = Math.min(...data, 0);
    const range = max - min || 1;
    const points = data.map((value, index) => {
      const x = (index / Math.max(data.length - 1, 1)) * width;
      const y = height - ((value - min) / range) * height;
      return `${x},${y}`;
    }).join(' ');
    return `<svg class="sparkline" width="${width}" height="${height}" viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" role="img" aria-hidden="true"><polyline fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="${points}"></polyline></svg>`;
  }

  function getFilteredPostings() {
    const query = (searchInput?.value || '').trim().toLowerCase();
    const range = rangeControl?.querySelector('.segmented-control__option--active')?.getAttribute('data-value') || '90d';
    const maxDays = RANGE_DAYS[range] ?? 90;

    return allPostings.filter((p) => {
      const haystack = [p.company, p.role, p.location, p.skillsLabel].join(' ').toLowerCase();
      return (!query || haystack.includes(query)) && p.postedDaysAgo <= maxDays;
    });
  }

  function sortPostings(items) {
    const keyMap = {
      company: 'company',
      role: 'role',
      seniority: 'seniority',
      location: 'location',
      salary: 'salary',
      skills: 'skillsLabel',
      posted: 'postedDaysAgo',
      gap: 'gap',
    };
    const field = keyMap[sortKey] || 'postedDaysAgo';
    return [...items].sort((a, b) => {
      const av = a[field] ?? '';
      const bv = b[field] ?? '';
      if (typeof av === 'number' && typeof bv === 'number') {
        return sortDir === 'asc' ? av - bv : bv - av;
      }
      return sortDir === 'asc'
        ? String(av).localeCompare(String(bv))
        : String(bv).localeCompare(String(av));
    });
  }

  function renderTable() {
    if (!tbody) return;
    const items = sortPostings(getFilteredPostings());
    tbody.innerHTML = items.map((p) => `
      <tr>
        <td><a href="/market/company/${p.companySlug}" class="data-table__link">${p.company}</a></td>
        <td>${p.role}</td>
        <td>${p.seniority}</td>
        <td>${p.location}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true">${formatSalary(p.salary)}</td>
        <td>${p.skillsLabel}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true">${p.postedLabel}</td>
        <td class="hermes-mono data-table__td--right" data-mono="true"><span class="status-pill status-pill--${gapVariant(p.gap)} hermes-mono" data-mono="true">${p.gapLabel}</span></td>
      </tr>
    `).join('');
    if (countEl) countEl.textContent = String(items.length);
  }

  async function loadMarket() {
    try {
      const response = await fetch('/api/market/overview', { cache: 'no-store' });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      allPostings = data.postings || [];
      renderMetrics(data.metrics);
      loadingEl?.setAttribute('hidden', '');
      errorEl?.setAttribute('hidden', '');
      contentEl?.removeAttribute('hidden');
      renderTable();
    } catch (error) {
      loadingEl?.setAttribute('hidden', '');
      contentEl?.setAttribute('hidden', '');
      errorEl?.removeAttribute('hidden');
      const msg = errorEl?.querySelector('.error-state__message');
      if (msg) msg.textContent = error instanceof Error ? error.message : 'Could not fetch market overview.';
    }
  }

  searchInput?.addEventListener('input', renderTable);
  rangeControl?.addEventListener('change', renderTable);

  table?.querySelectorAll('[data-sort-key]').forEach((header) => {
    header.addEventListener('click', () => {
      const key = header.getAttribute('data-sort-key');
      if (!key) return;
      if (sortKey === key) {
        sortDir = sortDir === 'asc' ? 'desc' : 'asc';
      } else {
        sortKey = key;
        sortDir = key === 'posted' || key === 'gap' || key === 'salary' ? 'desc' : 'asc';
      }
      renderTable();
    });
    header.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        header.click();
      }
    });
  });

  errorEl?.addEventListener('retry', loadMarket);
  document.querySelector('#market-error [data-retry]')?.addEventListener('click', loadMarket);

  loadMarket();
</script>

<style>
  .market-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .market-page__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--stroke-hairline);
  }

  .market-page__search {
    flex: 1;
    min-width: min(100%, 20rem);
  }

  .market-page__metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .market-page__metrics :global(.metric-card) {
    background: var(--bg-card);
    border: 1px solid var(--stroke-hairline);
    box-shadow: var(--shadow-nous);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .market-page__metrics :global(.metric-card--primary) {
    border-left: 3px solid var(--color-primary);
  }

  .market-page__metrics :global(.metric-card__label) {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .market-page__metrics :global(.metric-card__value) {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
  }

  .market-page__metrics :global(.metric-card__unit),
  .market-page__metrics :global(.metric-card__trend) {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }

  .market-page__metrics :global(.metric-card__trend--up) {
    color: var(--ui-success);
    margin-left: auto;
  }

  @media (max-width: 1024px) {
    .market-page__metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .market-page__metrics {
      grid-template-columns: 1fr;
    }
  }

  .market-page__table-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .market-page__section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .market-page__section-title {
    margin: 0;
    font-size: var(--text-lg);
  }

  .market-page__count {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }

  .market-page__loader-wrap,
  .market-page__error {
    padding: var(--space-10);
    display: flex;
    justify-content: center;
  }

  .data-table-panel {
    background: var(--bg-card);
    border: 1px solid var(--stroke-hairline);
    box-shadow: var(--shadow-nous);
  }

  .data-table-panel__scroll {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table thead th {
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--stroke-hairline);
    background: var(--bg-panel);
    white-space: nowrap;
    cursor: pointer;
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right;
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--stroke-hairline);
    color: var(--text-primary);
  }

  .data-table tbody tr:hover td {
    background: var(--bg-hover);
  }

  .data-table__link {
    color: var(--color-primary);
    text-decoration: none;
    min-height: auto;
  }

  .data-table__link:hover {
    text-decoration: underline;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    border: 1px solid var(--stroke-hairline);
    border-radius: var(--radius-sm);
    background: var(--bg-panel);
    white-space: nowrap;
  }

  .status-pill--success {
    color: var(--ui-success);
    border-color: color-mix(in srgb, var(--ui-success) 30%, transparent);
    background: var(--tag-success-bg);
  }

  .status-pill--warning {
    color: var(--ui-warning);
    border-color: color-mix(in srgb, var(--ui-warning) 30%, transparent);
    background: var(--tag-warning-bg);
  }

  .status-pill--warm {
    color: var(--color-warm);
    border-color: color-mix(in srgb, var(--color-warm) 30%, transparent);
    background: color-mix(in srgb, var(--color-warm) 10%, transparent);
  }
</style>
