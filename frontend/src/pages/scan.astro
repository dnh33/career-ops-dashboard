---
import PageLayout from '../components/layout/PageLayout.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import MetricCard from '../components/primitives/MetricCard.astro';
import DataTable from '../components/primitives/DataTable.astro';
import EmptyState from '../components/primitives/EmptyState.astro';
import StatusPill from '../components/primitives/StatusPill.astro';
import Loader from '../components/primitives/Loader.astro';
import ErrorState from '../components/primitives/ErrorState.astro';
import CodeBlock from '../components/primitives/CodeBlock.astro';
import Overlay from '../components/primitives/Overlay.astro';
---

<PageLayout
  title="Scan Job Boards"
  pageTitle="Job Board Scanner"
  description="Scan public ATS APIs for new job postings matching your criteria. Configure filters below and run a scan to discover opportunities."
  currentPath="/scan"
>
  <div slot="hero" class="scan-page__hero">
    <h1 class="scan-page__title">Job Board Scanner</h1>
    <p class="scan-page__subtitle">Scan public ATS APIs for new job postings matching your criteria. Configure filters below and run a scan to discover opportunities.</p>
  </div>

  <div slot="actions" class="scan-page__actions">
    <SearchField
      id="board-url"
      name="boardUrl"
      type="url"
      placeholder="https://careers.company.com/jobs"
      class="scan-page__url-input"
    />
    <SegmentedControl
      options={[{ id: 'all', label: 'All' }, { id: 'tech', label: 'Tech' }, { id: 'remote', label: 'Remote' }]}
      value="all"
      name="scan-filter"
      compact
      ariaLabel="Scan filter"
      class="scan-page__filter"
    />
  </div>

  <section class="scan-page__state">
    <Loader label="Loading scan data" size="lg" />
  </section>

  <section class="scan-page__table-section" aria-label="Scan results" hidden>
    <header class="scan-page__section-header">
      <h2 class="scan-page__section-title">Scan Results</h2>
      <span class="scan-page__count hermes-mono" data-mono="true" id="scan-row-count">0</span>
    </header>
    <div class="data-table-panel">
      <div class="data-table-panel__scroll">
        <table class="data-table" id="scan-table" aria-label="Scan results">
          <thead>
            <tr>
              <th scope="col" data-sort-key="title" tabindex="0" role="button">Title</th>
              <th scope="col" data-sort-key="company" tabindex="0" role="button">Company</th>
              <th scope="col" data-sort-key="location" tabindex="0" role="button">Location</th>
              <th scope="col" data-sort-key="score" tabindex="0" role="button">Score</th>
              <th scope="col" data-sort-key="date" tabindex="0" role="button">Date</th>
              <th scope="col" class="data-table__th--right">Actions</th>
            </tr>
          </thead>
          <tbody id="scan-table-body"></tbody>
        </table>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  interface ScanResult {
    id: string;
    title: string;
    company: string;
    location: string;
    score: number;
    date: string;
    url: string;
  }

  let allResults: ScanResult[] = [];
  let sortKey = 'date';
  let sortDir = 'desc';

  const loadingEl = document.getElementById('scan-loading');
  const errorEl = document.getElementById('scan-error');
  const contentEl = document.getElementById('scan-content');
  const tbody = document.getElementById('scan-table-body');
  const countEl = document.getElementById('scan-row-count');
  const searchInput = document.getElementById('scan-search');

  function statusVariant(status: string): 'high' | 'mid' | 'low' {
    if (status === 'matched') return 'high';
    if (status === 'pending') return 'mid';
    return 'low';
  }

  function formatDate(dateStr: string): string {
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return dateStr;
    return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function renderTable() {
    if (!tbody) return;
    if (allResults.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="empty-row">No scan results</td></tr>';
      return;
    }

    tbody.innerHTML = allResults.map((r) => `
      <tr>
        <td>${r.title}</td>
        <td>${r.company}</td>
        <td>${r.location}</td>
        <td class="hermes-mono" data-mono="true">${r.score.toFixed(1)}</td>
        <td class="hermes-mono" data-mono="true">${formatDate(r.date)}</td>
        <td class="data-table__td--right">
          <a href="${r.url}" class="data-table__link" target="_blank" rel="noopener">View</a>
        </td>
      </tr>
    `).join('');
  }

  async function loadScan() {
    try {
      const res = await fetch('/api/scan', { cache: 'no-store' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      allResults = data.results || [];
      renderTable();
      if (countEl) countEl.textContent = String(allResults.length);
      loadingEl?.setAttribute('hidden', '');
      errorEl?.setAttribute('hidden', '');
      contentEl?.removeAttribute('hidden');
    } catch (error) {
      loadingEl?.setAttribute('hidden', '');
      contentEl?.setAttribute('hidden', '');
      errorEl?.removeAttribute('hidden');
    }
  }

  // Search handler
  document.getElementById('scan-search')?.addEventListener('input', (e) => {
    const value = (e.target as HTMLInputElement).value.toLowerCase();
    // Filter logic here
  });

  loadScan();
</script>

<style>
  .scan-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .scan-page__hero {
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .scan-page__title {
    margin: 0 0 var(--space-1);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .scan-page__subtitle {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .scan-page__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .scan-page__url-input {
    flex: 1;
    min-width: min(100%, var(--size-80));
  }

  .scan-page__filter {
    font-family: var(--font-sans);
    min-width: var(--size-36);
  }

  .scan-page__state {
    display: flex;
    justify-content: center;
    padding: var(--space-10);
  }

  .scan-page__table-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .scan-page__section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .scan-page__section-title {
    margin: 0;
    font-size: var(--text-lg);
  }

  .scan-page__count {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .data-table-panel {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .data-table-panel__scroll {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table thead th {
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-muted);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    background: var(--bg-card);
    white-space: nowrap;
    cursor: pointer;
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right;
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    color: var(--text-primary);
  }

  .data-table tbody tr:hover td {
    background: var(--bg-tertiary);
  }

  .data-table__link {
    color: var(--accent-primary);
    text-decoration: none;
    min-height: auto;
  }

  .data-table__link:hover {
    text-decoration: underline;
  }

  .empty-row {
    padding: var(--space-8);
    text-align: center;
    color: var(--text-muted);
  }
</style>