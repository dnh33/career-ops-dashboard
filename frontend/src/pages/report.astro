---
import PageLayout from '../components/layout/PageLayout.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import MetricCard from '../components/primitives/MetricCard.astro';
import DataTable from '../components/primitives/DataTable.astro';
import EmptyState from '../components/primitives/EmptyState.astro';
import StatusPill from '../components/primitives/StatusPill.astro';
import Loader from '../components/primitives/Loader.astro';
import ErrorState from '../components/primitives/ErrorState.astro';
---

<PageLayout
  title="Report"
  pageTitle="Report"
  description="View detailed evaluation report."
  currentPath="/report"
>
  <div slot="hero" class="report-page__hero">
    <h1 class="report-page__title">Report</h1>
    <p class="report-page__subtitle">View detailed evaluation report.</p>
  </div>

  <div slot="actions" class="report-page__actions">
    <a href="/reports" class="toolbar-btn">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Reports
    </a>
    <button id="pdf-btn" class="toolbar-btn toolbar-btn-primary">Generate PDF</button>
  </div>

  <section class="report-page__table-section" aria-label="Report content">
    <!-- Loading -->
    <div id="report-loading" class="report-page__state">
      <Loader label="Loading report" size="lg" />
    </div>

    <!-- Error -->
    <div id="report-error" class="report-page__state" hidden>
      <ErrorState title="Report unavailable" message="Could not load the evaluation report." />
    </div>

    <!-- Report content (populated client-side) -->
    <div id="report-content" class="hidden space-y-6">
      <!-- Score Hero -->
      <div class="report-page__score-section">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h1 class="text-2xl font-bold text-[var(--text-primary)] truncate" id="report-title">—</h1>
            <p class="text-[var(--text-secondary)] mt-1" id="report-role">—</p>
            <p class="text-xs text-[var(--text-muted)] mt-1 font-mono" id="report-date"></p>
            <span class="inline-block mt-2 px-2 py-0.5 text-xs rounded bg-[var(--bg-tertiary)] text-[var(--text-secondary)] hidden" id="report-legitimacy"></span>
          </div>
          <div class="text-center shrink-0" id="report-score-section">
            <div class="text-5xl font-bold text-[var(--accent-primary)]" id="report-score">—</div>
            <span class="inline-block mt-2 px-3 py-0.5 text-xs border border-[var(--accent-primary)] text-[var(--accent-primary)] rounded-full" id="report-grade"></span>
            <p class="text-xs text-[var(--text-secondary)] mt-2 max-w-[var(--max-width-card)] mx-auto" id="report-archetype"></p>
          </div>
        </div>
      </div>

      <!-- Action Bar -->
      <div class="flex flex-wrap gap-3">
        <button id="pdf-btn" class="toolbar-btn toolbar-btn-primary">Generate PDF</button>
        <a href="/tracker" class="toolbar-btn">Track this</a>
        <a href="/reports" class="toolbar-btn">Compare</a>
      </div>

      <!-- Report Content Blocks -->
      <div id="report-blocks" class="space-y-4"></div>
    </div>
  </section>
</PageLayout>

<script>
  import { scoreToGrade, gradeClass, gradeColorVars } from '../utils/colors';

  function escapeHtml(s: string) {
    return String(s).replace(/&/g, '&').replace(/</g, '<').replace(/>/g, '>').replace(/\"/g, '"');
  }

  function renderMd(md: string) {
    return md
      .replace(/&/g, '&').replace(/</g, '<').replace(/>/g, '>')
      .replace(/\*\*(.+?)\*\*/g, '<strong class="text-[var(--text-primary)]">$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/`(.+?)`/g, '<code class="px-1.5 py-0.5 bg-[var(--bg-tertiary)] rounded text-xs font-mono text-[var(--text-primary)]">$1</code>')
      .replace(/^- (.+)$/gm, '<li class="ml-4 list-disc">$1</li>')
      .replace(/^### (.+)$/gm, '<h4 class="text-base font-semibold text-[var(--text-primary)] mt-3 mb-1">$1</h4>')
      .replace(/\n\n/g, '</p><p class="mt-2">');
  }

  const API_BASE = '';

  // Extract report ID from query param: /report?id=X
  const urlParams = new URLSearchParams(window.location.search);
  const reportId = urlParams.get('id') || '';

  const loadingEl = document.getElementById('report-loading');
  const errorEl = document.getElementById('report-error');
  const contentEl = document.getElementById('report-content');
  const errorMsg = document.getElementById('error-msg') as HTMLElement | null;
  const pdfBtn = document.getElementById('pdf-btn');

  if (pdfBtn) {
    pdfBtn.addEventListener('click', function() {
      fetch(`${API_BASE}/api/output/generate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ report_id: reportId }),
      }).then(async function(res) {
        if (res.ok) alert('PDF generation started');
        else { const d = await res.json(); alert(d.detail || 'Failed to generate PDF'); }
      }).catch(function() { alert('Backend unavailable'); });
    });
  }

  function renderBlocks(content: string) {
    const blocksEl = document.getElementById('report-blocks');
    if (!blocksEl) return;

    const sections: Array<{ letter: string; title: string; body: string }> = [];
    const pattern = /^## (?:Block\s+)?([A-G])(?:\\)\s*|:\\s*|\\s+—\\s+|\\s+)(.+)?$/gm;
    const matches: Array<{ idx: number; letter: string; title: string; headerLen: number }> = [];
    let m: RegExpExecArray | null;
    while ((m = pattern.exec(content)) !== null) {
      matches.push({ idx: m.index, letter: m[1], title: (m[2] || `Block ${m[1]}`).trim(), headerLen: m[0].length });
    }
    matches.forEach(function(match, i) {
      const start = match.idx + match.headerLen + 2;
      const end = i + 1 < matches.length ? matches[i+1].idx : content.length;
      sections.push({ letter: match.letter, title: match.title, body: content.slice(start, end).trim() });
    });

    if (sections.length === 0) {
      blocksEl.innerHTML = '<pre class="whitespace-pre-wrap text-sm text-[var(--text-primary)] bg-[var(--bg-secondary)] rounded-lg p-6 overflow-x-auto">' + escapeHtml(content) + '</pre>';
      return;
    }

    blocksEl.innerHTML = sections.map(function(s) {
      const cv = gradeColorVars(s.letter);
      return `<details class="group bg-[var(--bg-secondary)] border-l-4 border-[var(--accent-primary)] rounded-lg overflow-hidden" open>` +
        `<summary class="flex items-center justify-between p-4 cursor-pointer select-none hover:bg-[var(--bg-tertiary)]/50 list-none">` +
        `<div class="flex items-center gap-3">` +
        `<span class="${gradeClass(s.letter)} w-8 h-8 flex items-center justify-center text-sm font-bold">${s.letter}</span>` +
        `<span class="font-medium text-[var(--text-primary)]">${escapeHtml(s.title)}</span></div>` +
        `<svg class="w-4 h-4 text-[var(--text-muted)] group-open:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">` +
        `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></summary>` +
        `<div class="px-4 pb-4 pt-2 text-sm text-[var(--text-primary)] leading-relaxed">${renderMd(s.body)}</div></details>`;
    }).join('');
  }

  async function loadReport() {
    if (!reportId) {
      if (loadingEl) loadingEl.classList.add('hidden');
      if (errorEl) errorEl.classList.remove('hidden');
      if (errorMsg) errorMsg.textContent = 'Invalid report ID';
      return;
    }

    try {
      const res = await fetch(`${API_BASE}/api/reports/${reportId}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const report = await res.json();

      if (loadingEl) loadingEl.classList.add('hidden');

      const titleEl = document.getElementById('report-title');
      const roleEl = document.getElementById('report-role');
      const dateEl = document.getElementById('report-date');
      if (titleEl) titleEl.textContent = report.company || report.id;
      if (roleEl) roleEl.textContent = report.role || 'No role specified';
      if (dateEl) dateEl.textContent = report.date || '';

      const legitimacyEl = document.getElementById('report-legitimacy');
      if (report.legitimacy && legitimacyEl) {
        legitimacyEl.textContent = report.legitimacy;
        legitimacyEl.classList.remove('hidden');
      }

      if (report.score != null && report.score > 0) {
        const scoreEl = document.getElementById('report-score');
        const gradeEl = document.getElementById('report-grade');
        const archetypeEl = document.getElementById('report-archetype');
        if (scoreEl) scoreEl.textContent = report.score + '/5';
        if (gradeEl) gradeEl.textContent = 'Grade ' + scoreToGrade(report.score);
        if (report.archetype && archetypeEl) archetypeEl.textContent = report.archetype;
      }

      if (report.content) {
        renderBlocks(report.content);
      }

      if (contentEl) contentEl.classList.remove('hidden');
    } catch (e) {
      console.error('Failed to load report:', e);
      if (loadingEl) loadingEl.classList.add('hidden');
      if (errorEl) errorEl.classList.remove('hidden');
      if (errorMsg) errorMsg.textContent = 'Unable to connect to backend';
    }
  }

  loadReport();
</script>

<style>
  .report-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .report-page__hero {
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .report-page__title {
    margin: 0 0 var(--space-1);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .report-page__subtitle {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .report-page__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .report-page__score-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-4);
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-xl);
  }

  .report-page__table-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .report-page__state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-10);
  }

  @media (max-width: 1024px) {
    .report-page__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>