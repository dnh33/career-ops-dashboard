---
import HermesLayout from '../layouts/HermesLayout.astro';
---

<HermesLayout title="Output" currentPath="/output" pageTitle="Output" description="View and manage generated outputs.">
  <main class="content-container">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-xl sm:text-2xl font-bold text-[var(--text-primary)]">Generated PDFs</h2>
        <p class="text-[var(--text-secondary)] text-sm mt-1">Browse, preview, and download tailored resumes &amp; cover letters.</p>
      </div>
      <button
        id="regenerate-all-btn"
        onclick="confirmRegenerate()"
        class="inline-flex items-center gap-2 rounded-md bg-amber-600 hover:bg-amber-500 text-sm font-medium text-white px-4 py-2 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        Regenerate All
      </button>
    </div>

    <!-- Generation Status Toast -->
    <div id="toast" class="hidden fixed bottom-6 right-6 z-50 rounded-lg bg-[var(--bg-tertiary)] border border-[var(--border-hover)] px-4 py-3 shadow-lg flex items-center gap-3 transition-all">
      <div id="toast-spinner" class="w-4 h-4 border-2 border-amber-500 border-t-transparent rounded-full animate-spin"></div>
      <span id="toast-message" class="text-sm text-[var(--text-primary)]"></span>
    </div>

    <!-- PDF List Container -->
    <div id="output-container" class="space-y-4">
      <!-- Loading skeleton -->
      <div class="animate-pulse space-y-4" id="skeleton">
        <div class="h-24 bg-[var(--bg-tertiary)] rounded-lg"></div>
        <div class="h-24 bg-[var(--bg-tertiary)] rounded-lg"></div>
        <div class="h-24 bg-[var(--bg-tertiary)] rounded-lg"></div>
      </div>
    </div>

    <!-- PDF Viewer Modal -->
    <div id="pdf-modal" class="hidden fixed inset-0 z-40 flex items-center justify-center bg-black/80 backdrop-blur-sm" onclick="closePdfModal(event)">
      <div class="relative w-full max-w-5xl h-[90vh] mx-4 bg-[var(--text-inverse)] rounded-xl border border-[var(--border-hover)] overflow-hidden flex flex-col" onclick="event.stopPropagation()">
        <div class="flex items-center justify-between px-5 py-3 border-b border-[var(--border-hover)]">
          <span id="pdf-modal-title" class="text-sm font-medium text-[var(--text-primary)] truncate">document.pdf</span>
          <div class="flex items-center gap-3">
            <a id="pdf-modal-download" href="#" target="_blank" class="text-xs text-amber-400 hover:text-amber-300">Download</a>
            <button onclick="closePdfModal()" class="text-[var(--text-secondary)] hover:text-white p-1" aria-label="Close viewer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        </div>
        <iframe id="pdf-frame" src="" class="flex-1 w-full border-0" title="PDF Preview"></iframe>
      </div>
    </div>
  </main>

  <script>
    interface OutputFile {
      id: string;
      filename: string;
      type: string;
      created_at: string;
      size_bytes: number;
      view_url: string;
      download_url: string;
      source_report_url?: string;
    }

    // --- Utilities ---
    function formatDate(iso: string) {
      const d = new Date(iso);
      return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' }) +
        ' ' + d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    }

    function formatSize(bytes: number) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function showToast(message: string, duration = 2500) {
      const toast = document.getElementById('toast');
      const msgEl = document.getElementById('toast-message');
      if (!toast || !msgEl) return;
      msgEl.textContent = message;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), duration);
    }

    // --- PDF Viewer Modal ---
    function openPdfModal(filename: string, url: string) {
      const modal = document.getElementById('pdf-modal');
      const frame = document.getElementById('pdf-frame') as HTMLIFrameElement | null;
      const title = document.getElementById('pdf-modal-title');
      const dl = document.getElementById('pdf-modal-download') as HTMLAnchorElement | null;
      if (frame) frame.src = url;
      if (title) title.textContent = filename;
      if (dl) dl.href = url;
      if (modal) modal.classList.remove('hidden');
    }

    function closePdfModal(event?: MouseEvent) {
      if (event && event.target !== event.currentTarget) return;
      const modal = document.getElementById('pdf-modal');
      const frame = document.getElementById('pdf-frame') as HTMLIFrameElement | null;
      if (frame) frame.src = '';
      if (modal) modal.classList.add('hidden');
    }

    // --- Download ---
    function downloadFile(url: string, filename: string) {
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
    }

    // --- Output List Rendering ---
    function renderEmpty() {
      return `
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <svg class="w-16 h-16 text-[var(--text-muted)] mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
          </svg>
          <p class="text-[var(--text-secondary)] text-lg font-medium">No PDFs generated yet</p>
          <p class="text-[var(--text-muted)] text-sm mt-1">Evaluate a job description and generate your first tailored resume.</p>
          <a href="/evaluate" class="mt-4 inline-flex items-center rounded-md bg-amber-600 hover:bg-amber-500 text-sm font-medium text-white px-4 py-2 transition-colors">
            Evaluate a Job
          </a>
        </div>
      `;
    }

    function renderItem(file: OutputFile) {
      const typeLabel = file.type === 'resume' ? 'Resume' : file.type === 'cover_letter' ? 'Cover Letter' : 'PDF';
      const sourceLink = file.source_report_url
        ? '<a href="' + file.source_report_url + '" class="text-xs text-amber-400 hover:text-amber-300 hover:underline">View source report</a>'
        : '';

      return '<div class="bg-[var(--bg-tertiary)]/60 border border-[var(--border-hover)] rounded-lg p-5 hover:border-[var(--border-hover)] transition-colors cursor-pointer card-interactive" data-id="' + file.id + '">' +
        '<div class="flex flex-col sm:flex-row items-start justify-between gap-4">' +
          '<div class="flex items-center gap-3 min-w-0">' +
            '<div class="shrink-0 w-10 h-10 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center">' +
              '<svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zM8 13h8v1H8v-1zm0 3h8v1H8v-1zm0-6h3v1H8V10z"/></svg>' +
            '</div>' +
            '<div class="min-w-0">' +
              '<p class="text-sm font-medium text-[var(--text-primary)] truncate">' + file.filename + '</p>' +
              '<div class="flex items-center gap-2 mt-0.5 text-xs text-[var(--text-muted)]">' +
                '<span class="inline-flex items-center px-1.5 py-0.5 rounded bg-[var(--border-hover)]/50 text-[var(--text-secondary)]">' + typeLabel + '</span>' +
                '<span>' + formatDate(file.created_at) + '</span>' +
                '<span>' + formatSize(file.size_bytes) + '</span>' +
              '</div>' +
              (sourceLink ? '<div class="mt-1">' + sourceLink + '</div>' : '') +
            '</div>' +
          '</div>' +
          '<div class="shrink-0 flex items-center gap-2">' +
            '<button onclick="openPdfModal(' + JSON.stringify(file.filename) + ', ' + JSON.stringify(file.view_url) + ')" ' +
              'class="inline-flex items-center gap-1.5 text-xs font-medium text-[var(--text-primary)] hover:text-amber-400 px-2 py-1.5 rounded hover:bg-[var(--border-hover)]/50 transition-colors" title="Preview PDF">' +
              '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>' +
              'View' +
            '</button>' +
            '<button onclick="downloadFile(' + JSON.stringify(file.download_url) + ', ' + JSON.stringify(file.filename) + ')" ' +
              'class="inline-flex items-center gap-1.5 text-xs font-medium text-[var(--text-primary)] hover:text-amber-400 px-2 py-1.5 rounded hover:bg-[var(--border-hover)]/50 transition-colors" title="Download PDF">' +
              '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>' +
              'Download' +
            '</button>' +
            '<button onclick="confirmRegenerateOne(' + JSON.stringify(file.id) + ')" ' +
              'class="inline-flex items-center text-xs text-[var(--text-muted)] hover:text-amber-400 px-2 py-1.5 rounded hover:bg-[var(--border-hover)]/50 transition-colors" title="Regenerate this PDF">' +
              '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>' +
            '</button>' +
          '</div>' +
        '</div>' +
      '</div>';
    }

    async function loadOutput() {
      const container = document.getElementById('output-container');
      const skeleton = document.getElementById('skeleton');
      if (skeleton) skeleton.style.display = 'none';
      if (!container) return;

      try {
        const res = await fetch('/api/output');
        if (!res.ok) throw new Error('Failed to load output files');
        const data = await res.json();
        const files: OutputFile[] = data.files || [];

        if (files.length === 0) {
          container.innerHTML = renderEmpty();
          return;
        }

        files.sort((a: OutputFile, b: OutputFile) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
        container.innerHTML = files.map(renderItem).join('');
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : 'Unknown error';
        container.innerHTML = '<div class="flex flex-col items-center justify-center py-16 text-center">' +
          '<svg class="w-12 h-12 text-red-400 mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>' +
          '<p class="text-[var(--text-primary)] font-medium">Failed to load PDFs</p>' +
          '<p class="text-[var(--text-muted)] text-sm mt-1">' + message + '</p>' +
          '<button onclick="location.reload()" class="mt-3 text-sm text-amber-400 hover:text-amber-300">Retry</button>' +
        '</div>';
      }
    }

    // --- Confirm Regenerate ---
    function confirmRegenerate() {
      const ok = window.confirm('Regenerate all PDFs? This will overwrite existing files with fresh versions from the latest source reports.');
      if (!ok) return;
      triggerRegenerate(null);
    }

    function confirmRegenerateOne(fileId: string) {
      const ok = window.confirm('Regenerate this PDF? It will be overwritten with a fresh version.');
      if (!ok) return;
      triggerRegenerate(fileId);
    }

    async function triggerRegenerate(fileId: string | null) {
      const spinner = document.getElementById('toast-spinner');
      const toast = document.getElementById('toast');
      const msg = document.getElementById('toast-message');
      if (spinner) spinner.style.display = 'block';
      if (msg) msg.textContent = 'Generating PDFs...';
      if (toast) toast.classList.remove('hidden');

      try {
        const res = await fetch('/api/output/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(fileId ? { file_id: fileId } : {})
        });
        if (!res.ok) throw new Error('Generation failed');

        showToast('Refresh to see new files \u2014 reloading...', 1800);
        setTimeout(function() { location.reload(); }, 1800);
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : 'Unknown error';
        if (spinner) spinner.style.display = 'none';
        showToast('Error: ' + message);
      }
    }

    // --- Keyboard shortcut: ESC closes modal ---
    document.addEventListener('keydown', function(e: KeyboardEvent) {
      if (e.key === 'Escape') closePdfModal();
    });

    // --- Init ---
    loadOutput();
  </script>

  <style>
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    .animate-spin {
      animation: spin 0.7s linear infinite;
    }
  </style>
</HermesLayout>
