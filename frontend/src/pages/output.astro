---
import PageLayout from '../components/layout/PageLayout.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import MetricCard from '../components/primitives/MetricCard.astro';
import DataTable from '../components/primitives/DataTable.astro';
import EmptyState from '../components/primitives/EmptyState.astro';
import StatusPill from '../components/primitives/StatusPill.astro';
import Loader from '../components/primitives/Loader.astro';
import ErrorState from '../components/primitives/ErrorState.astro';
import CodeBlock from '../components/primitives/CodeBlock.astro';
---

<PageLayout
  title="Output"
  pageTitle="Output"
  description="View and manage generated outputs."
  currentPath="/output"
>
  <div slot="hero" class="output-page__hero">
    <h1 class="output-page__title">Generated PDFs</h1>
    <p class="output-page__subtitle">Browse, preview, and download tailored resumes & cover letters.</p>
  </div>

  <div slot="actions" class="output-page__actions">
    <button
      id="regenerate-all-btn"
      class="toolbar-btn toolbar-btn-primary"
      data-action="output-regenerate-all"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Regenerate All
    </button>
  </div>

  <section class="output-page__table-section" aria-label="Generated PDFs">
    <div class="data-table-panel">
      <div class="data-table-panel__scroll">
        <table class="data-table" id="output-table" aria-label="Generated PDFs">
          <thead>
            <tr>
              <th scope="col">Filename</th>
              <th scope="col">Type</th>
              <th scope="col" class="hermes-mono" data-mono="true">Date</th>
              <th scope="col" class="hermes-mono" data-mono="true">Size</th>
              <th scope="col" class="data-table__th--right">Actions</th>
            </tr>
          </thead>
          <tbody id="output-table-body"></tbody>
        </table>
      </div>
    </div>

    <div id="output-empty" hidden>
      <EmptyState
        title="No PDFs generated yet"
        description="Evaluate a job description and generate your first tailored resume."
        icon="document"
        actionLabel="Evaluate a Job"
        actionHref="/evaluate"
      />
    </div>
  </section>
</PageLayout>

<script>
  interface OutputFile {
    id: string;
    filename: string;
    type: string;
    created_at: string;
    size_bytes: number;
    view_url: string;
    download_url: string;
    source_report_url?: string;
  }

  function formatDate(iso: string) {
    const d = new Date(iso);
    return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' }) +
      ' ' + d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
  }

  function formatSize(bytes: number) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  async function loadOutput() {
    const container = document.getElementById('output-table-body');
    const emptyEl = document.getElementById('output-empty');
    if (!container) return;

    try {
      const res = await fetch('/api/output');
      if (!res.ok) throw new Error('Failed to load output files');
      const data = await res.json();
      const files: OutputFile[] = data.files || [];

      if (files.length === 0) {
        emptyEl.hidden = false;
        container.innerHTML = '';
        return;
      }

      emptyEl.hidden = true;

      files.sort((a: OutputFile, b: OutputFile) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());

      container.innerHTML = files.map(file => `
        <tr data-id="${file.id}">
          <td>${file.filename}</td>
          <td>${file.type === 'resume' ? 'Resume' : file.type === 'cover_letter' ? 'Cover Letter' : 'PDF'}</td>
          <td class="hermes-mono" data-mono="true">${formatDate(file.created_at)}</td>
          <td class="hermes-mono" data-mono="true">${formatSize(file.size_bytes)}</td>
          <td class="hermes-mono data-table__td--right">
            <div class="flex items-center gap-2 justify-end">
              <button
                data-action="output-preview"
                data-filename="${JSON.stringify(file.filename)}"
                data-url="${JSON.stringify(file.view_url)}"
                class="toolbar-btn"
                title="Preview PDF"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                View
              </button>
              <a
                href="${file.download_url}"
                class="toolbar-btn"
                download="${file.filename}"
                title="Download PDF"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
                Download
              </a>
            </div>
          </td>
        </tr>
      `).join('');
    } catch (err) {
      console.error('Failed to load output:', err);
      const errorEl = document.getElementById('output-empty');
      if (errorEl) {
        errorEl.hidden = false;
        errorEl.querySelector('.empty-state__message')!.textContent = 'Failed to load output files';
      }
    }
  }

  // Delegated event listeners
    document.addEventListener('click', (e: Event) => {
      const btn = (e.target as HTMLElement).closest('[data-action="output-preview"]');
      if (btn) {
        const filename = btn.getAttribute('data-filename');
        const url = btn.getAttribute('data-url');
        if (filename && url) openPdfModal(filename, url);
      }
    });

    // PDF Modal
    function openPdfModal(filename: string, url: string) {
      const modal = document.getElementById('pdf-modal');
      const frame = document.getElementById('pdf-frame') as HTMLIFrameElement | null;
      const title = document.getElementById('pdf-modal-title');
      const dl = document.getElementById('pdf-modal-download') as HTMLAnchorElement | null;
      if (frame) frame.src = url;
      if (title) title.textContent = filename;
      if (dl) dl.href = url;
      if (modal) modal.classList.remove('hidden');
    }

    function closePdfModal(event?: MouseEvent) {
      if (event && event.target !== event.currentTarget) return;
      const modal = document.getElementById('pdf-modal');
      const frame = document.getElementById('pdf-frame') as HTMLIFrameElement | null;
      if (frame) frame.src = '';
      if (modal) modal.classList.add('hidden');
    }

    document.addEventListener('click', (e: Event) => {
      const btn = (e.target as HTMLElement).closest('[data-action="pdf-modal-close"]');
      if (btn) closePdfModal(e);
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closePdfModal();
    });
  </script>

  <style>
    .output-page {
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }

    .output-page__hero {
      padding-bottom: var(--space-4);
      border-bottom: var(--border-width) solid var(--border-default);
    }

    .output-page__title {
      margin: 0 0 var(--space-1);
      font-size: var(--text-2xl);
      font-weight: 700;
      font-family: var(--font-display);
      color: var(--text-primary);
    }

    .output-page__subtitle {
      margin: 0;
      font-size: var(--text-sm);
      color: var(--text-secondary);
    }

    .output-page__actions {
      display: flex;
      justify-content: flex-end;
    }

    .output-page__table-section {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .data-table-panel {
      background: var(--bg-card);
      border: var(--border-width) solid var(--border-default);
      box-shadow: var(--shadow-md);
    }

    .data-table-panel__scroll {
      overflow-x: auto;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--text-sm);
    }

    .data-table thead th {
      text-align: left;
      font-weight: 600;
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: var(--letter-spacing-tight);
      color: var(--text-muted);
      padding: var(--space-3) var(--space-4);
      border-bottom: var(--border-width) solid var(--border-default);
      background: var(--bg-card);
      white-space: nowrap;
      cursor: pointer;
    }

    .data-table__th--right,
    .data-table__td--right {
      text-align: right;
    }

    .data-table tbody td {
      padding: var(--space-3) var(--space-4);
      border-bottom: var(--border-width) solid var(--border-default);
      color: var(--text-primary);
    }

    .data-table tbody tr:hover td {
      background: var(--bg-tertiary);
    }

    .empty-row {
      padding: var(--space-8);
      text-align: center;
      color: var(--text-muted);
    }

    .toolbar-btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-1-1);
      padding: var(--space-2) var(--space-3);
      border: var(--border-width) solid var(--border-default);
      background: var(--bg-elevated);
      box-shadow: var(--shadow-md);
      color: var(--text-secondary);
      font-family: var(--font-sans);
      font-size: var(--text-xs);
      min-height: auto;
      cursor: pointer;
      white-space: nowrap;
      transition: color var(--transition-base), background-color var(--transition-base);
    }

    .toolbar-btn:hover {
      color: var(--text-primary);
      background: var(--bg-tertiary);
    }

    @media (max-width: 1024px) {
      .output-page__actions {
        flex-direction: column;
        align-items: stretch;
      }
    }
  </style>