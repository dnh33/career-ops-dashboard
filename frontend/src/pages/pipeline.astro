---
import PageLayout from '../components/layout/PageLayout.astro';
import SearchField from '../components/primitives/SearchField.astro';
import SegmentedControl from '../components/primitives/SegmentedControl.astro';
import Loader from '../components/primitives/Loader.astro';
import ErrorState from '../components/primitives/ErrorState.astro';
import StatusPill from '../components/primitives/StatusPill.astro';
---

<PageLayout
  title="Pipeline"
  pageTitle="Pipeline"
  description="Manage and monitor the pipeline queue."
  currentPath="/pipeline"
>
  <div slot="hero" class="pipeline-page__hero">
    <h1 class="pipeline-page__title">Pipeline</h1>
    <p class="pipeline-page__subtitle">Manage and monitor the evaluation pipeline queue.</p>
  </div>

  <div slot="actions" class="pipeline-page__toolbar">
    <div class="pipeline-page__add-form">
      <SearchField
        id="bulk-input"
        name="bulk-input"
        type="url"
        placeholder="Paste URLs here, one per line..."
        class="pipeline-page__bulk-input"
      />
      <button id="add-btn" type="button" class="toolbar-btn toolbar-btn-primary" data-action="pipeline-add-bulk">
        Add <span id="add-count">0</span>
      </button>
    </div>
    <p id="bulk-error" class="text-xs text-[var(--grade-low)] mt-1 hidden"></p>
  </div>

  <section class="pipeline-page__table-section" aria-label="Pipeline queue">
    <header class="pipeline-page__section-header">
      <h2 class="pipeline-page__section-title">Queue</h2>
      <span id="pipeline-count" class="pipeline-page__count hermes-mono" data-mono="true">0</span>
    </header>
    <div class="data-table-panel">
      <div class="data-table-panel__scroll">
        <table class="data-table" id="pipeline-table" aria-label="Pipeline queue">
          <thead>
            <tr>
              <th scope="col" data-sort-key="status" tabindex="0" role="button">Status</th>
              <th scope="col" data-sort-key="url" tabindex="0" role="button">URL</th>
              <th scope="col" data-sort-key="date" tabindex="0" role="button">Date Added</th>
              <th scope="col" class="data-table__th--right">Actions</th>
            </tr>
          </thead>
          <tbody id="pipeline-table-body"></tbody>
        </table>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  interface PipelineEntry {
    url: string;
    status: string;
    date_added: string;
    evaluated_at?: string;
  }

  let allItems: PipelineEntry[] = [];
  let sortKey: keyof PipelineEntry = 'date_added';
  let sortDir: 'asc' | 'desc' = 'desc';

  const list = document.getElementById('pipeline-table-body') as HTMLTableSectionElement;
  const countEl = document.getElementById('pipeline-count') as HTMLSpanElement;
  const bulkInput = document.getElementById('bulk-input') as HTMLTextAreaElement;
  const addBtn = document.getElementById('add-btn') as HTMLButtonElement;
  const addCount = document.getElementById('add-count') as HTMLSpanElement;
  const bulkError = document.getElementById('bulk-error') as HTMLParagraphElement;

  function statusTag(s: string): string {
    if (!s) return 'tag-neutral';
    const lc = s.toLowerCase();
    if (lc === 'done' || lc === 'evaluated') return 'tag-high';
    if (lc === 'running' || lc === 'processing') return 'tag-mid';
    if (lc === 'error' || lc === 'failed') return 'tag-low';
    return 'tag-neutral';
  }

  function relDate(d: string | null | undefined): string {
    if (!d) return '—';
    const diff = (Date.now() - new Date(d).getTime()) / 86400000;
    if (diff < 1) return 'Today';
    if (diff < 2) return 'Yesterday';
    if (diff < 7) return `${Math.floor(diff)}d ago`;
    return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  async function load() {
    try {
      const res = await fetch('/api/pipeline');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      allItems = data.entries || data.items || data || [];
      countEl.textContent = `${allItems.length} items`;
      render();
    } catch (e) {
      list.innerHTML = '<div class="empty-row">Failed to load <button class="toolbar-btn" data-action="pipeline-reload" style="margin-left: var(--space-2);">Retry</button></div>';
    }
  }

  function render() {
    let items = [...allItems];
    items.sort((a, b) => {
      const av = a[sortKey] ?? '';
      const bv = b[sortKey] ?? '';
      if (typeof av === 'number' && typeof bv === 'number') return sortDir === 'asc' ? av - bv : bv - av;
      return sortDir === 'asc' ? String(av).localeCompare(String(bv)) : String(bv).localeCompare(String(av));
    });

    if (items.length === 0) {
      list.innerHTML = '<div class="empty-row">Nothing in queue</div>';
      return;
    }

    list.innerHTML = items.map(p => `
      <tr class="data-row" style="gap: var(--space-3);">
        <span class="tag ${statusTag(p.status)}" style="min-width: var(--size-15); justify-content: center; font-size: var(--text-xs);">${p.status || 'pending'}</span>
        <div style="flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
          <span style="color: var(--text-primary); font-size: var(--text-sm);">${new URL(p.url).hostname.replace('www.', '')}</span>
          <span style="color: var(--text-muted); font-size: var(--text-xs); margin-left: var(--space-2);">${relDate(p.date_added)}</span>
        </div>
        <div style="display: flex; gap: var(--space-1); flex-shrink: 0;">
          ${p.status !== 'done' && p.status !== 'evaluated' ? `<a href="/evaluate?url=${encodeURIComponent(p.url)}" class="toolbar-btn" style="font-size: var(--text-xs); padding: var(--space-1) var(--space-2);">Eval</a>` : ''}
          <button class="toolbar-btn" style="font-size: var(--text-xs); padding: var(--space-1) var(--space-2);" data-action="pipeline-remove" data-url="${p.url}">✕</button>
        </div>
      </tr>
    `).join('');
  }

  // Bulk add
  bulkInput.addEventListener('input', () => {
    const urls = bulkInput.value.split('\n').map(u => u.trim()).filter(u => u.length > 0);
    addCount.textContent = String(urls.length);
  });

  addBtn.addEventListener('click', async () => {
    const urls = bulkInput.value.split('\n').map(u => u.trim()).filter(u => u.length > 0);
    if (urls.length === 0) return;

    addBtn.disabled = true;
    bulkError.classList.add('hidden');

    try {
      for (const url of urls) {
        await fetch('/api/pipeline', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url })
        });
      }
      bulkInput.value = '';
      addCount.textContent = '0';
      await load();
    } catch (e) {
      bulkError.textContent = `Failed: ${e instanceof Error ? e.message : 'Unknown error'}`;
      bulkError.classList.remove('hidden');
    } finally {
      addBtn.disabled = false;
    }
  });

  // Delegated actions
  document.addEventListener('click', (e: Event) => {
    const btn = (e.target as HTMLElement).closest('[data-action="pipeline-reload"]');
    if (btn) {
      load();
      return;
    }
    const removeBtn = (e.target as HTMLElement).closest('[data-action="pipeline-remove"]');
    if (removeBtn) {
      const url = removeBtn.getAttribute('data-url');
      if (url) removeItem(url);
    }
  });

  async function removeItem(url: string) {
    try {
      await fetch('/api/pipeline', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url })
      });
      allItems = allItems.filter(i => i.url !== url);
      countEl.textContent = `${allItems.length} items`;
      render();
    } catch (e) {
      console.error('Remove failed:', e);
    }
  }

  load();
</script>

<style>
  .pipeline-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .pipeline-page__hero {
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .pipeline-page__title {
    margin: 0 0 var(--space-1);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .pipeline-page__subtitle {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .pipeline-page__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .pipeline-page__add-form {
    flex: 1;
    min-width: 0;
  }

  .pipeline-page__bulk-input {
    width: 100%;
    min-height: var(--size-28);
    background: var(--bg-input);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-2-5);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    resize: vertical;
  }

  .pipeline-page__toolbar-actions {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
  }

  .pipeline-page__section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .pipeline-page__section-title {
    margin: 0;
    font-size: var(--text-lg);
  }

  .pipeline-page__count {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .data-table-panel {
    background: var(--bg-card);
    border: var(--border-width) solid var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .data-table-panel__scroll {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table thead th {
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-muted);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    background: var(--bg-card);
    white-space: nowrap;
    cursor: pointer;
  }

  .data-table__th--right,
  .data-table__td--right {
    text-align: right;
  }

  .data-table tbody td {
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width) solid var(--border-default);
    color: var(--text-primary);
  }

  .data-table tbody tr:hover td {
    background: var(--bg-tertiary);
  }

  .data-row {
    display: flex;
    align-items: center;
  }

  .empty-row {
    padding: var(--space-8);
    text-align: center;
    color: var(--text-muted);
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    white-space: nowrap;
  }

  .tag-high {
    color: var(--grade-high);
    border-color: var(--grade-high-border);
    background: var(--grade-high-bg);
  }

  .tag-mid {
    color: var(--grade-mid);
    border-color: var(--grade-mid-border);
    background: var(--grade-mid-bg);
  }

  .tag-low {
    color: var(--grade-low);
    border-color: var(--grade-low-border);
    background: var(--grade-low-bg);
  }

  .tag-neutral {
    color: var(--text-muted);
    border-color: var(--border-hover);
    background: var(--bg-surface);
  }

  @media (max-width: 1024px) {
    .pipeline-page__toolbar {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>