---
import HermesLayout from '../layouts/HermesLayout.astro';
---

<HermesLayout title="Profile & CV" currentPath="/profile" pageTitle="Profile & CV" description="Manage your professional profile and CV.">
  <main class="content-container">
    <h2 class="text-xl sm:text-2xl font-bold mb-6">Profile & CV Manager</h2>

    <!-- Toast container -->
    <div id="toast-container" class="toast-container"></div>

    <!-- ═══ SECTION A: Profile Form ═══ -->
    <section class="mb-8">
      <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-4">Profile</h3>
      <div class="bg-[var(--bg-secondary)] rounded-lg p-4 sm:p-6 border border-[var(--border-default)] space-y-5">

        <!-- Name + Email row -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="profile-name" class="block text-sm font-medium text-[var(--text-primary)] mb-1.5">Full Name</label>
            <input id="profile-name" type="text" class="w-full bg-[var(--bg-primary)] border border-[var(--border-default)] rounded-md px-4 py-2.5 text-[var(--text-primary)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent" placeholder="Your name" />
          </div>
          <div>
            <label for="profile-email" class="block text-sm font-medium text-[var(--text-primary)] mb-1.5">Email</label>
            <input id="profile-email" type="email" class="w-full bg-[var(--bg-primary)] border border-[var(--border-default)] rounded-md px-4 py-2.5 text-[var(--text-primary)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent" placeholder="you@example.com" />
          </div>
        </div>

        <!-- Location + Salary row -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="profile-location" class="block text-sm font-medium text-[var(--text-primary)] mb-1.5">Location</label>
            <input id="profile-location" type="text" class="w-full bg-[var(--bg-primary)] border border-[var(--border-default)] rounded-md px-4 py-2.5 text-[var(--text-primary)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent" placeholder="City, Country" />
          </div>
          <div>
            <label for="profile-salary" class="block text-sm font-medium text-[var(--text-primary)] mb-1.5">Salary Minimum</label>
            <input id="profile-salary" type="number" class="w-full bg-[var(--bg-primary)] border border-[var(--border-default)] rounded-md px-4 py-2.5 text-[var(--text-primary)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent" placeholder="80000" />
          </div>
        </div>

        <!-- Remote Preference -->
        <div>
          <label for="profile-remote" class="block text-sm font-medium text-[var(--text-primary)] mb-1.5">Remote Preference</label>
          <select id="profile-remote" class="cursor-pointer w-full bg-[var(--bg-primary)] border border-[var(--border-default)] rounded-md px-4 py-2.5 text-[var(--text-primary)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent">
            <option value="">Select...</option>
            <option value="remote">Fully Remote</option>
            <option value="hybrid">Hybrid</option>
            <option value="onsite">On-site</option>
            <option value="flexible">Flexible</option>
          </select>
        </div>

        <!-- Target Roles (tags) -->
        <div>
          <label for="profile-target-roles" class="block text-sm font-medium text-[var(--text-primary)] mb-1.5">Target Roles</label>
          <div id="target-roles-tags" class="flex flex-wrap gap-2 mb-2"></div>
          <input id="profile-target-roles" type="text" class="w-full bg-[var(--bg-primary)] border border-[var(--border-default)] rounded-md px-4 py-2.5 text-[var(--text-primary)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent" placeholder="Type a role and press Enter" />
        </div>

        <!-- Skills (tags) -->
        <div>
          <label for="profile-skills" class="block text-sm font-medium text-[var(--text-primary)] mb-1.5">Skills</label>
          <div id="skills-tags" class="flex flex-wrap gap-2 mb-2"></div>
          <input id="profile-skills" type="text" class="w-full bg-[var(--bg-primary)] border border-[var(--border-default)] rounded-md px-4 py-2.5 text-[var(--text-primary)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent" placeholder="Type a skill and press Enter" />
        </div>

        <!-- Languages (tags) -->
        <div>
          <label for="profile-languages" class="block text-sm font-medium text-[var(--text-primary)] mb-1.5">Languages</label>
          <div id="languages-tags" class="flex flex-wrap gap-2 mb-2"></div>
          <input id="profile-languages" type="text" class="w-full bg-[var(--bg-primary)] border border-[var(--border-default)] rounded-md px-4 py-2.5 text-[var(--text-primary)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent" placeholder="Type a language and press Enter" />
        </div>

        <!-- Save Profile button -->
        <div class="pt-2">
          <button id="save-profile-btn" class="px-6 py-2.5 bg-[var(--accent-primary)] hover:bg-[var(--accent-hover)] text-[var(--bg-primary)] font-semibold rounded-md text-sm transition-colors focus-ring-visible">
            Save Profile
          </button>
        </div>
      </div>
    </section>

    <!-- ═══ SECTION B: CV Editor ═══ -->
    <section>
      <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-4">CV (Markdown)</h3>
      <div class="bg-[var(--bg-secondary)] rounded-lg p-4 sm:p-6 border border-[var(--border-default)]">
        <textarea
          id="cv-editor"
          class="w-full h-72 sm:h-96 bg-[var(--bg-primary)] border border-[var(--border-default)] rounded-md p-4 text-[var(--text-primary)] font-mono text-sm resize-y focus:outline-none focus:ring-2 focus:ring-[var(--accent-primary)] focus:border-transparent"
          placeholder="Write your CV in Markdown format..."
        ></textarea>
        <div class="mt-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
          <span class="text-xs text-[var(--text-muted)]">Supports Markdown formatting</span>
          <button id="save-cv-btn" class="px-6 py-2.5 bg-[var(--accent-primary)] hover:bg-[var(--accent-hover)] text-[var(--bg-primary)] font-semibold rounded-md text-sm transition-colors">
            Save CV
          </button>
        </div>
      </div>
    </section>
  </main>
</HermesLayout>

<script>
  // ═══ YAML parse/stringify (simple flat structure) ═══
  interface YAMLResult {
    [key: string]: string | number | string[] | Record<string, string> | null;
  }

  function parseYAML(str: string): YAMLResult {
    const result: YAMLResult = {};
    let currentKey: string | null = null;
    let currentList: string[] | null = null;

    for (const rawLine of str.split('\n')) {
      const line = rawLine.trimEnd();
      if (!line.trim() || line.trim().startsWith('#')) continue;

      // Top-level key: value or key with list/object
      if (!line.startsWith(' ') && !line.startsWith('-')) {
        const colonIdx = line.indexOf(':');
        if (colonIdx === -1) continue;
        currentKey = line.slice(0, colonIdx).trim();
        const val = line.slice(colonIdx + 1).trim();
        if (val) {
          // Scalar value
          result[currentKey] = isNaN(Number(val)) ? val : Number(val);
          currentList = null;
        } else {
          // Could be list or object lookahead
          result[currentKey] = [];
          currentList = [];
        }
      }
      // List item at indent 0 (continuation of top-level list)
      else if (line.match(/^- /) && currentList !== null && currentKey) {
        currentList.push(line.slice(2).trim());
        result[currentKey] = currentList;
      }
      // Indented key: sub-object
      else if (line.match(/^  [a-zA-Z]/) && currentKey) {
        const colonIdx = line.indexOf(':');
        if (colonIdx !== -1) {
          const subKey = line.slice(0, colonIdx).trim();
          const val = line.slice(colonIdx + 1).trim();
          const existing = result[currentKey];
          if (!existing || Array.isArray(existing)) {
            result[currentKey] = {} as Record<string, string>;
          }
          (result[currentKey] as Record<string, string>)[subKey] = val;
          currentList = null;
        }
      }
    }
    return result;
  }

  function toYAML(obj: Record<string, unknown>) {
    const lines: string[] = [];
    for (const [key, val] of Object.entries(obj)) {
      if (val == null || val === '') continue;
      if (Array.isArray(val)) {
        if (val.length === 0) continue;
        lines.push(key + ':');
        for (const item of val) {
          lines.push('- ' + item);
        }
      } else if (typeof val === 'object') {
        lines.push(key + ':');
        for (const [subK, subV] of Object.entries(val as Record<string, unknown>)) {
          lines.push('  ' + subK + ': ' + subV);
        }
      } else {
        lines.push(key + ': ' + val);
      }
    }
    return lines.join('\n') + '\n';
  }

  // ═══ Tag input management ═══
  function createTagInput(inputEl: HTMLInputElement, containerEl: HTMLElement, tags: string[]) {
    function render() {
      containerEl.innerHTML = '';
      tags.forEach((tag, i) => {
        const chip = document.createElement('span');
        chip.className = 'inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full bg-[var(--accent-primary)]/10 text-[var(--accent-primary)] border border-[var(--accent-primary)]/20';
        chip.textContent = tag;
        const remove = document.createElement('button');
        remove.type = 'button';
        remove.className = 'hover:text-white transition-colors ml-0.5 text-[10px] leading-none';
        remove.innerHTML = '&times;';
        remove.addEventListener('click', () => {
          tags.splice(i, 1);
          render();
        });
        chip.appendChild(remove);
        containerEl.appendChild(chip);
      });
    }

    inputEl.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        const val = inputEl.value.trim().replace(/,$/, '');
        if (val && !tags.includes(val)) {
          tags.push(val);
          render();
        }
        inputEl.value = '';
      }
      if (e.key === 'Backspace' && !inputEl.value && tags.length > 0) {
        tags.pop();
        render();
      }
    });

    return { render };
  }

  // ═══ Toast notification ═══
  function showToast(title: string, message: string) {
    const container = document.getElementById('toast-container');
    if (!container) return;
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.innerHTML =
      '<div class="toast-content">' +
        '<div class="toast-title">' + title + '</div>' +
        '<div class="toast-message">' + message + '</div>' +
      '</div>' +
      '<button class="toast-close" aria-label="Dismiss">&times;</button>';
    container.appendChild(toast);

    const close = () => {
      toast.classList.add('toast-exit');
      setTimeout(() => toast.remove(), 150);
    };
    const closeBtn = toast.querySelector('.toast-close');
    if (closeBtn) closeBtn.addEventListener('click', close);
    setTimeout(close, 3000);
  }

  // ═══ State ═══
  let targetRoles: string[] = [];
  let skills: string[] = [];
  let languages: Record<string, string> = {};
  let originalProfile: YAMLResult = {};

  // ═══ DOM refs ═══
  const nameInput = document.getElementById('profile-name') as HTMLInputElement | null;
  const emailInput = document.getElementById('profile-email') as HTMLInputElement | null;
  const locationInput = document.getElementById('profile-location') as HTMLInputElement | null;
  const salaryInput = document.getElementById('profile-salary') as HTMLInputElement | null;
  const remoteSelect = document.getElementById('profile-remote') as HTMLSelectElement | null;
  const targetRolesInput = document.getElementById('profile-target-roles') as HTMLInputElement | null;
  const targetRolesContainer = document.getElementById('target-roles-tags');
  const skillsInput = document.getElementById('profile-skills') as HTMLInputElement | null;
  const skillsContainer = document.getElementById('skills-tags');
  const languagesInput = document.getElementById('profile-languages') as HTMLInputElement | null;
  const languagesContainer = document.getElementById('languages-tags');
  const cvEditor = document.getElementById('cv-editor') as HTMLTextAreaElement | null;
  const saveProfileBtn = document.getElementById('save-profile-btn');
  const saveCVBtn = document.getElementById('save-cv-btn');

  // Tag inputs
  const tagHandler = createTagInput(targetRolesInput!, targetRolesContainer!, targetRoles);
  const skillsHandler = createTagInput(skillsInput!, skillsContainer!, skills);

  // Languages tag input (special: stores as object)
  function renderLanguages() {
    if (!languagesContainer) return;
    languagesContainer.innerHTML = '';
    for (const [lang, level] of Object.entries(languages)) {
      const chip = document.createElement('span');
      chip.className = 'inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20';
      chip.textContent = lang + ' (' + level + ')';
      const remove = document.createElement('button');
      remove.type = 'button';
      remove.className = 'hover:text-white transition-colors ml-0.5 text-[10px] leading-none';
      remove.innerHTML = '&times;';
      remove.addEventListener('click', () => {
        delete languages[lang];
        renderLanguages();
      });
      chip.appendChild(remove);
      languagesContainer.appendChild(chip);
    }
  }
  if (languagesInput) {
    languagesInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        const val = languagesInput.value.trim().replace(/,$/, '');
        if (val && !languages[val]) {
          languages[val] = 'intermediate';
          renderLanguages();
        }
        languagesInput.value = '';
      }
      if (e.key === 'Backspace' && !languagesInput.value) {
        const keys = Object.keys(languages);
        if (keys.length) {
          delete languages[keys[keys.length - 1]];
          renderLanguages();
        }
      }
    });
  }

  // ═══ Load data ═══
  async function loadProfile() {
    try {
      const resp = await fetch('/api/profile');
      const data = await resp.json();
      if (data.profile) {
        const parsed = parseYAML(data.profile);
        originalProfile = parsed;
        if (nameInput) nameInput.value = (parsed.name as string) || '';
        if (emailInput) emailInput.value = (parsed.email as string) || '';
        if (locationInput) locationInput.value = (parsed.location as string) || '';
        if (salaryInput) salaryInput.value = (parsed.salary_min as string) || '';
        if (remoteSelect) remoteSelect.value = (parsed.remote_preference as string) || '';
        targetRoles.length = 0;
        if (Array.isArray(parsed.target_roles)) targetRoles.push(...(parsed.target_roles as string[]));
        tagHandler.render();
        skills.length = 0;
        if (Array.isArray(parsed.skills)) skills.push(...(parsed.skills as string[]));
        skillsHandler.render();
        languages = parsed.languages && typeof parsed.languages === 'object' && !Array.isArray(parsed.languages)
          ? parsed.languages as Record<string, string>
          : {};
        renderLanguages();
      }
    } catch (e: unknown) {
      const message = e instanceof Error ? e.message : 'Unknown error';
      showToast('Error', 'Failed to load profile: ' + message);
    }
  }

  async function loadCV() {
    try {
      const resp = await fetch('/api/cv');
      const data = await resp.json();
      if (data.cv && cvEditor) {
        cvEditor.value = data.cv;
      }
    } catch (e: unknown) {
      const message = e instanceof Error ? e.message : 'Unknown error';
      showToast('Error', 'Failed to load CV: ' + message);
    }
  }

  // ═══ Save handlers ═══
  async function saveProfile() {
    // Merge form values into original profile to preserve unknown fields
    const obj = { ...originalProfile };
    obj.name = nameInput?.value || '';
    obj.email = emailInput?.value || '';
    obj.location = locationInput?.value || '';
    obj.target_roles = targetRoles;
    obj.salary_min = salaryInput?.value ? Number(salaryInput.value) : null;
    obj.skills = skills;
    obj.languages = languages;
    obj.remote_preference = remoteSelect?.value || '';
    const yaml = toYAML(obj as Record<string, unknown>);

    try {
      const resp = await fetch('/api/profile', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ profile: yaml }),
      });
      if (!resp.ok) throw new Error('Server error ' + resp.status);
      showToast('Profile Saved', 'Your profile has been updated successfully.');
    } catch (e: unknown) {
      const message = e instanceof Error ? e.message : 'Unknown error';
      showToast('Error', 'Failed to save profile: ' + message);
    }
  }

  async function saveCV() {
    try {
      const resp = await fetch('/api/cv', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cv: cvEditor?.value || '' }),
      });
      if (!resp.ok) throw new Error('Server error ' + resp.status);
      showToast('CV Saved', 'Your CV has been updated successfully.');
    } catch (e: unknown) {
      const message = e instanceof Error ? e.message : 'Unknown error';
      showToast('Error', 'Failed to save CV: ' + message);
    }
  }

  // ═══ Event wiring ═══
  if (saveProfileBtn) saveProfileBtn.addEventListener('click', saveProfile);
  if (saveCVBtn) saveCVBtn.addEventListener('click', saveCV);

  // ═══ Init ═══
  loadProfile();
  loadCV();
</script>
